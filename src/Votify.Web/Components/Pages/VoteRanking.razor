@page "/event/{EventId}/categories/{CategoryId}/vote-ranking"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Votación - Votify</PageTitle>

<div class="ranking-container">
    <header class="ranking-header">
        <button class="back-btn" @onclick='() => Navigation.NavigateTo($"/event/{EventId}/categories/{CategoryId}/projects")'>
            ← Volver a proyectos
        </button>
        <h1 class="ranking-title">Votación por ranking</h1>
        <p class="ranking-subtitle">
            Selecciona hasta <strong>@TopN proyectos</strong> y ordénalos según tu preferencia.
        </p>
    </header>

    @if (ProyectosDisponibles == null)
    {
        <div class="ranking-loading">
            <div class="spinner"></div>
            <p>Cargando proyectos...</p>
        </div>
    }
    else if (!ProyectosDisponibles.Any())
    {
        <div class="ranking-empty">
            <p>No hay proyectos en esta categoría.</p>
        </div>
    }
    else
    {
        <div class="ranking-grid">
            <div class="ranking-projects-column">
                <h3 class="column-title">Proyectos disponibles</h3>
                <div class="projects-list">
                    @foreach (var p in ProyectosDisponibles.Where(p => !ProyectosSeleccionados.Contains(p)))
                    {
                        <div class="project-card-mini" @onclick="() => SeleccionarProyecto(p)">
                            <strong>@p.Title</strong>
                            @if (!string.IsNullOrWhiteSpace(p.Description))
                            {
                                <p class="project-desc-mini">@p.Description</p>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="ranking-slots-column">
                <h3 class="column-title">Tu ranking</h3>
                <div class="slots-list">
                    @for (int index = 0; index < TopN; index++)
                    {
                        var i = index;
                        var p = i < ProyectosSeleccionados.Count ? ProyectosSeleccionados[i] : null;

                        <div class="slot-card @(p != null ? "filled" : "empty")">
                            <div class="slot-number">@(i + 1)º</div>

                            <div class="slot-body">
                                @if (p != null)
                                {
                                    <div class="slot-title-row">
                                        <strong class="slot-title">@p.Title</strong>
                                        <button class="remove-btn" @onclick="() => QuitarProyecto(p)" title="Quitar">✕</button>
                                    </div>

                                    @if (sesion?.AllowComments == true)
                                    {
                                        <label class="comment-label-inline">
                                            Comentario
                                            @if (sesion.RequireComments)
                                            {
                                                <span class="required-star">*</span>
                                            }
                                            else
                                            {
                                                <span class="optional-tag">(opcional)</span>
                                            }
                                        </label>
                                        <textarea class="comment-textarea"
                                                  placeholder="@(sesion.RequireComments ? "Comentario obligatorio..." : "Comentario anónimo opcional...")"
                                                  rows="2"
                                                  maxlength="500"
                                                  @bind="comentarios[p.Id]"
                                                  @bind:event="oninput">
                                        </textarea>
                                        <div class="char-count">@((comentarios.TryGetValue(p.Id, out var txt) ? txt?.Length : 0) ?? 0)/500</div>
                                    }
                                }
                                else
                                {
                                    <span class="empty-text">Haz clic en un proyecto para añadirlo aquí</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (error != null)
                {
                    <div class="error-banner">@error</div>
                }

                <button class="btn-primary submit-vote-btn" disabled="@(!ProyectosSeleccionados.Any())" @onclick="EnviarVoto">
                    Confirmar Mi Voto
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string EventId { get; set; } = "";
    [Parameter] public string CategoryId { get; set; } = "";

    private int TopN = 3;
    private string SessionId = "";
    private string UserId = "";
    private string? error;

    private VotingSessionDto? sesion;
    private List<ProjectDto>? ProyectosDisponibles;
    private List<ProjectDto> ProyectosSeleccionados = new();
    private Dictionary<string, string> comentarios = new();

    protected override async Task OnInitializedAsync()
    {
        var http = HttpClientFactory.CreateClient("API");

        var cats = await http.GetFromJsonAsync<List<CategorySimpleDto>>($"api/categories/by-event/{EventId}");
        var categoriaActual = cats?.FirstOrDefault(c => c.Id == CategoryId);
        if (categoriaActual != null) TopN = categoriaActual.TopNProjectsAllowed;

        try
        {
            var sesiones = await http.GetFromJsonAsync<List<VotingSessionDto>>(
                $"api/votingsessions/by-category/{CategoryId}");
            sesion = sesiones?.FirstOrDefault(s =>
                s.EvaluationType is "TopN" or "2");
            if (sesion != null) SessionId = sesion.Id;
        }
        catch { }

        ProyectosDisponibles = await http.GetFromJsonAsync<List<ProjectDto>>($"api/projects/by-category/{CategoryId}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        UserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        if (string.IsNullOrEmpty(UserId)) return;

        var http = HttpClientFactory.CreateClient("API");
        var votosPrevios = await http.GetFromJsonAsync<List<VoteResultDto>>(
            $"api/votes/by-user?userId={UserId}&categoryId={CategoryId}");

        if (votosPrevios != null && votosPrevios.Any() && ProyectosDisponibles != null)
        {
            foreach (var voto in votosPrevios.OrderBy(v => v.TopPosition))
            {
                var proj = ProyectosDisponibles.FirstOrDefault(p => p.Id == voto.VotedProjectId);
                if (proj != null)
                {
                    ProyectosSeleccionados.Add(proj);
                    comentarios[proj.Id] = string.Empty;
                }
            }
            StateHasChanged();
        }
    }

    private void SeleccionarProyecto(ProjectDto p)
    {
        if (ProyectosSeleccionados.Count < TopN && !ProyectosSeleccionados.Contains(p))
        {
            ProyectosSeleccionados.Add(p);
            comentarios[p.Id] = string.Empty;
        }
    }

    private void QuitarProyecto(ProjectDto? p)
    {
        if (p == null) return;
        ProyectosSeleccionados.Remove(p);
        comentarios.Remove(p.Id);
    }

    private async Task EnviarVoto()
    {
        error = null;

        if (sesion?.RequireComments == true &&
            ProyectosSeleccionados.Any(p => string.IsNullOrWhiteSpace(comentarios.TryGetValue(p.Id, out var c) ? c : null)))
        {
            error = "El comentario es obligatorio en cada proyecto seleccionado.";
            return;
        }

        var http = HttpClientFactory.CreateClient("API");

        var rankedProjects = ProyectosSeleccionados
            .Select((p, index) => new
            {
                ProjectId = p.Id,
                Position = index + 1,
                Comment = (sesion?.AllowComments == true &&
                           comentarios.TryGetValue(p.Id, out var c) &&
                           !string.IsNullOrWhiteSpace(c))
                            ? c.Trim()
                            : (string?)null
            })
            .ToList();

        var payload = new
        {
            CategoryId,
            EventId,
            UserId,
            VotingSessionId = SessionId,
            RankedProjects = rankedProjects
        };

        var response = await http.PostAsJsonAsync("api/votes/batch", payload);

        if (response.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("alert", "¡Tus votos han sido registrados con éxito!");
            Navigation.NavigateTo($"/event/{EventId}/categories/{CategoryId}/projects");
        }
        else
        {
            var msg = await response.Content.ReadAsStringAsync();
            error = string.IsNullOrWhiteSpace(msg) ? "Hubo un error al guardar los votos." : msg.Trim('"');
        }
    }

    public class VotingSessionDto
    {
        public string Id { get; set; } = string.Empty;
        public string EvaluationType { get; set; } = string.Empty;
        public bool AllowComments { get; set; }
        public bool RequireComments { get; set; }
        public int? TopN { get; set; }
    }

    public class CategorySimpleDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool AllowSelfVoting { get; set; }
        public int TopNProjectsAllowed { get; set; }
    }

    public class ProjectDto
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string? Description { get; set; }
        public string ProjectType { get; set; } = "";
    }

    public class VoteResultDto
    {
        public string VotedProjectId { get; set; } = "";
        public int TopPosition { get; set; }
    }
}
