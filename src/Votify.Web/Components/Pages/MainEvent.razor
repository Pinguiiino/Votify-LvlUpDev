@page "/MainEvent"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Votify.Web.Auth
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@inject CustomAuthStateProvider CustomAuthProvider

<PageTitle>Inicio - Votify</PageTitle>

<div class="mainevent-container">
    
    <Breadcrumb CurrentPageName="Eventos" />
    <header class="hero-section">
        <h1 class="main-title">Eventos Activos</h1>
        <p class="subtitle">Explora los eventos activos, descubre proyectos innovadores y comparte tu opinión</p>
    </header>

    <div class="toolbar">
        <AuthorizeView>
            <Authorized>
                <a href="/create-event" class="btn-dark" style="text-decoration: none;">+ Crear Evento</a>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (isLoading)
    {
        <div style="padding: 2rem; text-align: center; color: #4b5563;">
            <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="animation: spin 1s linear infinite; margin-bottom: 1rem;">
                <path d="M12,1A11,11,0,1,0,23,12,11,11,0,0,0,12,1Zm0,19a8,8,0,1,1,8-8A8,8,0,0,1,12,20Z" opacity=".25" fill="currentColor" />
                <path d="M10.14,1.16a11,11,0,0,0-9,8.92A1.59,1.59,0,0,0,2.46,12,1.52,1.52,0,0,0,4.11,10.7a8,8,0,0,1,6.66-6.61A1.42,1.42,0,0,0,12,2.69h0A1.57,1.57,0,0,0,10.14,1.16Z" fill="currentColor" />
            </svg>
            <p><em>@mensajeEstado</em></p>
        </div>
    }
    else if (EventosActivos == null || !EventosActivos.Any())
    {
        <p>No hay eventos disponibles en este momento.</p>
    }
    else
    {
        var misEventos = EventosActivos.Where(e => e.Organizer == currentUserId).ToList();
        var eventosAuditor = EventosActivos.Where(e => e.Organizer != currentUserId && e.AuditorId == currentUserId).ToList();
        var eventosInscrito = EventosActivos.Where(e => e.Organizer != currentUserId && e.AuditorId != currentUserId &&
                                    ((e.ParticipantsIds != null && e.ParticipantsIds.Contains(currentUserId)) ||
                                     (e.PublicIds != null && e.PublicIds.Contains(currentUserId)))).ToList();
        var eventosDisponibles = EventosActivos.Where(e => e.Organizer != currentUserId && e.AuditorId != currentUserId &&
                                    (e.ParticipantsIds == null || !e.ParticipantsIds.Contains(currentUserId)) &&
                                    (e.PublicIds == null || !e.PublicIds.Contains(currentUserId))).ToList();

        @if (misEventos.Any())
        {
            <h2 class="section-title" style="margin-top: 2rem; margin-bottom: 1rem; color: #111827; font-size: 1.5rem; font-weight: 700;">Mis Eventos</h2>
            <div class="events-grid">
                @foreach (var evento in misEventos)
                {
                    @RenderEventCard(evento)
                }
            </div>
        }

        @if (eventosAuditor.Any())
        {
            <h2 class="section-title" style="margin-top: 3rem; margin-bottom: 1rem; color: #111827; font-size: 1.5rem; font-weight: 700;">Eventos como Auditor</h2>
            <div class="events-grid">
                @foreach (var evento in eventosAuditor)
                {
                    @RenderEventCard(evento)
                }
            </div>
        }

        @if (eventosInscrito.Any())
        {
            <h2 class="section-title" style="margin-top: 3rem; margin-bottom: 1rem; color: #111827; font-size: 1.5rem; font-weight: 700;">Eventos en los que participo</h2>
            <div class="events-grid">
                @foreach (var evento in eventosInscrito)
                {
                    @RenderEventCard(evento)
                }
            </div>
        }

        @if (eventosDisponibles.Any())
        {
            <h2 class="section-title" style="margin-top: 3rem; margin-bottom: 1rem; color: #111827; font-size: 1.5rem; font-weight: 700;">Eventos Disponibles</h2>
            <div class="events-grid">
                @foreach (var evento in eventosDisponibles)
                {
                    @RenderEventCard(evento)
                }
            </div>
        }
    }
</div>

@if (mostrandoConfirmacionEliminar)
{
    <div class="delete-confirm-overlay" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 1000;">
        <div style="background: white; padding: 2rem; border-radius: 1rem; max-width: 400px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="#ef4444" viewBox="0 0 16 16" style="margin-bottom: 1rem;">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z" />
            </svg>
            <h3 style="color: #111827; margin-top: 0; font-size: 1.25rem;">¿Eliminar este evento?</h3>
            <p style="color: #4b5563; font-size: 0.9rem; margin-bottom: 1.5rem;">Esta acción es irreversible. Se eliminará permanentemente el evento y todos sus datos asociados.</p>
            <div style="display: flex; gap: 1rem; justify-content: center;">
                <button type="button" class="btn-secondary" @onclick="() => mostrandoConfirmacionEliminar = false">Cancelar</button>
                <button type="button" class="btn-danger" style="background-color: #ef4444; color: white; border: none; padding: 0.5rem 1rem; border-radius: 0.5rem; cursor: pointer; font-weight: 600;" @onclick="EliminarEventoConfirmado" disabled="@eliminando">
                    @(eliminando ? "Eliminando..." : "Sí, eliminar")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(errorServidor))
            {
                <p style="color: #ef4444; font-size: 0.85rem; margin-top: 1rem;">@errorServidor</p>
            }
        </div>
    </div>
}

@code {
    private List<EventDto>? EventosActivos;
    private bool isLoading = true;
    private string mensajeEstado = "Conectando con el servidor...";
    private string apiBaseUrl = string.Empty;
    private string currentUserId = string.Empty;
    private bool _rendered = false;

    // Variables para el borrado
    private bool mostrandoConfirmacionEliminar = false;
    private bool eliminando = false;
    private string eventoAEliminarId = string.Empty;
    private string? errorServidor;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_rendered)
        {
            _rendered = true;

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            currentUserId = authState.User.FindFirst(
                System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;

            await LoadEvents();
        }
    }

    private async Task LoadEvents()
    {
        var http = HttpClientFactory.CreateClient("API");
        apiBaseUrl = http.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;

        int intentos = 0;
        int maxIntentos = 5;

        while (intentos < maxIntentos)
        {
            try
            {
                EventosActivos = await http.GetFromJsonAsync<List<EventDto>>("api/events");
                isLoading = false;
                StateHasChanged();
                return;
            }
            catch (HttpRequestException)
            {
                intentos++;
                mensajeEstado = $"La API se está iniciando... Reintentando ({intentos}/{maxIntentos})";
                StateHasChanged();
                await Task.Delay(2000);
            }
        }

        isLoading = false;
        mensajeEstado = "No se pudo conectar con el servidor.";
        StateHasChanged();
    }

    private void ConfirmarEliminar(string eventId)
    {
        eventoAEliminarId = eventId;
        mostrandoConfirmacionEliminar = true;
        errorServidor = null;
    }

    private async Task EliminarEventoConfirmado()
    {
        eliminando = true;
        errorServidor = null;
        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var session = await CustomAuthProvider.GetUserSessionAsync();
            
            if (session != null && !string.IsNullOrEmpty(session.Token))
            {
                http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", session.Token);
            }

            var response = await http.DeleteAsync($"/api/events/{eventoAEliminarId}");

            if (response.IsSuccessStatusCode)
            {
                mostrandoConfirmacionEliminar = false;
                await LoadEvents();
            }
            else
            {
                errorServidor = (await response.Content.ReadAsStringAsync()).Trim('"');
            }
        }
        catch
        {
            errorServidor = "Error crítico de conexión al eliminar.";
        }
        finally
        {
            eliminando = false;
        }
    }

    private async Task EnrollAsPublic(string eventId, string eventName)
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var request = new { UserId = currentUserId, Role = "Public" };
            var response = await http.PostAsJsonAsync($"api/events/{eventId}/enroll", request);

            if (response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"¡Te has inscrito correctamente al evento '{eventName}' como Público!");
                var eventoActualizado = EventosActivos?.FirstOrDefault(e => e.Id == eventId);
                if (eventoActualizado != null && !eventoActualizado.PublicIds.Contains(currentUserId))
                    eventoActualizado.PublicIds.Add(currentUserId);

                StateHasChanged();
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                await JSRuntime.InvokeVoidAsync("alert", $"Error al inscribirse: {errorMsg}");
            }
        }
        catch
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error de conexión. Inténtalo de nuevo más tarde.");
        }
    }

    private RenderFragment RenderEventCard(EventDto evento) => __builder =>
    {
        bool isOrganizer = evento.Organizer == currentUserId;
        bool isParticipant = evento.ParticipantsIds != null && evento.ParticipantsIds.Contains(currentUserId);
        bool isPublic = evento.PublicIds != null && evento.PublicIds.Contains(currentUserId);
        bool isAuditor = evento.AuditorId == currentUserId;
        bool eventoNoIniciado = DateTime.UtcNow < evento.StartDate.ToUniversalTime();

        <div class="event-card cursor-pointer" @onclick='() => Navigation.NavigateTo($"/event/{evento.Id}/categories")'>

            @if (!string.IsNullOrWhiteSpace(evento.ImageUrl))
            {
                <img src="@(apiBaseUrl + evento.ImageUrl)" alt="@evento.Name" class="card-image" />
            }
            else
            {
                <div class="icon-container">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                        <path d="M11.354 4.646a.5.5 0 0 0-.708 0l-6 6a.5.5 0 0 0 .708.708l6-6a.5.5 0 0 0 0-.708z" />
                    </svg>
                </div>
            }

            <div class="card-info">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem;">
                    <h2 class="card-title" style="margin: 0; flex: 1;">@evento.Name</h2>
                    
                    @if (isOrganizer)
                    {
                        <div style="display: flex; gap: 0.5rem;" @onclick:stopPropagation="true">
                            @if (eventoNoIniciado)
                            {
                                <button class="btn-edit-pencil" style="background: none; border: none; cursor: pointer; color: #4b5563; padding: 0.25rem; transition: color 0.2s;"
                                        @onclick='() => Navigation.NavigateTo($"/event/{evento.Id}/edit")' title="Editar Evento">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
                                    </svg>
                                </button>
                            }
                            <button class="btn-delete-trash" style="background: none; border: none; cursor: pointer; color: #ef4444; padding: 0.25rem; transition: color 0.2s;"
                                    @onclick='() => ConfirmarEliminar(evento.Id)' title="Eliminar Evento">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z" />
                                    <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z" />
                                </svg>
                            </button>
                        </div>
                    }
                </div>
                
                <span class="card-date">@evento.StartDate.ToString("dd 'de' MMMM, yyyy")</span>
                <p class="card-description">@evento.Description</p>
                <span class="card-modality" style="font-weight: bold; color: #4b5563;">@evento.Modality</span>

                <div style="margin-top: 1.5rem; border-top: 1px solid #e5e7eb; padding-top: 1rem;" @onclick:stopPropagation="true">
                    @if (isOrganizer)
                    {
                        <span style="display: block; font-size: 0.85rem; color: #16a34a; font-weight: 600; text-align: center;">
                            ★ Creador del Evento
                        </span>
                    }
                    else if (isAuditor)
                    {
                        <span style="display: block; font-size: 0.85rem; color: #b45309; font-weight: 600; text-align: center;">
                            🔍 Eres el Auditor
                        </span>
                    }
                    else if (isParticipant)
                    {
                        <span style="display: block; font-size: 0.85rem; color: #0284c7; font-weight: 600; text-align: center;">
                            ✓ Inscrito como Participante
                        </span>
                    }
                    else if (isPublic)
                    {
                        <span style="display: block; font-size: 0.85rem; color: #9333ea; font-weight: 600; text-align: center;">
                            ✓ Inscrito como Público
                        </span>
                    }
                    else
                    {
                        <button class="btn-outline" style="width: 100%; padding: 0.6rem; font-size: 0.9rem;"
                                @onclick='() => EnrollAsPublic(evento.Id, evento.Name)'>
                            Inscribirse al evento
                        </button>
                    }
                </div>
            </div>
        </div>
    };

    public class EventDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int MaxProjects { get; set; }
        public DateTime StartDate { get; set; }
        public string? ImageUrl { get; set; }
        public string Modality { get; set; } = string.Empty;
        public string Organizer { get; set; } = string.Empty;
        public List<string> ParticipantsIds { get; set; } = new();
        public List<string> PublicIds { get; set; } = new();
        public string AuditorId { get; set; } = string.Empty;
    }
}