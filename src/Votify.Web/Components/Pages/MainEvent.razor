@page "/MainEvent"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Votify.Web.Auth
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@inject CustomAuthStateProvider CustomAuthProvider

<PageTitle>Inicio - Votify</PageTitle>

<div class="mainevent-container">
    
    <Breadcrumb CurrentPageName="Eventos" />
    <header class="hero-section">
        <h1 class="main-title">Eventos Activos</h1>
        <p class="subtitle">Explora los eventos activos, descubre proyectos innovadores y comparte tu opinión</p>
    </header>

    <div class="toolbar">
        <AuthorizeView>
            <Authorized>
                <a href="/create-event" class="btn-dark" style="text-decoration: none;">+ Crear Evento</a>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (isLoading)
    {
        <div style="padding: 2rem; text-align: center; color: #4b5563;">
            <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="animation: spin 1s linear infinite; margin-bottom: 1rem;">
                <path d="M12,1A11,11,0,1,0,23,12,11,11,0,0,0,12,1Zm0,19a8,8,0,1,1,8-8A8,8,0,0,1,12,20Z" opacity=".25" fill="currentColor" />
                <path d="M10.14,1.16a11,11,0,0,0-9,8.92A1.59,1.59,0,0,0,2.46,12,1.52,1.52,0,0,0,4.11,10.7a8,8,0,0,1,6.66-6.61A1.42,1.42,0,0,0,12,2.69h0A1.57,1.57,0,0,0,10.14,1.16Z" fill="currentColor" />
            </svg>
            <p><em>@mensajeEstado</em></p>
        </div>
    }
    else if (EventosActivos == null || !EventosActivos.Any())
    {
        <p>No hay eventos disponibles en este momento.</p>
    }
    else
    {
        <div class="events-grid">
            @foreach (var evento in EventosActivos)
            {
                bool isOrganizer = evento.Organizer == currentUserId;
                bool isParticipant = evento.ParticipantsIds != null && evento.ParticipantsIds.Contains(currentUserId);
                bool isPublic = evento.PublicIds != null && evento.PublicIds.Contains(currentUserId);
                bool isAuditor = evento.AuditorId == currentUserId;
                bool yaAsignado = !string.IsNullOrEmpty(evento.AuditorId);

                <div class="event-card cursor-pointer" style="position: relative;" @onclick='() => Navigation.NavigateTo($"/event/{evento.Id}/categories")'>

                    @if (!string.IsNullOrWhiteSpace(evento.ImageUrl))
                    {
                        <img src="@(apiBaseUrl + evento.ImageUrl)" alt="@evento.Name" class="card-image" />
                    }
                    else
                    {
                        <div class="icon-container">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                                <path d="M11.354 4.646a.5.5 0 0 0-.708 0l-6 6a.5.5 0 0 0 .708.708l6-6a.5.5 0 0 0 0-.708z" />
                            </svg>
                        </div>
                    }

                    @if (isOrganizer)
                    {
                        <button type="button"
                                title="Eliminar evento"
                                @onclick:stopPropagation="true"
                                @onclick="() => AbrirModalEliminarEvento(evento)"
                                style="position: absolute; bottom: 0.85rem; right: 0.85rem; width: 2.2rem; height: 2.2rem; border-radius: 50%; border: none; background-color: #ef4444; color: white; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 2; box-shadow: 0 2px 6px rgba(239,68,68,0.4); transition: background-color 0.2s;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                                <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                            </svg>
                        </button>
                    }

                    <div class="card-info">
                        <h2 class="card-title">@evento.Name</h2>
                        <span class="card-date">@evento.StartDate.ToString("dd 'de' MMMM, yyyy")</span>
                        <p class="card-description">@evento.Description</p>
                        <span class="card-modality" style="font-weight: bold; color: #4b5563;">@evento.Modality</span>

                        <div style="margin-top: 1.5rem; border-top: 1px solid #e5e7eb; padding-top: 1rem;" @onclick:stopPropagation="true">

                            @if (isOrganizer)
                            {
                                <span style="display: block; font-size: 0.85rem; color: #16a34a; font-weight: 600; text-align: center; margin-bottom: 0.5rem;">
                                    ★ Creador del Evento
                                </span>
                            }
                            else if (isAuditor)
                            {
                                <span style="display: block; font-size: 0.85rem; color: #b45309; font-weight: 600; text-align: center;">
                                    🔍 Eres el Auditor
                                </span>
                            }
                            else if (isParticipant)
                            {
                                <span style="display: block; font-size: 0.85rem; color: #0284c7; font-weight: 600; text-align: center;">
                                    ✓ Inscrito como Participante
                                </span>
                            }
                            else if (isPublic)
                            {
                                <span style="display: block; font-size: 0.85rem; color: #9333ea; font-weight: 600; text-align: center;">
                                    ✓ Inscrito como Público
                                </span>
                            }
                            else
                            {
                                <button class="btn-outline" style="width: 100%; padding: 0.6rem; font-size: 0.9rem;"
                                @onclick='() => EnrollAsPublic(evento.Id, evento.Name)'>
                                    Inscribirse al evento
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (eventoAEliminar != null)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(17,24,39,0.55); display: flex; align-items: center; justify-content: center; z-index: 10000; backdrop-filter: blur(4px); padding: 1rem;"
         @onclick="CerrarModalEliminarEvento">
        <div style="background: white; width: 100%; max-width: 440px; border-radius: 1rem; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.15); padding: 2rem; text-align: center;"
             @onclick:stopPropagation="true">
            <div style="width: 3rem; height: 3rem; background-color: #fee2e2; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#ef4444" viewBox="0 0 16 16">
                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                    <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                </svg>
            </div>
            <h2 style="font-size: 1.15rem; font-weight: 700; color: #111827; margin: 0 0 0.5rem;">¿Está seguro de que desea eliminar '@eventoAEliminar.Name'?</h2>
            <p style="font-size: 0.9rem; color: #6b7280; margin: 0 0 1.75rem;">Esta acción no se puede deshacer y eliminará todas sus categorías y proyectos asociados.</p>
            <div style="display: flex; gap: 0.75rem; justify-content: center;">
                <button @onclick="CerrarModalEliminarEvento"
                        style="flex: 1; padding: 0.65rem 1.25rem; border-radius: 0.5rem; border: 1px solid #d1d5db; background: white; color: #374151; font-weight: 600; cursor: pointer; font-size: 0.95rem;">
                    Cancelar
                </button>
                <button @onclick="ConfirmarEliminarEvento" disabled="@eliminando"
                        style="flex: 1; padding: 0.65rem 1.25rem; border-radius: 0.5rem; border: none; background: #ef4444; color: white; font-weight: 600; cursor: pointer; font-size: 0.95rem; opacity: @(eliminando ? "0.7" : "1");">
                    @(eliminando ? "Eliminando..." : "Eliminar")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .cursor-pointer { cursor: pointer; transition: transform 0.2s; }
    .cursor-pointer:hover { transform: translateY(-2px); }
    .btn-outline { background: transparent; border: 1px solid #cbd5e1; border-radius: 0.5rem; color: #0f172a; font-weight: 600; transition: all 0.2s; cursor: pointer; }
    .btn-outline:hover { background-color: #f8fafc; border-color: #94a3b8; }
</style>

@code {
    private List<EventDto>? EventosActivos;
    private bool isLoading = true;
    private string mensajeEstado = "Conectando con el servidor...";
    private string apiBaseUrl = string.Empty;
    private string currentUserId = string.Empty;
    private string currentUserRole = string.Empty; 
    private bool _rendered = false;
    private string? mensajeAuditor = null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_rendered)
        {
            _rendered = true;

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            currentUserId = authState.User.FindFirst(
                System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
            
            // currentUserRole ya no se usa para filtrar pantallas globales
            currentUserRole = authState.User.FindFirst(
                System.Security.Claims.ClaimTypes.Role)?.Value ?? string.Empty;

            await LoadEvents();
        }
    }

    private async Task LoadEvents()
    {
        var http = HttpClientFactory.CreateClient("API");
        apiBaseUrl = http.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;

        int intentos = 0;
        int maxIntentos = 5;

        while (intentos < maxIntentos)
        {
            try
            {
                var todosEventos = await http.GetFromJsonAsync<List<EventDto>>("api/events");

                // Todo el mundo ve todos los eventos, su rol dependerá de la lógica dentro de las cards.
                EventosActivos = todosEventos;
                
                isLoading = false;
                StateHasChanged();
                return;
            }
            catch (HttpRequestException)
            {
                intentos++;
                mensajeEstado = $"La API se está iniciando... Reintentando ({intentos}/{maxIntentos})";
                StateHasChanged();
                await Task.Delay(2000);
            }
        }

        isLoading = false;
        mensajeEstado = "No se pudo conectar con el servidor.";
        StateHasChanged();
    }

    private async Task EnrollAsPublic(string eventId, string eventName)
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var request = new { UserId = currentUserId, Role = "Public" };
            var response = await http.PostAsJsonAsync($"api/events/{eventId}/enroll", request);

            if (response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("alert",
                    $"¡Te has inscrito correctamente al evento '{eventName}' como Público!");

                var eventoActualizado = EventosActivos?.FirstOrDefault(e => e.Id == eventId);
                if (eventoActualizado != null && !eventoActualizado.PublicIds.Contains(currentUserId))
                    eventoActualizado.PublicIds.Add(currentUserId);

                StateHasChanged();
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                await JSRuntime.InvokeVoidAsync("alert", $"Error al inscribirse: {errorMsg}");
            }
        }
        catch
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error de conexión. Inténtalo de nuevo más tarde.");
        }
    }

    private EventDto? eventoAEliminar;
    private bool eliminando;

    private void AbrirModalEliminarEvento(EventDto evento)
    {
        eventoAEliminar = evento;
        eliminando = false;
    }

    private void CerrarModalEliminarEvento()
    {
        eventoAEliminar = null;
        eliminando = false;
    }

    private async Task ConfirmarEliminarEvento()
    {
        if (eventoAEliminar == null) return;
        eliminando = true;

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var session = await CustomAuthProvider.GetUserSessionAsync();
            if (!string.IsNullOrEmpty(session?.Token))
                http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", session.Token);

            var response = await http.DeleteAsync($"api/events/{eventoAEliminar.Id}");

            if (response.IsSuccessStatusCode)
            {
                EventosActivos?.RemoveAll(e => e.Id == eventoAEliminar!.Id);
                eventoAEliminar = null;
                StateHasChanged();
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                await JSRuntime.InvokeVoidAsync("alert", $"Error al eliminar: {msg}");
            }
        }
        catch
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error de conexión al eliminar el evento.");
        }
        finally
        {
            eliminando = false;
        }
    }

    private string? eventoAsignando = null;
    private string? eventoConMensaje = null;
    private string emailAuditor = string.Empty;
    private string? errorAuditor = null;

    private async Task AsignarAuditor(string eventId)
    {
        errorAuditor = null;
        if (string.IsNullOrWhiteSpace(emailAuditor))
        {
            errorAuditor = "Introduce un correo.";
            return;
        }

        try
        {
            var http = HttpClientFactory.CreateClient("API");

            var existe = await http.GetFromJsonAsync<bool>(
                $"api/auth/check-email?email={emailAuditor.Trim().ToLower()}");

            if (!existe)
            {
                errorAuditor = "No existe ningún usuario con ese correo.";
                return;
            }

            var auditorUser = await http.GetFromJsonAsync<UserDto>(
                $"api/auth/user-by-email?email={emailAuditor.Trim().ToLower()}");

            // Hemos quitado la comprobación de "Rol global" porque el auditor ahora puede ser un User cualquiera.
            if (auditorUser == null)
            {
                errorAuditor = "No se pudo recuperar la información del usuario.";
                return;
            }

            var session = await ((CustomAuthStateProvider)AuthStateProvider).GetUserSessionAsync();
            http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", session?.Token);

            var response = await http.PostAsJsonAsync(
                $"api/events/{eventId}/assign-auditor",
                new { AuditorId = auditorUser.Id });

            if (response.IsSuccessStatusCode)
            {
                eventoAsignando = null;
                emailAuditor = string.Empty;
                eventoConMensaje = eventId;  
                await LoadEvents();
                StateHasChanged();
            }
            else
            {
                errorAuditor = (await response.Content.ReadAsStringAsync()).Trim('"');
            }
        }
        catch
        {
            errorAuditor = "Error de conexión.";
        }
    }

    public class UserDto
    {
        public string Id { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
    }

    public class AssignAuditorDto
    {
        public string AuditorId { get; set; } = string.Empty;
    }

    public class EventDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int MaxProjects { get; set; }
        public DateTime StartDate { get; set; }
        public string? ImageUrl { get; set; }
        public string Modality { get; set; } = string.Empty;
        public string Organizer { get; set; } = string.Empty;
        public List<string> ParticipantsIds { get; set; } = new();
        public List<string> PublicIds { get; set; } = new();
        public string AuditorId { get; set; } = string.Empty;
    }
}