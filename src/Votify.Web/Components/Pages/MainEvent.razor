@page "/"
@using Microsoft.EntityFrameworkCore
@using Votify.Domain.EventFolder
@using Votify.Infrastructure
@inject NavigationManager Navigation
@inject IDbContextFactory<VotifyDbContext> DbFactory

<PageTitle>Inicio - Votify</PageTitle>

<div class="mainevent-container">
    <header class="hero-section">
        <div class="status-badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z" />
            </svg>
            Eventos Activos
        </div>
        <h1 class="main-title">Plataforma de Gestión de Proyectos</h1>
        <p class="subtitle">Explora los eventos activos, descubre proyectos innovadores y comparte tu opinión</p>
    </header>

    <div class="toolbar">
        <button class="btn-dark" @onclick="IrACrearEvento">
            + Crear Evento
        </button>
    </div>

    @if (EventosActivos == null)
    {
        <p><em>Cargando eventos desde la base de datos...</em></p>
    }
    else if (!EventosActivos.Any())
    {
        <p>No hay eventos disponibles en este momento.</p>
    }
    else
    {
        <div class="events-grid">
            @foreach (var evento in EventosActivos)
            {
                <div class="event-card">
                    <div class="icon-container">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                            <path d="M11.354 4.646a.5.5 0 0 0-.708 0l-6 6a.5.5 0 0 0 .708.708l6-6a.5.5 0 0 0 0-.708z" />
                        </svg>
                    </div>
                    <div class="card-info">
                        <h2 class="card-title">@evento.Name</h2>
                        <span class="card-date">@evento.StartDate.ToString("dd 'de' MMMM, yyyy")</span>
                        <p class="card-description">@evento.Description</p>
                        <a class="card-modality" style="font-weight:bold; color: #4b5563;">@evento.Modality</a>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Event>? EventosActivos;

    protected override async Task OnInitializedAsync()
    {
        await CargarEventos();
    }

    private async Task CargarEventos()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        EventosActivos = await context.Events.AsNoTracking().ToListAsync();
    }

    private void IrACrearEvento()
    {
        Navigation.NavigateTo("/crear-evento");
    }
}