@page "/create-event"
@using Microsoft.AspNetCore.Authorization
@using Votify.Web.Auth
@inject CustomAuthStateProvider AuthStateProvider
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<PageTitle>Crear Nuevo Evento - Votify</PageTitle>

<div class="create-event-container">
    <EditForm Model="eventModel" OnValidSubmit="ManejarSubmitValido">
        <DataAnnotationsValidator />

        <header class="modal-header">
            <div class="header-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z" />
                </svg>
                <h1>Crear Nuevo Evento</h1>
            </div>
            <button type="button" class="close-btn" @onclick="Cancelar">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
        </header>

        <div class="modal-body">

            <div class="form-group">
                <label>Nombre del evento *</label>
                <InputText class="@($"form-control {(errorServidor != null ? "is-invalid" : "")}")"
                           placeholder="Ej: Hackathon 2026"
                           @bind-Value="eventModel.Name"
                           @oninput="() => errorServidor = null" />
                <ValidationMessage For="@(() => eventModel.Name)" />

                @if (errorServidor != null)
                {
                    <div class="validation-error" style="color: #dc2626; font-size: 0.85rem; margin-top: 0.25rem;">
                        @errorServidor
                    </div>
                }
            </div>

            <div class="form-group">
                <label>Descripción</label>
                <InputTextArea class="form-control" rows="4" placeholder="Describe el evento..."
                               @bind-Value="eventModel.Description" />
            </div>

            <div class="form-group">
                <label>Imagen del evento</label>
                <InputFile class="form-control" OnChange="OnImagenSeleccionada" accept="image/*" />
                @if (subiendoImagen)
                {
                    <div style="font-size: 0.85rem; color: #6b7280; margin-top: 0.25rem;">Subiendo imagen...</div>
                }
                @if (errorImagen != null)
                {
                    <div class="validation-error" style="color: #dc2626; font-size: 0.85rem; margin-top: 0.25rem;">
                        @errorImagen
                    </div>
                }
                @if (!string.IsNullOrEmpty(eventModel.ImageUrl))
                {
                    <div style="margin-top: 0.5rem;">
                        <img src="@(apiBaseUrl + eventModel.ImageUrl)" alt="Vista previa"
                             style="max-width: 200px; max-height: 150px; border-radius: 0.5rem; border: 1px solid #e5e7eb;" />
                        <button type="button" class="btn-delete" style="margin-left: 0.5rem;"
                                @onclick="() => eventModel.ImageUrl = null">Quitar</button>
                    </div>
                }
            </div>

            <div class="form-group">
                <label>Modalidad *</label>
                <InputText class="form-control" placeholder="Ej: Presencial, Online, Híbrido"
                           @bind-Value="eventModel.Modality" />
                <ValidationMessage For="@(() => eventModel.Modality)" />
            </div>

            <div class="form-group">
                <label>Número máximo de proyectos *</label>
                <InputNumber class="form-control" placeholder="20" @bind-Value="eventModel.MaxProjects" />
                <ValidationMessage For="@(() => eventModel.MaxProjects)" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
                <div class="form-group">
                    <label>Fecha de inicio *</label>
                    <InputDate class="form-control"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               @bind-Value="eventModel.StartDate" />
                    <ValidationMessage For="@(() => eventModel.StartDate)" />
                </div>
                <div class="form-group">
                    <label>Fecha de fin *</label>
                    <InputDate class="form-control"
                               min="@(eventModel.StartDate.HasValue ? eventModel.StartDate.Value.ToString("yyyy-MM-dd") : DateTime.Today.ToString("yyyy-MM-dd"))"
                               @bind-Value="eventModel.EndDate" />
                    <ValidationMessage For="@(() => eventModel.EndDate)" />
                </div>
            </div>

            <p style="font-size: 0.85rem; color: #6b7280; margin-top: 0.5rem;">
                Las categorías y votaciones se configuran una vez creado el evento.
            </p>

        </div>

        <footer class="modal-footer">
            <button type="button" class="btn-secondary" @onclick="Cancelar">Cancelar</button>
            <button type="submit" class="btn-primary">Crear evento</button>
        </footer>

    </EditForm>
</div>

@code {
    private CreateEventModel eventModel = new();
    private string? errorServidor;
    private string? errorImagen;
    private bool subiendoImagen;
    private const string apiBaseUrl = "https://localhost:7276";

    private async Task<string?> GetTokenAsync()
    {
    var customProvider = (CustomAuthStateProvider)AuthStateProvider;
    var session = await customProvider.GetUserSessionAsync();
    return session?.Token;
    }


    protected override async Task OnInitializedAsync()
    {
    var authState = await AuthStateProvider.GetAuthenticationStateAsync();
    var user = authState.User;

    if (!user.Identity?.IsAuthenticated ?? true)
        {
        Navigation.NavigateTo("/login");
        return;
        }

    if (!user.IsInRole("Organizer"))
        {
        Navigation.NavigateTo("/not-found");
        return;
        }
    }


    private async Task OnImagenSeleccionada(InputFileChangeEventArgs e)
    {
        errorImagen = null;
        var file = e.File;
        if (file == null) return;

        if (file.Size > 5 * 1024 * 1024)
        {
            errorImagen = "La imagen no puede superar los 5 MB.";
            return;
        }

        try
        {
            subiendoImagen = true;
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(5 * 1024 * 1024);
            var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(streamContent, "file", file.Name);

            var http = HttpClientFactory.CreateClient("API");
            var response = await http.PostAsync("/api/events/upload-image", content);

            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<UploadResponse>();
                eventModel.ImageUrl = data?.Url;
            }
            else
            {
                errorImagen = "No se pudo subir la imagen.";
            }
        }
        catch (Exception ex)
        {
            errorImagen = $"No se pudo subir la imagen: {ex.Message}";
        }
        finally
        {
            subiendoImagen = false;
        }
    }

    private class UploadResponse
    {
        public string? Url { get; set; }
    }

    private async Task ManejarSubmitValido()
    {
        try
        {
            var payload = new
            {
                eventModel.Name,
                eventModel.Description,
                eventModel.Modality,
                eventModel.MaxProjects,
                StartDate = eventModel.StartDate!.Value,
                EndDate = eventModel.EndDate!.Value,
                eventModel.ImageUrl
            };

            var http = HttpClientFactory.CreateClient("API");
                    
             var token = await GetTokenAsync();
                    if (!string.IsNullOrEmpty(token))
                    http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);


            var respuesta = await http.PostAsJsonAsync("/api/events", payload);

            if (respuesta.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/MainEvent");
            }
            else
            {
                var errorMsg = await respuesta.Content.ReadAsStringAsync();
                errorServidor = errorMsg.Trim('"');
            }
        }
        catch (Exception)
        {
            await JS.InvokeVoidAsync("alert", "Error crítico: No se pudo conectar con el servidor API.");
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/MainEvent");

    private class CreatedEventResponse
    {
        public string? Message { get; set; }
        public string? Id { get; set; }
    }

    public class CreateEventModel : IValidatableObject
    {
        [Required(ErrorMessage = "Requerido")]
        public string Name { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;

        [Required(ErrorMessage = "Requerido")]
        public string Modality { get; set; } = string.Empty;

        [Range(1, 1000)]
        public int MaxProjects { get; set; }

        [Required(ErrorMessage = "La fecha de inicio es obligatoria.")]
        public DateTime? StartDate { get; set; }

        [Required(ErrorMessage = "La fecha de fin es obligatoria.")]
        public DateTime? EndDate { get; set; }

        public string? ImageUrl { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (StartDate.HasValue && StartDate.Value.Date < DateTime.Today)
                yield return new ValidationResult(
                    "La fecha de inicio no puede ser anterior a hoy.",
                    new[] { nameof(StartDate) });

            if (EndDate.HasValue && StartDate.HasValue && EndDate.Value.Date < StartDate.Value.Date)
                yield return new ValidationResult(
                    "La fecha de fin debe ser posterior a la de inicio.",
                    new[] { nameof(EndDate) });
        }
    }
}
