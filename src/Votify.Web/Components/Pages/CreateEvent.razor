@page "/create-event"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Crear Nuevo Evento - Votify</PageTitle>

<div class="create-event-container">
    <EditForm Model="eventModel" OnValidSubmit="ManejarSubmitValido">
        <DataAnnotationsValidator />

        <header class="modal-header">
            <div class="header-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path
                    d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z" />
                </svg>
                <h1>Crear Nuevo Evento</h1>
            </div>
            <button type="button" class="close-btn" @onclick="Cancelar">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path
                    d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
        </header>

        <div class="modal-body">

            <div class="form-group">
                <label>Nombre del evento *</label>
                <InputText class="form-control" placeholder="Ej: Hackathon 2026" @bind-Value="eventModel.Name" />
                <ValidationMessage For="@(() => eventModel.Name)" />
            </div>

            <div class="form-group">
                <label>Descripción</label>
                <InputTextArea class="form-control" rows="4" placeholder="Describe el evento..."
                               @bind-Value="eventModel.Description" />
            </div>

            <div class="form-group">
                <label>Modalidad *</label>
                <InputText class="form-control" placeholder="Ej: Presencial, Online, Híbrido"
                           @bind-Value="eventModel.Modality" />
                <ValidationMessage For="@(() => eventModel.Modality)" />
            </div>

            <div class="form-group">
                <label>Número máximo de proyectos *</label>
                <InputNumber class="form-control" placeholder="20" @bind-Value="eventModel.MaxProjects" />
                <ValidationMessage For="@(() => eventModel.MaxProjects)" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
                <div class="form-group">
                    <label>Fecha de inicio *</label>
                    <InputDate class="form-control" @bind-Value="eventModel.StartDate" />
                    <ValidationMessage For="@(() => eventModel.StartDate)" />
                </div>
                <div class="form-group">
                    <label>Fecha de fin *</label>
                    <InputDate class="form-control" @bind-Value="eventModel.EndDate" />
                    <ValidationMessage For="@(() => eventModel.EndDate)" />
                </div>
            </div>

            <hr style="margin: 1rem 0; border: 0; border-top: 1px solid #e5e7eb;" />

            <div class="form-group">
                <label>Categorías del Evento * <span
                    style="font-weight: normal; font-size: 0.85rem; color: #6b7280;">(Añade al menos
                    una)</span></label>

                    @if (eventModel.Categories.Any())
                    {
                        <div class="categories-list">
                            @foreach (var cat in eventModel.Categories)
                            {
                                <div class="category-item">
                                    <div>
                                        <strong>@cat.Name</strong>
                                        <span style="font-size: 0.8rem; color: #6b7280; display: block;">
                                            @cat.Description | Modo: @cat.VotingMode
                                            | Criterios: @cat.Criteria.Count | Premios: @cat.Prizes.Count
                                        </span>
                                    </div>
                                    <button type="button" class="btn-delete"
                                            @onclick="() => eventModel.Categories.Remove(cat)">X</button>
                                </div>
                            }
                        </div>
                    }

                    @if (errorCategorias)
                    {
                        <div class="validation-message">Debes añadir al menos una categoría para crear el evento.</div>
                    }

                    @if (!mostrandoFormularioCategoria)
                    {
                        <button type="button" class="btn-secondary mt-2" style="border: 2px dashed #d1d5db; color: #4b5563;"
                                @onclick="MostrarFormulario">
                            + Añadir Categoría
                        </button>
                    }
                    else
                    {
                        <div class="add-category-box">
                            <h4 style="margin-top: 0; margin-bottom: 1rem; font-size: 0.95rem; color: #374151;">Configurar
                                categoría</h4>

                                <div class="form-group">
                                    <input type="text" class="form-control form-control-sm"
                                           placeholder="Nombre (Ej: Proyectos de IA)" @bind="nuevaCategoria.Name" />
                                </div>

                                <div class="form-group">
                                    <textarea class="form-control form-control-sm" rows="2"
                                              placeholder="Descripción de la categoría..." @bind="nuevaCategoria.Description"></textarea>
                                </div>

                                <div class="form-group">
                                    <label style="font-size: 0.85rem;">Modo de votación</label>
                                    <select class="form-control form-control-sm" @bind="nuevaCategoria.VotingMode">
                                        <option value="Scored">Scored — criterios con peso</option>
                                        <option value="PointPool">PointPool — repartir puntos entre proyectos</option>
                                        <option value="TopN">TopN — elegir los N mejores proyectos</option>
                                        <option value="Ranked">Ranked — asignar puntos por posición</option>
                                    </select>
                                </div>

                                @if (nuevaCategoria.VotingMode != "Scored")
                                {
                                    <div class="form-group">
                                        <label style="font-size: 0.85rem;">@ParametroLabel(nuevaCategoria.VotingMode)</label>
                                        <input type="number" class="form-control form-control-sm"
                                               placeholder="@ParametroPlaceholder(nuevaCategoria.VotingMode)"
                                               @bind="nuevaCategoria.VotingParameter" />
                                        <span
                                        style="font-size: 0.75rem; color: #6b7280;">@ParametroAyuda(nuevaCategoria.VotingMode)</span>
                                    </div>
                                }

                                <div class="form-group">
                                    <label style="font-size: 0.85rem;">
                                        <input type="checkbox" @bind="nuevaCategoria.AllowSelfVoting" /> Permitir que los
                                        participantes voten su propia categoría
                                    </label>
                                </div>

                                @* ── Criterios ── *@
                                <div style="margin-top: 0.75rem;">
                                    <label style="font-size: 0.85rem; font-weight: 600;">Criterios de evaluación</label>
                                    @foreach (var cr in nuevaCategoria.Criteria)
                                    {
                                        <div
                                            style="display: grid; grid-template-columns: 2fr 1fr 1fr auto; gap: 0.5rem; margin-top: 0.4rem; align-items: center;">
                                            <input type="text" class="form-control form-control-sm" placeholder="Nombre criterio"
                                                   @bind="cr.Name" />
                                            <select class="form-control form-control-sm" @bind="cr.Type">
                                                <option value="Numeric">Numérico</option>
                                                <option value="Checklist">Checklist</option>
                                                <option value="Rubric">Rúbrica</option>
                                                <option value="Comment">Comentario</option>
                                                <option value="Audio">Audio</option>
                                                <option value="Video">Vídeo</option>
                                            </select>
                                            <input type="number" class="form-control form-control-sm" step="0.05" min="0" max="1"
                                                   placeholder="Peso" @bind="cr.Weight" />
                                            <button type="button" class="btn-delete"
                                                    @onclick="() => nuevaCategoria.Criteria.Remove(cr)">X</button>
                                        </div>
                                    }
                                    @if (errorPesos)
                                    {
                                        <div class="validation-message" style="margin-top: 0.25rem;">Los pesos de los criterios deben
                                            sumar 1.0.</div>
                                        }
                                        <button type="button" class="btn-secondary mt-2" style="font-size: 0.8rem;"
                                                @onclick="() => nuevaCategoria.Criteria.Add(new CriterionDraft())">
                                            + Añadir criterio
                                        </button>
                                    </div>

                                    @* ── Premios ── *@
                                    <div style="margin-top: 0.75rem;">
                                        <label style="font-size: 0.85rem; font-weight: 600;">Premios</label>
                                        @foreach (var pr in nuevaCategoria.Prizes)
                                        {
                                            <div
                                                style="display: grid; grid-template-columns: auto 2fr 2fr auto; gap: 0.5rem; margin-top: 0.4rem; align-items: center;">
                                                <input type="number" class="form-control form-control-sm" placeholder="Pos." min="1"
                                                       @bind="pr.Position" style="width: 4rem;" />
                                                <input type="text" class="form-control form-control-sm" placeholder="Nombre (Ej: 1.000€)"
                                                       @bind="pr.Name" />
                                                <input type="text" class="form-control form-control-sm" placeholder="Descripción"
                                                       @bind="pr.Description" />
                                                <button type="button" class="btn-delete"
                                                        @onclick="() => nuevaCategoria.Prizes.Remove(pr)">X</button>
                                            </div>
                                        }
                                        <button type="button" class="btn-secondary mt-2" style="font-size: 0.8rem;"
                                                @onclick="() => nuevaCategoria.Prizes.Add(new PrizeDraft { Position = nuevaCategoria.Prizes.Count + 1 })">
                                            + Añadir premio
                                        </button>
                                    </div>

                                    @if (errorNombreCategoria)
                                    {
                                        <div class="validation-message" style="margin-top: 0.5rem;">El nombre de la categoría es
                                            obligatorio.</div>
                                        }

                                        <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                                            <button type="button" class="btn-primary" style="flex: 1; padding: 0.5rem;"
                                                    @onclick="ConfirmarCategoria">Confirmar</button>
                                            <button type="button" class="btn-secondary" style="flex: 1; padding: 0.5rem;"
                                                    @onclick="OcultarFormulario">Cancelar</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <footer class="modal-footer">
                            <button type="submit" class="btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem;">Finalizar y
                                Crear Evento</button>
                            </footer>
                        </EditForm>
                    </div>

@code {
    private CreateEventModel eventModel = new();
    private CategoryDraft nuevaCategoria = new();

    private bool errorCategorias = false;
    private bool errorNombreCategoria = false;
    private bool errorPesos = false;
    private bool mostrandoFormularioCategoria = false;

    private const int DefaultMaxProjects = 20;

    protected override void OnInitialized()
    {
        eventModel.MaxProjects = DefaultMaxProjects;
        eventModel.StartDate = DateTime.Today;
        eventModel.EndDate = DateTime.Today.AddDays(1);
    }

    private void MostrarFormulario()
    {
        nuevaCategoria = new CategoryDraft();
        errorNombreCategoria = false;
        errorPesos = false;
        mostrandoFormularioCategoria = true;
    }

    private void OcultarFormulario() => mostrandoFormularioCategoria = false;

    private void ConfirmarCategoria()
    {
        errorNombreCategoria = false;
        errorPesos = false;

        if (string.IsNullOrWhiteSpace(nuevaCategoria.Name))
        {
            errorNombreCategoria = true;
            return;
        }

        // Validar pesos solo en modo Scored con criterios definidos
        if (nuevaCategoria.VotingMode == "Scored" && nuevaCategoria.Criteria.Any())
        {
            var suma = nuevaCategoria.Criteria.Sum(c => c.Weight);
            if (Math.Abs(suma - 1.0) > 0.01)
            {
                errorPesos = true;
                return;
            }
        }

        errorCategorias = false;
        eventModel.Categories.Add(nuevaCategoria);
        mostrandoFormularioCategoria = false;
    }

    private async Task ManejarSubmitValido()
    {
        if (!eventModel.Categories.Any())
        {
            errorCategorias = true;
            return;
        }

        try
        {
            var payload = new
            {
                eventModel.Name,
                eventModel.Description,
                eventModel.Modality,
                eventModel.MaxProjects,
                StartDate = eventModel.StartDate!.Value,
                EndDate = eventModel.EndDate!.Value,
                Categories = eventModel.Categories.Select(c => new
                {
                    c.Name,
                    c.Description,
                    c.VotingMode,
                    c.VotingParameter,
                    c.AllowSelfVoting,
                    Criteria = c.Criteria.Select(cr => new { cr.Name, cr.Type, cr.Weight, cr.Description }),
                    Prizes = c.Prizes.Select(p => new { p.Position, p.Name, p.Description })
                })
            };

            var respuesta = await Http.PostAsJsonAsync("https://localhost:7150/api/events", payload);

            if (respuesta.IsSuccessStatusCode)
                Navigation.NavigateTo("/");
            else
            {
                var errorMsg = await respuesta.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Error del servidor: {errorMsg}");
            }
        }
        catch (Exception)
        {
            await JS.InvokeVoidAsync("alert", "Error crítico: No se pudo conectar con el servidor API.");
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/");

    // ── Helpers para el parámetro de votación ────────────────────────────────

    private static string ParametroLabel(string modo) => modo switch
    {
        "PointPool" => "Puntos a repartir por votante",
        "TopN" => "Número de proyectos a elegir (N)",
        "Ranked" => "Puntos para el 1er puesto",
        _ => "Parámetro"
    };

    private static string ParametroPlaceholder(string modo) => modo switch
    {
        "PointPool" => "Ej: 100",
        "TopN" => "Ej: 3",
        "Ranked" => "Ej: 10",
        _ => ""
    };

    private static string ParametroAyuda(string modo) => modo switch
    {
        "PointPool" => "Cada votante distribuye este total de puntos entre los proyectos.",
        "TopN" => "Cada votante selecciona exactamente N proyectos favoritos.",
        "Ranked" => "El 1er proyecto recibe estos puntos, el 2º la mitad, el 3º un tercio...",
        _ => ""
    };

    // ── Modelos locales del formulario ───────────────────────────────────────

    public class CreateEventModel
    {
        [Required(ErrorMessage = "Requerido")]
        public string Name { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;

        [Required(ErrorMessage = "Requerido")]
        public string Modality { get; set; } = string.Empty;

        [Range(1, 1000)]
        public int MaxProjects { get; set; }

        [Required] public DateTime? StartDate { get; set; }
        [Required] public DateTime? EndDate { get; set; }

        public List<CategoryDraft> Categories { get; set; } = new();
    }

    public class CategoryDraft
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string VotingMode { get; set; } = "Scored";
        public int? VotingParameter { get; set; }
        public bool AllowSelfVoting { get; set; } = false;
        public List<CriterionDraft> Criteria { get; set; } = new();
        public List<PrizeDraft> Prizes { get; set; } = new();
    }

    public class CriterionDraft
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string Type { get; set; } = "Numeric";
        public double Weight { get; set; } = 0.0;
    }

    public class PrizeDraft
    {
        public int Position { get; set; } = 1;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }
}