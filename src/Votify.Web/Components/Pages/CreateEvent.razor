@page "/create-event"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore
@using Votify.Domain.EventFolder
@using Votify.Infrastructure
@using Votify.Domain.Factory
@inject NavigationManager Navigation
@inject IDbContextFactory<VotifyDbContext> DbFactory

<PageTitle>Crear Nuevo Evento - Votify</PageTitle>

<div class="create-event-container">
    <EditForm Model="eventModel" OnValidSubmit="ManejarSubmitValido">
        <DataAnnotationsValidator />

        <header class="modal-header">
            <div class="header-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z" />
                </svg>
                <h1>Crear Nuevo Evento</h1>
            </div>
            <button type="button" class="close-btn" @onclick="Cancelar">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
        </header>

        <div class="modal-body">
            <div class="form-group">
                <label>Nombre del evento *</label>
                <InputText class="form-control" placeholder="Ej: Hackathon 2026" @bind-Value="eventModel.Name" />
                <ValidationMessage For="@(() => eventModel.Name)" />
            </div>

            <div class="form-group">
                <label>Descripción *</label>
                <InputTextArea class="form-control" rows="4" placeholder="Describe el evento..." @bind-Value="eventModel.Description" />
                <ValidationMessage For="@(() => eventModel.Description)" />
            </div>

            <div class="form-group">
                <label>Modalidad *</label>
                <InputText class="form-control" placeholder="Ej: Presencial, Online, Híbrido" @bind-Value="eventModel.Modality" />
                <ValidationMessage For="@(() => eventModel.Modality)" />
            </div>

            <div class="form-group">
                <label>Número máximo de proyectos *</label>
                <InputNumber class="form-control" placeholder=DefaultMaxProjects @bind-Value="eventModel.MaxProjects" />
                <ValidationMessage For="@(() => eventModel.MaxProjects)" />
            </div>

            <div class="form-group">
                <label>Fecha de comienzo *</label>
                <InputDate class="form-control" @bind-Value="eventModel.Date" />
                <ValidationMessage For="@(() => eventModel.Date)" />
            </div>
        </div>

        <footer class="modal-footer">
            <button type="submit" class="btn-primary">Crear Evento</button>
        </footer>
    </EditForm>
</div>

@code {
    private CreateEventModel eventModel = new();

	private const int DefaultMaxProjects = 20;

    protected override void OnInitialized()
    {
        eventModel.MaxProjects = DefaultMaxProjects;
    }

    private async Task ManejarSubmitValido()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        EventCreator eventCreator = new ModalityEventCreator();

        var fechaSeleccionada = eventModel.Date ?? DateTime.UtcNow;
        var fechaUtc = DateTime.SpecifyKind(fechaSeleccionada, DateTimeKind.Utc);

        var nuevoEvento = eventCreator.Create(
            name: eventModel.Name,
            maxProjects: eventModel.MaxProjects,
            startDate: fechaUtc,
            modality: eventModel.Modality,
            description: eventModel.Description
        );

        context.Events.Add(nuevoEvento);
        await context.SaveChangesAsync();

        Navigation.NavigateTo("/");
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/");
    }

    public class CreateEventModel
    {
        [Required(ErrorMessage = "El nombre del evento es requerido")]
        [StringLength(100, ErrorMessage = "El nombre no puede superar los 100 caracteres")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "La descripción es requerida")]
        public string Description { get; set; } = string.Empty;

        [Required(ErrorMessage = "La modalidad es requerida")]
        public string Modality { get; set; } = string.Empty;

        [Required(ErrorMessage = "Establece un número máximo de proyectos")]
        [Range(1, 1000, ErrorMessage = "El número debe ser mayor a 0")]
        public int MaxProjects { get; set; }

        [Required(ErrorMessage = "La fecha es requerida")]
        public DateTime? Date { get; set; }
    }
}