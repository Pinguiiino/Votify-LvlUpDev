                                <span>@email</span>
                                <button type="button" class="btn-remove" style="background: none; border: none; color: #9ca3af; cursor: pointer; font-size: 0.9rem; padding: 0;" @onclick="() => ses.JurorEmails.Remove(email)">✕</button>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if (d.Sessions.Count == 2)
        {
            <div class="combine-block">
                <label class="checkbox-row">
                    <input type="checkbox" @bind="d.CombineResults" />
