@page "/event/{EventId}/categories"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Categorías del Evento - Votify</PageTitle>

<div class="categories-page-container">

    @if (evento == null)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Cargando categorías...</p>
        </div>
    }
    else
    {
        <header class="page-header">
            <button class="back-btn" @onclick="Volver">← Volver</button>

            <div class="header-content">
                <div class="event-badge">@evento.Modality</div>
                <h1 class="page-title">@evento.Name</h1>
                @if (!string.IsNullOrWhiteSpace(evento.Description))
                {
                    <p class="page-subtitle">@evento.Description</p>
                }
                <div class="event-meta">
                    <span class="meta-item">@evento.StartDate.ToString("dd MMM yyyy") — @evento.EndDate.ToString("dd MMM yyyy")</span>
                    <span class="meta-item">Máx. @evento.MaxProjects proyectos</span>
                </div>
            </div>
        </header>

        <div class="section-header">
            <h2 class="section-title">
                Categorías
                @if (evento.Categories.Any())
                {
                    <span class="count-badge">@evento.Categories.Count</span>
                }
            </h2>

            <div style="display: flex; gap: 0.75rem; align-items: center;">
                @if (evento.Categories.Any())
                {
                    <a href="@($"/dashboard/{EventId}")" class="btn-secondary" style="text-decoration:none;">Ver resultados</a>

                    @if (isParticipant || isPublic)
                    {
                        <a href="@($"/event/{EventId}/create-project")" class="btn-dark">+ Subir proyecto</a>
                    }

                    @if (isGlobalAuditor)
                    {
                        <a href="@($"/event/{EventId}/audit")" class="btn-dark">Auditar</a>
                    }
                    @if (isOrganizer)
                    {
                        <a href="@($"/event/{EventId}/voting-windows")" class="btn-secondary" style="text-decoration:none;">
                            Ventanas de votación
                        </a>
                    }
                }

                @if (isOrganizer && !mostrandoFormulario)
                {
                    <button class="btn-dark" @onclick="MostrarFormulario">+ Crear categoría</button>
                }
            </div>
        </div>

        @if (!evento.Categories.Any() && !mostrandoFormulario)
        {
            <div class="empty-state">
                <p>
                    Este evento todavía no tiene categorías.
                    Crea la primera para empezar.
                </p>
            </div>
        }

        @if (mostrandoFormulario && isOrganizer)
        {
            <div class="create-cat-panel">
                <h3 class="panel-title">Nueva categoría</h3>
                <p class="panel-subtitle">Configura el nombre, las votaciones y los premios.</p>

                <div class="form-group">
                    <label>Nombre *</label>
                    <input type="text" class="form-control" @bind="draft.Name" placeholder="Ej: Proyectos de IA" />
                </div>

                <div class="form-group">
                    <label>Descripción</label>
                    <textarea class="form-control" rows="2" @bind="draft.Description"
                              placeholder="Descripción opcional..."></textarea>
                </div>

                <div class="form-group">
                    <label class="checkbox-row">
                        <input type="checkbox" @bind="draft.AllowSelfVoting" />
                        Permitir que los participantes voten su propio proyecto
                    </label>
                </div>

                <hr class="panel-divider" />

                <h4 class="section-label">Votaciones</h4>
                <p class="section-hint">Añade al menos una (jurado o público).</p>

                <div class="session-add-buttons">
                    <button type="button" class="btn-secondary"
                            disabled="@(draft.Sessions.Any(s => s.VoterType == "Jury"))"
                            @onclick='() => AddSession("Jury")'>
                        + Votación del jurado
                    </button>
                    <button type="button" class="btn-secondary"
                            disabled="@(draft.Sessions.Any(s => s.VoterType == "Public"))"
                            @onclick='() => AddSession("Public")'>
                        + Votación del público
                    </button>
                </div>

                @foreach (var ses in draft.Sessions)
                {
                    <div class="session-card">
                        <div class="session-card-header">
                            <h5 class="session-title">
                                Votación
                                <span class="voter-tag @(ses.VoterType == "Public" ? "public" : "")">
                                    @(ses.VoterType == "Jury" ? "Jurado" : "Público")
                                </span>
                            </h5>
                            <button type="button" class="btn-remove" @onclick="() => draft.Sessions.Remove(ses)">✕</button>
                        </div>

                        <div class="form-group">
                            <label>Modelo de votación</label>
                            <div class="model-grid">
                                @if (ses.VoterType == "Jury")
                                {
                                    <div class="model-card @(ses.EvaluationType == "WeightedScale" ? "selected" : "")"
                                         @onclick='() => SelectModel(ses, "WeightedScale")'>
                                        <div class="model-radio"></div>
                                        <p class="model-title">Baremo ponderado</p>
                                    </div>
                                }

                                <div class="model-card @(ses.EvaluationType == "PointDistribution" ? "selected" : "")"
                                     @onclick='() => SelectModel(ses, "PointDistribution")'>
                                    <div class="model-radio"></div>
                                    <p class="model-title">Reparto de puntos</p>
                                </div>

                                <div class="model-card @(ses.EvaluationType == "TopN" ? "selected" : "")"
                                     @onclick='() => SelectModel(ses, "TopN")'>
                                    <div class="model-radio"></div>
                                    <p class="model-title">Selección Top-N</p>
                                </div>
                            </div>

                            @if (ses.EvaluationType == "TopN")
                            {
                                <div class="model-config">
                                    <label class="field-label">Top N proyectos a elegir</label>
                                    <input type="number" min="1" class="form-control form-control-sm" @bind="ses.TopN" style="max-width: 100px;" />
                                </div>
                            }
                            else if (ses.EvaluationType == "PointDistribution")
                            {
                                <div class="model-config" style="display:flex; gap:1rem;">
                                    <div>
                                        <label class="field-label">Total puntos</label>
                                        <input type="number" min="1" class="form-control form-control-sm" @bind="ses.PointsPerVoter" style="max-width: 100px;" />
                                    </div>
                                    <div>
                                        <label class="field-label">Máx. por proyecto</label>
                                        <input type="number" min="1" class="form-control form-control-sm" @bind="ses.MaxPointsPerProject" style="max-width: 100px;" />
                                    </div>
                                </div>
                            }

                            @if (ses.EvaluationType == "WeightedScale")
                            {
                                <div class="model-config" style="margin-top: 0.75rem;">
                                    <label class="field-label">Tipo de criterio</label>
                                    <div class="criterion-type-grid" style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                        <div class="model-card @(ses.CriterionType == "Numeric" ? "selected" : "")"
                                             style="flex: 1; min-width: 140px; min-height: auto; padding: 0.65rem 0.85rem;"
                                             @onclick='() => ses.CriterionType = "Numeric"'>
                                            <p class="model-title" style="font-size: 0.85rem; margin: 0;"># Numérico</p>
                                            <p class="model-desc" style="font-size: 0.75rem; margin: 0.15rem 0 0;">Puntuación 0–10 por criterio</p>
                                        </div>
                                        <div class="model-card @(ses.CriterionType == "Checklist" ? "selected" : "")"
                                             style="flex: 1; min-width: 140px; min-height: auto; padding: 0.65rem 0.85rem;"
                                             @onclick='() => ses.CriterionType = "Checklist"'>
                                            <p class="model-title" style="font-size: 0.85rem; margin: 0;">✓ Checklist</p>
                                            <p class="model-desc" style="font-size: 0.75rem; margin: 0.15rem 0 0;">Cumple / no cumple</p>
                                        </div>
                                        <div class="model-card @(ses.CriterionType == "Rubric" ? "selected" : "")"
                                             style="flex: 1; min-width: 140px; min-height: auto; padding: 0.65rem 0.85rem;"
                                             @onclick='() => ses.CriterionType = "Rubric"'>
                                            <p class="model-title" style="font-size: 0.85rem; margin: 0;">▤ Rúbrica</p>
                                            <p class="model-desc" style="font-size: 0.75rem; margin: 0.15rem 0 0;">Niveles D / C / B / A / S</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (ses.EvaluationType == "WeightedScale")
                        {
                            <div class="form-group" style="margin-top: 1.5rem; border-top: 1px dashed #cbd5e1; padding-top: 1rem;">
                                <label>Criterios de evaluación</label>
                                @foreach (var cr in ses.Criteria)
                                {
                                    <div class="item-row">
                                        <div class="item-row-main">
                                            <input type="text" class="form-control form-control-sm" placeholder="Nombre" @bind="cr.Name" />
                                            <input type="number" step="0.05" min="0.05" max="1" class="form-control form-control-sm" placeholder="Peso" @bind="cr.Weight" />
                                            <button type="button" class="btn-remove" @onclick="() => ses.Criteria.Remove(cr)">✕</button>
                                        </div>
                                    </div>
                                }
                                <button type="button" class="btn-ghost" @onclick="() => ses.Criteria.Add(new CriterionDraft())">+ Añadir criterio</button>
                            </div>
                        }

                        <div class="form-group" style="background-color: #f8fafc; padding: 1rem; border-radius: 0.5rem; border: 1px solid #e2e8f0;">
                            <label style="margin-bottom: 0.5rem;">Comentarios</label>

                            <label class="checkbox-row">
                                <input type="checkbox" @bind="ses.AllowComments" />
                                Permitir comentario por proyecto
                            </label>

                            @if (ses.AllowComments)
                            {
                                <label class="checkbox-row" style="margin-left: 1.5rem; margin-top: 0.4rem;">
                                    <input type="checkbox" @bind="ses.RequireComments" />
                                    Hacerlo obligatorio
                                </label>
                            }

                            @if (ses.EvaluationType == "WeightedScale")
                            {
                                <label class="checkbox-row" style="margin-top: 0.4rem;">
                                    <input type="checkbox" @bind="ses.AllowCommentsPerCriterion" />
                                    Permitir comentario por criterio
                                </label>
                            }
                        </div>

                        <div class="form-group" style="margin-top: 1.5rem; border-top: 1px dashed #cbd5e1; padding-top: 1rem;">
                            <label>Premios de esta votación</label>
                            @foreach (var pr in ses.Prizes)
                            {
                                <div class="item-row">
                                    <div class="item-row-main prize" style="grid-template-columns: 4.5rem 2fr auto;">
                                        <input type="number" min="1" class="form-control form-control-sm" placeholder="Pos." @bind="pr.Position" />
                                        <input type="text" class="form-control form-control-sm" placeholder="Recompensa" @bind="pr.Name" />
                                        <button type="button" class="btn-remove" @onclick="() => ses.Prizes.Remove(pr)">✕</button>
                                    </div>
                                    <div class="item-row-desc">
                                        <input type="text" style="width: 100%; border: none; font-size: 0.8rem;" placeholder="Descripción opcional..." @bind="pr.Description" />
                                    </div>
                                </div>
                            }
                            <button type="button" class="btn-ghost" @onclick="() => AddPrize(ses)">+ Añadir premio</button>
                        </div>

                        @if (ses.VoterType == "Jury")
                        {
                            <div class="form-group" style="margin-top: 1.5rem; border-top: 1px dashed #cbd5e1; padding-top: 1rem;">
                                <label>Correos de jurado</label>
                                <div style="display:flex; gap:0.5rem; margin-bottom:0.5rem;">
                                    <input type="email" class="form-control form-control-sm" placeholder="correo@ejemplo.com"
                                           @bind="ses.InputCorreoJurado" @bind:event="oninput"
                                           @onkeydown='async e => { if (e.Key == "Enter") await AddJuror(ses); }' />
                                    <button type="button" class="btn-ghost" @onclick="() => AddJuror(ses)">Añadir</button>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(ses.JurorError))
                                {
                                    <div style="color: #ef4444; font-size: 0.85rem; margin-bottom: 0.75rem;">@ses.JurorError</div>
                                }

                                @foreach (var email in ses.JurorEmails)
                                {
                                    <div class="juror-chip" style="display: inline-flex; align-items: center; gap: 0.4rem; background: #f3f4f6; padding: 0.2rem 0.6rem; border-radius: 9999px; font-size: 0.85rem; margin-right: 0.4rem; margin-bottom: 0.4rem;">
                                        <span>@email</span>
                                        <button type="button" class="btn-remove" style="background: none; border: none; color: #9ca3af; cursor: pointer; font-size: 0.9rem; padding: 0;" @onclick="() => ses.JurorEmails.Remove(email)">✕</button>
                                    </div>
                                }
                            </div>
                        }

                    </div>
                }

                @if (draft.Sessions.Count == 2)
                {
                    <div class="combine-block">
                        <label class="checkbox-row">
                            <input type="checkbox" @bind="draft.CombineResults" />
                            Combinar resultados de jurado y público en un único ranking
                        </label>
                        @if (draft.CombineResults)
                        {
                            <div class="combine-weights">
                                <div><label>Peso jurado</label><input type="number" step="0.05" @bind="draft.JuryWeight" class="form-control" /></div>
                                <div><label>Peso público</label><input type="number" step="0.05" @bind="draft.PublicWeight" class="form-control" /></div>
                            </div>
                        }
                    </div>
                }

                @if (errorFormulario != null)
                {
                    <div class="error-banner">@errorFormulario</div>
                }

                <div class="panel-actions">
                    <button type="button" class="btn-secondary" @onclick="CancelarFormulario">Cancelar</button>
                    <button type="button" class="btn-primary" disabled="@guardando" @onclick="GuardarCategoria">
                        @(guardando ? "Guardando..." : "Guardar categoría")
                    </button>
                </div>
            </div>
        }

        @if (evento.Categories.Any())
        {
            <div class="categories-grid">
                @foreach (var cat in evento.Categories)
                {
                    <div class="category-card @(expandedCategoryId == cat.Id ? "expanded" : "")">
                        <div class="cat-card-header" @onclick="() => ToggleExpand(cat.Id)">
                            <div class="cat-title-row">
                                <div style="flex:1; min-width:0;">
                                    <h3 class="cat-name">@cat.Name</h3>
                                    @if (!string.IsNullOrWhiteSpace(cat.Description))
                                    {
                                        <p class="cat-description">@cat.Description</p>
                                    }
                                </div>
                            </div>
                            <div class="cat-summary-row">
                                <div class="cat-pills">
                                    <!-- AQUÍ AÑADIMOS LA PÍLDORA SI ERES JURADO -->
                                    @if (cat.VotingSessions.Any(vs => vs.VoterType == "Jury" && vs.JurorEmails.Contains(currentUserEmail)))
                                    {
                                        <span class="pill" style="background-color: #fef08a; color: #92400e; border: 1px solid #fde047;">⭐ Eres jurado</span>
                                    }

                                    @foreach (var vs in cat.VotingSessions)
                                    {
                                        <span class="pill @(vs.VoterType == "Public" ? "pill-green" : "pill-blue")">
                                            @(vs.VoterType == "Jury" ? "Jurado" : "Público") — @FormatEval(vs)
                                        </span>
                                    }
                                    @if (cat.CombineResults)
                                    {
                                        <span class="pill pill-amber">Combinada @((cat.JuryWeight * 100)?.ToString("0"))% / @((cat.PublicWeight * 100)?.ToString("0"))%</span>
                                    }
                                    @if (cat.AllowSelfVoting)
                                    {
                                        <span class="pill" style="background:#f3f4f6; color:#374151;">Autovoto permitido</span>
                                    }
                                </div>
                                <span style="color:#6b7280; font-size:0.85rem;">@(expandedCategoryId == cat.Id ? "▲" : "▼")</span>
                            </div>
                        </div>

                        @if (expandedCategoryId == cat.Id)
                        {
                            <div class="cat-card-body">
                                @if (cat.CombineResults)
                                {
                                    <div class="detail-section">
                                        <p class="detail-title">Resultados combinados</p>
                                        <span style="font-size:0.85rem; color:#374151;">
                                            Jurado: @((cat.JuryWeight * 100)?.ToString("0"))% / Público: @((cat.PublicWeight * 100)?.ToString("0"))%
                                        </span>
                                    </div>
                                }

                                @foreach (var vs in cat.VotingSessions)
                                {
                                    <div class="detail-section">
                                        <p class="detail-title">
                                            <span class="voter-tag @(vs.VoterType == "Public" ? "public" : "")">
                                                @(vs.VoterType == "Jury" ? "Jurado" : "Público")
                                            </span>
                                            <span style="color:#374151; text-transform:none; letter-spacing:0; font-weight:600;">@FormatEval(vs)</span>
                                        </p>

                                        @if (vs.Criteria.Any())
                                        {
                                            <div class="criteria-list">
                                                @foreach (var cr in vs.Criteria)
                                                {
                                                    <div class="criterion-item">
                                                        <div class="criterion-info">
                                                            <div class="criterion-name-row">
                                                                <span class="criterion-name">@cr.Name</span>
                                                            </div>
                                                        </div>
                                                        <div class="weight-display">
                                                            <div class="weight-bar-container">
                                                                <div class="weight-bar" style="width: @((cr.Weight * 100).ToString("0"))%"></div>
                                                            </div>
                                                            <span class="weight-label">@((cr.Weight * 100).ToString("0"))%</span>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }

                                        <div style="margin-top: 1rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 0.9rem 1rem; display: flex; align-items: center; gap: 0.6rem; font-size: 0.82rem; color: #475569;">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z" />
                                                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z" />
                                            </svg>
                                            @if (vs.OpenAt.HasValue && vs.CloseAt.HasValue)
                                            {
                                                <span>
                                                    Ventana: <strong>@vs.OpenAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                                    — <strong>@vs.CloseAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                                </span>
                                            }
                                            else
                                            {
                                                <span style="color: #94a3b8; font-style: italic;">Sin ventana temporal configurada</span>
                                            }
                                        </div>

                                        @if (vs.Prizes.Any())
                                        {
                                            <div class="prizes-list" style="margin-top:1rem; border-top:1px dashed #e2e8f0; padding-top:1rem;">
                                                <h5 style="font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:#b45309; margin:0 0 0.5rem 0;">Premios de esta votación:</h5>
                                                @foreach (var pr in vs.Prizes.OrderBy(p => p.Position))
                                                {
                                                    <div class="prize-item">
                                                        <div class="prize-position">
                                                            @(pr.Position == 1 ? "🥇" : pr.Position == 2 ? "🥈" : pr.Position == 3 ? "🥉" : $"#{pr.Position}")
                                                        </div>
                                                        <div class="prize-info">
                                                            <span class="prize-name">@pr.Name</span>
                                                            @if (!string.IsNullOrWhiteSpace(pr.Description))
                                                            {
                                                                <p class="prize-desc">@pr.Description</p>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                <!-- HEMOS CORREGIDO EL BUG AQUÍ PARA QUE COMPRUEBE EL CORREO EN LUGAR DEL ID -->
                                @if (isOrganizer || cat.VotingSessions.Any(vs =>
                                    (vs.VoterType == "Jury" && vs.JurorEmails.Contains(currentUserEmail)) ||
                                    (vs.VoterType == "Public" && (isParticipant || isPublic))))
                                {
                                    <a href="@($"/event/{EventId}/categories/{cat.Id}/projects")"
                                           class="btn-primary" style="display:inline-block; text-decoration:none; align-self:flex-start;">
                                        Ver proyectos y votar →
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string EventId { get; set; } = string.Empty;

    private EventDetailDto? evento;
    private string? expandedCategoryId;

    private bool mostrandoFormulario;
    private bool guardando;
    private string? errorFormulario;
    private CategoryDraft draft = new();

    private string currentUserId = string.Empty;
    private string currentUserEmail = string.Empty; // <-- AÑADIDO PARA LA PÍLDORA

    private bool isGlobalAuditor = false;
    private bool isOrganizer = false;
    private bool isParticipant = false;
    private bool isPublic = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        
        // Recuperamos el correo del usuario en minúsculas para las comparaciones
        currentUserEmail = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value?.ToLower() ?? string.Empty;
        
        isGlobalAuditor = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Auditor";
        await CargarEvento();
    }

    private async Task CargarEvento()
    {
        var http = HttpClientFactory.CreateClient("API");
        evento = await http.GetFromJsonAsync<EventDetailDto>($"/api/events/{EventId}");

        if (evento != null && !string.IsNullOrEmpty(currentUserId))
        {
            isOrganizer = evento.Organizer == currentUserId;
            isParticipant = evento.ParticipantsIds.Contains(currentUserId);
            isPublic = evento.PublicIds.Contains(currentUserId);
        }
    }

    private void ToggleExpand(string catId) => expandedCategoryId = expandedCategoryId == catId ? null : catId;
    private void Volver() => Navigation.NavigateTo("/MainEvent");
    private void MostrarFormulario() { draft = new CategoryDraft(); errorFormulario = null; mostrandoFormulario = true; }
    private void CancelarFormulario() { mostrandoFormulario = false; errorFormulario = null; }

    private void AddSession(string voterType)
    {
        var defaultEval = voterType == "Jury" ? "WeightedScale" : "TopN";
        draft.Sessions.Add(new SessionDraft
        {
            VoterType = voterType,
            EvaluationType = defaultEval,
            TopN = defaultEval == "TopN" ? 3 : null,
        });
    }

    private void SelectModel(SessionDraft ses, string model)
    {
        ses.EvaluationType = model;

        if (model != "WeightedScale")
        {
            ses.CriterionType = null;
            ses.AllowCommentsPerCriterion = false;
        }
        else if (string.IsNullOrEmpty(ses.CriterionType))
        {
            ses.CriterionType = "Numeric";
        }
    }

    private void AddPrize(SessionDraft ses)
    {
        ses.Prizes.Add(new PrizeDraft { Position = ses.Prizes.Count + 1 });
    }

    private async Task AddJuror(SessionDraft ses)
    {
        ses.JurorError = null; // Limpiar errores anteriores
        var correo = ses.InputCorreoJurado?.Trim().ToLower();
        if (string.IsNullOrWhiteSpace(correo)) return;

        if (ses.JurorEmails.Contains(correo))
        {
            ses.InputCorreoJurado = string.Empty;
            return;
        }

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var existe = await http.GetFromJsonAsync<bool>($"api/auth/check-email?email={correo}");

            if (existe)
            {
                ses.JurorEmails.Add(correo);
                ses.InputCorreoJurado = string.Empty;
            }
            else
            {
                ses.JurorError = $"La cuenta '{correo}' no está registrada en Votify.";
            }
        }
        catch
        {
            ses.JurorError = "Error al verificar el correo con el servidor.";
        }
    }

    private static string FormatEval(VotingSessionDto vs) => vs.EvaluationType switch
    {
        "WeightedScale" => "Baremo ponderado",
        "PointDistribution" => $"Reparto {vs.PointsPerVoter}pts (máx {vs.MaxPointsPerProject}/proy)",
        "TopN" => $"Top {vs.TopN}",
        _ => vs.EvaluationType
    };

    private void OnSessionOpenAtChange(SessionDraft ses, string? value)
    {
        ses.OpenAt = string.IsNullOrEmpty(value) ? null : DateTime.Parse(value).ToUniversalTime();
        if (ses.OpenAt.HasValue && ses.CloseAt.HasValue && ses.CloseAt <= ses.OpenAt)
            ses.CloseAt = null;
    }

    private void OnSessionCloseAtChange(SessionDraft ses, string? value)
    {
        ses.CloseAt = string.IsNullOrEmpty(value) ? null : DateTime.Parse(value).ToUniversalTime();
    }

    private async Task GuardarCategoria()
    {
        errorFormulario = null;

        if (string.IsNullOrWhiteSpace(draft.Name))
        {
            errorFormulario = "El nombre de la categoría es obligatorio.";
            return;
        }
        if (draft.Sessions.Count == 0)
        {
            errorFormulario = "Debe haber al menos una votación.";
            return;
        }

        foreach (var ses in draft.Sessions)
        {
            string tipoVotante = ses.VoterType == "Jury" ? "Jurado" : "Público";

            if (ses.OpenAt.HasValue && ses.CloseAt.HasValue && ses.CloseAt <= ses.OpenAt)
            {
                errorFormulario = $"La votación de {tipoVotante}: la fecha de cierre debe ser posterior a la de apertura.";
                return;
            }

            if (ses.OpenAt.HasValue && ses.OpenAt < DateTime.UtcNow)
            {
                errorFormulario = $"La votación de {tipoVotante}: la fecha de apertura no puede ser anterior a la actual.";
                return;
            }

            if (ses.CloseAt.HasValue && evento != null && ses.CloseAt > evento.EndDate.ToUniversalTime())
            {
                errorFormulario = $"La votación de {tipoVotante}: la fecha de cierre no puede superar el fin del evento ({evento.EndDate:dd/MM/yyyy}).";
                return;
            }

            if (ses.VoterType == "Jury" && !ses.JurorEmails.Any())
            {
                errorFormulario = "La votación de Jurado requiere al menos un correo de jurado asignado.";
                return;
            }

            if (ses.EvaluationType == "WeightedScale" && !ses.Criteria.Any())
            {
                errorFormulario = $"La votación de {tipoVotante} requiere al menos un criterio porque usa Baremo Ponderado.";
                return;
            }

            if (ses.Criteria.Any())
            {
                double sumaPesos = 0;
                foreach (var cr in ses.Criteria)
                {
                    if (string.IsNullOrWhiteSpace(cr.Name))
                    {
                        errorFormulario = $"Todos los criterios en la votación de {tipoVotante} deben tener un nombre.";
                        return;
                    }
                    if (cr.Weight <= 0)
                    {
                        errorFormulario = $"El peso del criterio '{cr.Name}' debe ser mayor que 0.";
                        return;
                    }
                    sumaPesos += cr.Weight;
                }

                if (Math.Abs(sumaPesos - 1.0) > 0.001)
                {
                    errorFormulario = $"La suma de los pesos de los criterios en la votación de {tipoVotante} debe ser exactamente 1 (actualmente suma {sumaPesos.ToString("0.##")}).";
                    return;
                }
            }

            if (ses.Prizes.Count == 0)
            {
                errorFormulario = $"La votación de {tipoVotante} debe tener al menos un premio.";
                return;
            }

            if (!ses.AllowComments)
            {
                ses.RequireComments = false;
            }

            if (ses.EvaluationType != "WeightedScale")
            {
                ses.AllowCommentsPerCriterion = false;
            }
        }

        try
        {
            guardando = true;
            var payload = new
            {
                EventId = EventId,
                draft.Name,
                draft.Description,
                draft.AllowSelfVoting,
                draft.CombineResults,
                JuryWeight = draft.CombineResults ? draft.JuryWeight : null,
                PublicWeight = draft.CombineResults ? draft.PublicWeight : null,
                VotingSessions = draft.Sessions.Select(s => new
                {
                    s.VoterType,
                    s.EvaluationType,
                    s.CriterionType,
                    s.TopN,
                    s.PointsPerVoter,
                    s.MaxPointsPerProject,
                    s.AllowComments,
                    s.RequireComments,
                    s.AllowCommentsPerCriterion,
                    OpenAt = s.OpenAt,
                    CloseAt = s.CloseAt,
                    JurorEmails = s.VoterType == "Jury" ? s.JurorEmails : new List<string>(),
                    Criteria = s.Criteria.Select(c => new { c.Name, c.Weight }),
                    Prizes = s.Prizes.Select(p => new { p.Position, p.Name, p.Description })
                })
            };

            var http = HttpClientFactory.CreateClient("API");
            var resp = await http.PostAsJsonAsync("/api/categories", payload);

            if (resp.IsSuccessStatusCode)
            {
                mostrandoFormulario = false;
                await CargarEvento();
            }
            else
            {
                errorFormulario = (await resp.Content.ReadAsStringAsync()).Trim('"');
            }
        }
        catch (Exception ex) { errorFormulario = $"Error: {ex.Message}"; }
        finally { guardando = false; }
    }

