@page "/event/{EventId}/categories"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Votify.Domain.CategoryFolder
@using Votify.Domain.EventFolder
@using Votify.Infrastructure
@inject NavigationManager Navigation
@inject IDbContextFactory<VotifyDbContext> DbFactory

<PageTitle>Categorías del Evento - Votify</PageTitle>

<div class="categories-page-container">

    @if (evento == null)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Cargando categorías...</p>
        </div>
    }
    else
    {
        <header class="page-header">
            <button class="back-btn" @onclick="Volver">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                </svg>
                Volver
            </button>

            <div class="header-content">
                <div class="event-badge">@evento.Modality()</div>
                <h1 class="page-title">@evento.Name</h1>
                @if (!string.IsNullOrWhiteSpace(evento.Description))
                {
                    <p class="page-subtitle">@evento.Description</p>
                }
                <div class="event-meta">
                    <span class="meta-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
                        </svg>
                        @evento.StartDate.ToString("dd MMM yyyy") — @evento.EndDate.ToString("dd MMM yyyy")
                    </span>
                    <span class="meta-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                            <path fill-rule="evenodd" d="M5.216 14A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216z"/>
                            <path d="M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/>
                        </svg>
                        Máx. @evento.MaxProjects proyectos · Top @evento.TopNProjectsAllowed
                    </span>
                </div>
            </div>
        </header>

        @if (!categorias.Any())
        {
            <div class="empty-state">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5V2zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1H4z"/>
                </svg>
                <p>Este evento no tiene categorías configuradas.</p>
            </div>
        }
        else
        {
            <div class="section-header">
                <h2 class="section-title">Categorías <span class="count-badge">@categorias.Count</span></h2>
                <a href="@($"/event/{EventId}/create-project")" class="btn-dark">
                    + Subir Proyecto
                </a>
            </div>

            <div class="categories-grid">
                @foreach (var cat in categorias)
                {
                    <div class="category-card @(expandedCategoryId == cat.Id ? "expanded" : "")">

                        <div class="cat-card-header" @onclick="() => ToggleExpand(cat.Id)">
                            <div class="cat-title-row">
                                <div class="cat-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5V2zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1H4z"/>
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="cat-name">@cat.Name</h3>
                                    @if (!string.IsNullOrWhiteSpace(cat.Description))
                                    {
                                        <p class="cat-description">@cat.Description</p>
                                    }
                                </div>
                            </div>

                            <div class="cat-summary-row">
                                <div class="cat-pills">
                                    @if (cat.Criteria.Any())
                                    {
                                        <span class="pill pill-blue">@cat.Criteria.Count criterio@(cat.Criteria.Count != 1 ? "s" : "")</span>
                                    }
                                    @if (cat.Prizes.Any())
                                    {
                                        <span class="pill pill-amber">@cat.Prizes.Count premio@(cat.Prizes.Count != 1 ? "s" : "")</span>
                                    }
                                    @if (cat.AllowSelfVoting)
                                    {
                                        <span class="pill pill-green">Autovoto permitido</span>
                                    }
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <a href="@($"/event/{EventId}/categories/{cat.Id}/projects")"
                                       class="btn-explore"
                                       @onclick:stopPropagation="true">
                                        Explorar proyectos
                                    </a>
                                    <div class="expand-icon @(expandedCategoryId == cat.Id ? "rotated" : "")">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                            <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                                        </svg>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (expandedCategoryId == cat.Id)
                        {
                            <div class="cat-card-body">

                                @if (cat.Criteria.Any())
                                {
                                    <div class="detail-section">
                                        <h4 class="detail-title">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M2.5 3a.5.5 0 0 0 0 1h11a.5.5 0 0 0 0-1h-11zm0 3a.5.5 0 0 0 0 1h6a.5.5 0 0 0 0-1h-6zm0 3a.5.5 0 0 0 0 1h6a.5.5 0 0 0 0-1h-6zm0 3a.5.5 0 0 0 0 1h11a.5.5 0 0 0 0-1h-11zm10.113-5.373a6.59 6.59 0 0 0-.445-.275l.138-.48C12.698 6.01 13 5.51 13 5c0-.726-.284-1.4-.845-1.898-.562-.498-1.358-.798-2.228-.886a.5.5 0 0 0-.479.26l-.143.274c-.045.09-.046.19-.003.28l.145.290a.5.5 0 0 0 .483.303C10.55 3.41 11 3.79 11 5c0 .353-.187.68-.483.87l-.145.089a.5.5 0 0 0-.195.601l.144.48c.086.287.363.45.65.384.405-.09.79-.266 1.1-.514a.5.5 0 0 0 .137-.698z"/>
                                            </svg>
                                            Criterios de evaluación
                                        </h4>
                                        <div class="criteria-list">
                                            @foreach (var cr in cat.Criteria.OrderByDescending(c => c.Weight))
                                            {
                                                <div class="criterion-item">
                                                    <div class="criterion-info">
                                                        <div class="criterion-name-row">
                                                            <span class="criterion-name">@cr.Name</span>
                                                            <span class="criterion-type-badge">@cr.Type</span>
                                                        </div>
                                                        @if (!string.IsNullOrWhiteSpace(cr.Description))
                                                        {
                                                            <p class="criterion-desc">@cr.Description</p>
                                                        }
                                                    </div>
                                                    <div class="weight-display">
                                                        <div class="weight-bar-container">
                                                            <div class="weight-bar" style="width: @((cr.Weight * 100).ToString("0"))%"></div>
                                                        </div>
                                                        <span class="weight-label">@((cr.Weight * 100).ToString("0"))%</span>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (cat.Prizes.Any())
                                {
                                    <div class="detail-section">
                                        <h4 class="detail-title">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M2.5.5A.5.5 0 0 1 3 0h10a.5.5 0 0 1 .5.5c0 .538-.012 1.05-.034 1.536a3 3 0 1 1-1.133 5.89c-.79 1.865-1.878 2.777-2.833 3.011v2.173l1.425.356c.194.048.377.135.537.255L13.3 15.1a.5.5 0 0 1-.3.9H3a.5.5 0 0 1-.3-.9l1.838-1.379c.16-.12.343-.207.537-.255L6.5 13.11v-2.173c-.955-.234-2.043-1.146-2.833-3.012a3 3 0 1 1-1.132-5.89A33.076 33.076 0 0 1 2.5.5zm.099 2.54a2 2 0 0 0 .72 3.935c-.333-1.05-.588-2.346-.72-3.935zm10.083 3.935a2 2 0 0 0 .72-3.935c-.133 1.59-.388 2.885-.72 3.935zM3.504 1c.007.517.026 1.006.056 1.469.13 2.028.457 3.546.87 4.667C5.294 9.48 6.484 10 7 10a.5.5 0 0 1 .5.5v2.61a1 1 0 0 1-.757.97l-1.426.356-.179.046H10.862l-.179-.046-1.426-.356a1 1 0 0 1-.757-.97V10.5A.5.5 0 0 1 9 10c.516 0 1.706-.52 2.57-2.864.413-1.12.74-2.64.87-4.667.03-.463.049-.952.056-1.469H3.504z"/>
                                            </svg>
                                            Premios
                                        </h4>
                                        <div class="prizes-list">
                                            @foreach (var pr in cat.Prizes.OrderBy(p => p.Position))
                                            {
                                                <div class="prize-item">
                                                    <div class="prize-position pos-@pr.Position">
                                                        @(pr.Position == 1 ? "🥇" : pr.Position == 2 ? "🥈" : pr.Position == 3 ? "🥉" : $"#{pr.Position}")
                                                    </div>
                                                    <div class="prize-info">
                                                        <span class="prize-name">@pr.Name</span>
                                                        @if (!string.IsNullOrWhiteSpace(pr.Description))
                                                        {
                                                            <p class="prize-desc">@pr.Description</p>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string EventId { get; set; } = string.Empty;

    private Event? evento;
    private List<Category> categorias = new();
    private string? expandedCategoryId;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        evento = await context.Events
            .AsNoTracking()
            .FirstOrDefaultAsync(e => e.Id == EventId);

        if (evento != null)
        {
            categorias = await context.Categories
                .Include(c => c.Criteria)
                .Include(c => c.Prizes)
                .Where(c => c.EventId == EventId)
                .AsNoTracking()
                .ToListAsync();
        }
    }

    private void ToggleExpand(string catId)
    {
        expandedCategoryId = expandedCategoryId == catId ? null : catId;
    }

    private void Volver() => Navigation.NavigateTo("/");
}
