@page "/event/{EventId}/categories"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@using Votify.Web.Auth
@inject CustomAuthStateProvider CustomAuthProvider

<PageTitle>Categorías del Evento - Votify</PageTitle>

<div class="categories-page-container">

    @if (evento == null)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Cargando categorías...</p>
        </div>
    }
    else
    {
        <header class="page-header">
            <Breadcrumb EventId="@EventId" CurrentPageName="Categorías" />
            <button class="btn-volver" @onclick="Volver">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
                </svg>
                Volver
            </button>

            <div class="header-content">
                <div class="event-badge">@evento.Modality</div>
                <h1 class="page-title">@evento.Name</h1>
                @if (!string.IsNullOrWhiteSpace(evento.Description))
                {
                    <p class="page-subtitle">@evento.Description</p>
                }
                <div class="event-meta">
                    <span class="meta-item">@evento.StartDate.ToString("dd MMM yyyy") — @evento.EndDate.ToString("dd MMM yyyy")</span>
                    <span class="meta-item">Máx. @evento.MaxProjects proyectos</span>
                </div>
            </div>
        </header>

        <div class="section-header">
            <h2 class="section-title">
                Categorías
                @if (evento.Categories.Any())
                {
                    <span class="count-badge">@evento.Categories.Count</span>
                }
            </h2>

            <div style="display: flex; gap: 0.75rem; align-items: center;">
                @if (evento.Categories.Any())
                {
                    <a href="@($"/dashboard/{EventId}")" class="btn-secondary" style="text-decoration:none;">Ver resultados</a>

                    @if ((isParticipant || isPublic) && !eventoNoIniciado && !eventoFinalizado)
                    {
                        <a href="@($"/event/{EventId}/create-project")" class="btn-dark">+ Subir proyecto</a>
                    }

                    @if (isGlobalAuditor || isAuditor)
                    {
                        <a href="@($"/event/{EventId}/audit")" class="btn-dark">Auditar</a>
                    }
                    @if (isOrganizer)
                    {
                        <a href="@($"/event/{EventId}/voting-windows")" class="btn-secondary" style="text-decoration:none;">
                            Ventanas de votación
                        </a>
                        <a href="@($"/event/{EventId}/pending-projects")" class="btn-secondary" style="text-decoration:none;">
                            Validar proyectos
                        </a>
                    }
                }

                @if (isOrganizer && !mostrandoFormulario)
                {
                    <button class="btn-dark" @onclick="MostrarFormulario">+ Crear categoría</button>
                }
            </div>
        </div>

        @if (!evento.Categories.Any() && !mostrandoFormulario)
        {
            <div class="empty-state">
                <p>Este evento todavía no tiene categorías. Crea la primera para empezar.</p>
            </div>
        }

        @if (mostrandoFormulario && isOrganizer)
        {
            <div class="create-cat-panel">
                <h3 class="panel-title">Nueva categoría</h3>
                <p class="panel-subtitle">Configura el nombre, las votaciones y los premios.</p>

                @RenderCategoryForm(draft)

                @if (errorFormulario != null)
                {
                    <div class="error-banner">@errorFormulario</div>
                }

                <div class="panel-actions">
                    <button type="button" class="btn-secondary" @onclick="CancelarFormulario">Cancelar</button>
                    <button type="button" class="btn-primary" disabled="@guardando" @onclick="GuardarCategoria">
                        @(guardando ? "Guardando..." : "Guardar categoría")
                    </button>
                </div>
            </div>
        }

        @if (evento.Categories.Any())
        {
            <div class="categories-grid">
                @foreach (var cat in evento.Categories)
                {
                    <div class="category-card @(expandedCategoryId == cat.Id ? "expanded" : "")" style="position: relative;">
                        @if (isOrganizer)
                        {
                            <div style="position: absolute; bottom: 0.85rem; right: 0.85rem; display: flex; gap: 0.5rem; z-index: 2;" @onclick:stopPropagation="true">
                                @if (eventoNoIniciado)
                                {
                                    <button type="button"
                                            title="Editar categoría"
                                            @onclick='() => Navigation.NavigateTo($"/event/{EventId}/categories/{cat.Id}/edit")'
                                            style="width: 2.2rem; height: 2.2rem; border-radius: 50%; border: none; background-color: #374151; color: white; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 2px 6px rgba(55,65,81,0.4); transition: background-color 0.2s;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
                                        </svg>
                                    </button>
                                }
                                <button type="button"
                                        title="Eliminar categoría"
                                        @onclick="() => AbrirModalEliminarCategoria(cat)"
                                        style="width: 2.2rem; height: 2.2rem; border-radius: 50%; border: none; background-color: #ef4444; color: white; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 2px 6px rgba(239,68,68,0.4); transition: background-color 0.2s;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z" />
                                        <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z" />
                                    </svg>
                                </button>
                            </div>
                        }

                        <div class="cat-card-header" @onclick="() => ToggleExpand(cat.Id)">
                            <div class="cat-title-row">
                                <div style="flex:1; min-width:0;">
                                    <h3 class="cat-name">@cat.Name</h3>
                                    @if (!string.IsNullOrWhiteSpace(cat.Description))
                                    {
                                        <p class="cat-description">@cat.Description</p>
                                    }
                                </div>
                            </div>
                            <div class="cat-summary-row">
                                <div class="cat-pills">
                                    @if (cat.VotingSessions.Any(vs => vs.VoterType == "Jury" && vs.JurorEmails.Contains(currentUserEmail)))
                                    {
                                        <span class="pill" style="background-color: #fef08a; color: #92400e; border: 1px solid #fde047;">⭐ Eres jurado</span>
                                    }
                                    @foreach (var vs in cat.VotingSessions)
                                    {
                                        <span class="pill @(vs.VoterType == "Public" ? "pill-green" : "pill-blue")">
                                            @(vs.VoterType == "Jury" ? "Jurado" : "Público") — @FormatEval(vs)
                                        </span>
                                    }
                                    @if (cat.CombineResults)
                                    {
                                        <span class="pill pill-amber">Combinada @((cat.JuryWeight * 100)?.ToString("0"))% / @((cat.PublicWeight * 100)?.ToString("0"))%</span>
                                    }
                                    @if (cat.AllowSelfVoting)
                                    {
                                        <span class="pill" style="background:#f3f4f6; color:#374151;">Autovoto permitido</span>
                                    }
                                </div>
                                <span style="color:#6b7280; font-size:0.85rem;">@(expandedCategoryId == cat.Id ? "▲" : "▼")</span>
                            </div>
                        </div>

                        @if (expandedCategoryId == cat.Id)
                        {
                            <div class="cat-card-body">
                                @if (cat.CombineResults)
                                {
                                    <div class="detail-section">
                                        <p class="detail-title">Resultados combinados</p>
                                        <span style="font-size:0.85rem; color:#374151;">
                                            Jurado: @((cat.JuryWeight * 100)?.ToString("0"))% / Público: @((cat.PublicWeight * 100)?.ToString("0"))%
                                        </span>
                                    </div>
                                }

                                @foreach (var vs in cat.VotingSessions)
                                {
                                    <div class="detail-section">
                                        <p class="detail-title">
                                            <span class="voter-tag @(vs.VoterType == "Public" ? "public" : "")">
                                                @(vs.VoterType == "Jury" ? "Jurado" : "Público")
                                            </span>
                                            <span style="color:#374151; text-transform:none; letter-spacing:0; font-weight:600;">@FormatEval(vs)</span>
                                        </p>

                                        @if (vs.Criteria.Any())
                                        {
                                            <div class="criteria-list">
                                                @foreach (var cr in vs.Criteria)
                                                {
                                                    <div class="criterion-item">
                                                        <div class="criterion-info">
                                                            <div class="criterion-name-row">
                                                                <span class="criterion-name">@cr.Name</span>
                                                            </div>
                                                        </div>
                                                        <div class="weight-display">
                                                            <div class="weight-bar-container">
                                                                <div class="weight-bar" style="width: @((cr.Weight * 100).ToString("0"))%"></div>
                                                            </div>
                                                            <span class="weight-label">@((cr.Weight * 100).ToString("0"))%</span>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }

                                        <div style="margin-top: 1rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 0.9rem 1rem; display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; font-size: 0.82rem; color: #475569;">
                                            <div style="display: flex; align-items: center; gap: 0.6rem;">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z" />
                                                    <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z" />
                                                </svg>
                                                @if (vs.OpenAt.HasValue && vs.CloseAt.HasValue)
                                                {
                                                    <span>
                                                        Ventana: <strong>@vs.OpenAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                                        — <strong>@vs.CloseAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span style="color: #94a3b8; font-style: italic;">Sin ventana temporal configurada</span>
                                                }
                                            </div>
                                            @{
                                                var estadoKey = GetVsStatusKey(vs);
                                            }
                                            <span style="font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.65rem; border-radius: 99px;
                                                background: @(estadoKey == "open" ? "#dcfce7" : estadoKey == "paused" ? "#fef9c3" : estadoKey == "scheduled" ? "#e0e7ff" : "#f1f5f9");
                                                color: @(estadoKey == "open" ? "#15803d" : estadoKey == "paused" ? "#a16207" : estadoKey == "closed" ? "#64748b" : estadoKey == "scheduled" ? "#4338ca" : "#64748b");">
                                                @(estadoKey == "open" ? "● Abierta" : estadoKey == "paused" ? "⏸ Pausada" : estadoKey == "closed" ? "■ Cerrada" : estadoKey == "scheduled" ? "◷ Programada" : "○ Por asignar")
                                            </span>
                                        </div>

                                        @if (vs.Prizes.Any())
                                        {
                                            <div class="prizes-list" style="margin-top:1rem; border-top:1px dashed #e2e8f0; padding-top:1rem;">
                                                <h5 style="font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:#b45309; margin:0 0 0.5rem 0;">Premios de esta votación:</h5>
                                                @foreach (var pr in vs.Prizes.OrderBy(p => p.Position))
                                                {
                                                    <div class="prize-item">
                                                        <div class="prize-position">
                                                            @(pr.Position == 1 ? "🥇" : pr.Position == 2 ? "🥈" : pr.Position == 3 ? "🥉" : $"#{pr.Position}")
                                                        </div>
                                                        <div class="prize-info">
                                                            <span class="prize-name">@pr.Name</span>
                                                            @if (!string.IsNullOrWhiteSpace(pr.Description))
                                                            {
                                                                <p class="prize-desc">@pr.Description</p>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                @{
                                    bool puedeVotar = cat.VotingSessions.Any(vs =>
                                        (vs.VoterType == "Jury" && vs.JurorEmails.Contains(currentUserEmail)) ||
                                        (vs.VoterType == "Public" && (isParticipant || isPublic)));
                                }
                                <a href="@($"/event/{EventId}/categories/{cat.Id}/projects")"
                                       class="btn-primary" style="display:inline-block; text-decoration:none; align-self:flex-start;">
                                    @(puedeVotar ? "Ver proyectos y votar →" : "Ver proyectos →")
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@* ── MODAL ELIMINAR CATEGORÍA ── *@
@if (categoriaAEliminar != null)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(17,24,39,0.55); display: flex; align-items: center; justify-content: center; z-index: 10000; backdrop-filter: blur(4px); padding: 1rem;"
         @onclick="CerrarModalEliminarCategoria">
        <div style="background: white; width: 100%; max-width: 440px; border-radius: 1rem; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.15); padding: 2rem; text-align: center;"
             @onclick:stopPropagation="true">
            <div style="width: 3rem; height: 3rem; background-color: #fee2e2; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#ef4444" viewBox="0 0 16 16">
                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z" />
                    <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z" />
                </svg>
            </div>
            <h2 style="font-size: 1.15rem; font-weight: 700; color: #111827; margin: 0 0 0.5rem;">¿Está seguro de que desea eliminar '@categoriaAEliminar.Name'?</h2>
            <p style="font-size: 0.9rem; color: #6b7280; margin: 0 0 1.75rem;">Se eliminarán también todas sus votaciones y resultados asociados. Esta acción no se puede deshacer.</p>
            <div style="display: flex; gap: 0.75rem; justify-content: center;">
                <button @onclick="CerrarModalEliminarCategoria"
                        style="flex: 1; padding: 0.65rem 1.25rem; border-radius: 0.5rem; border: 1px solid #d1d5db; background: white; color: #374151; font-weight: 600; cursor: pointer; font-size: 0.95rem;">
                    Cancelar
                </button>
                <button @onclick="ConfirmarEliminarCategoria" disabled="@eliminandoCategoria"
                        style="flex: 1; padding: 0.65rem 1.25rem; border-radius: 0.5rem; border: none; background: #ef4444; color: white; font-weight: 600; cursor: pointer; font-size: 0.95rem; opacity: @(eliminandoCategoria ? "0.7" : "1");">
                    @(eliminandoCategoria ? "Eliminando..." : "Eliminar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string EventId { get; set; } = string.Empty;

    private EventDetailDto? evento;
    private string? expandedCategoryId;

    private bool mostrandoFormulario;
    private bool guardando;
    private string? errorFormulario;
    private CategoryDraft draft = new();

    private string currentUserId = string.Empty;
    private string currentUserEmail = string.Empty;

    private bool isGlobalAuditor = false;
    private bool isOrganizer = false;
    private bool isParticipant = false;
    private bool isPublic = false;
    private bool isAuditor = false;
    private bool eventoNoIniciado = false;
    private bool eventoFinalizado = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        currentUserEmail = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value?.ToLower() ?? string.Empty;
        isGlobalAuditor = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Auditor";
        await CargarEvento();
    }

    private async Task CargarEvento()
    {
        var http = HttpClientFactory.CreateClient("API");
        evento = await http.GetFromJsonAsync<EventDetailDto>($"/api/events/{EventId}");

        if (evento != null && !string.IsNullOrEmpty(currentUserId))
        {
            isOrganizer = evento.Organizer == currentUserId;
            isParticipant = evento.ParticipantsIds.Contains(currentUserId);
            isPublic = evento.PublicIds.Contains(currentUserId);
            isAuditor = evento.AuditorId == currentUserId;
            eventoNoIniciado = DateTime.UtcNow < evento.StartDate;
            eventoFinalizado = DateTime.UtcNow > evento.EndDate;
        }
    }

    private void ToggleExpand(string catId) => expandedCategoryId = expandedCategoryId == catId ? null : catId;
    private void Volver() => Navigation.NavigateTo("/MainEvent");
    private void MostrarFormulario() { draft = new CategoryDraft(); errorFormulario = null; mostrandoFormulario = true; }
    private void CancelarFormulario() { mostrandoFormulario = false; errorFormulario = null; }

    private void AddSession(string voterType) => AddSessionToDraft(draft, voterType);

    private void AddSessionToDraft(CategoryDraft d, string voterType)
    {
        var defaultEval = voterType == "Jury" ? "WeightedScale" : "TopN";
        d.Sessions.Add(new SessionDraft
        {
            VoterType = voterType,
            EvaluationType = defaultEval,
            TopN = defaultEval == "TopN" ? 3 : null,
        });
    }

    private void SelectModel(SessionDraft ses, string model) => SelectModelOnDraft(ses, model);

    private void SelectModelOnDraft(SessionDraft ses, string model)
    {
        ses.EvaluationType = model;
        if (model != "WeightedScale") { ses.CriterionType = null; ses.AllowCommentsPerCriterion = false; }
        else if (string.IsNullOrEmpty(ses.CriterionType)) ses.CriterionType = "Numeric";
    }

    private void AddPrize(SessionDraft ses) => AddPrizeToDraft(ses);
    private void AddPrizeToDraft(SessionDraft ses) => ses.Prizes.Add(new PrizeDraft { Position = ses.Prizes.Count + 1 });

    private async Task AddJuror(SessionDraft ses)
    {
        ses.JurorError = null;
        var correo = ses.InputCorreoJurado?.Trim().ToLower();
        if (string.IsNullOrWhiteSpace(correo)) return;
        if (ses.JurorEmails.Contains(correo)) { ses.InputCorreoJurado = string.Empty; return; }

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var existe = await http.GetFromJsonAsync<bool>($"api/auth/check-email?email={correo}");
            if (existe) { ses.JurorEmails.Add(correo); ses.InputCorreoJurado = string.Empty; }
            else ses.JurorError = $"La cuenta '{correo}' no está registrada en Votify.";
        }
        catch { ses.JurorError = "Error al verificar el correo con el servidor."; }
    }

    private string? ValidarDraft(CategoryDraft d)
    {
        if (string.IsNullOrWhiteSpace(d.Name)) return "El nombre de la categoría es obligatorio.";
        if (d.Sessions.Count == 0) return "Debe haber al menos una votación.";

        foreach (var ses in d.Sessions)
        {
            string tipoVotante = ses.VoterType == "Jury" ? "Jurado" : "Público";

            if (ses.OpenAt.HasValue && ses.CloseAt.HasValue && ses.CloseAt <= ses.OpenAt)
                return $"La votación de {tipoVotante}: la fecha de cierre debe ser posterior a la de apertura.";
            if (ses.OpenAt.HasValue && ses.OpenAt < DateTime.UtcNow)
                return $"La votación de {tipoVotante}: la fecha de apertura no puede ser anterior a la actual.";
            if (ses.CloseAt.HasValue && evento != null && ses.CloseAt > evento.EndDate.ToUniversalTime())
                return $"La votación de {tipoVotante}: la fecha de cierre no puede superar el fin del evento ({evento.EndDate:dd/MM/yyyy}).";
            if (ses.VoterType == "Jury" && !ses.JurorEmails.Any())
                return "La votación de Jurado requiere al menos un correo de jurado asignado.";
            if (ses.EvaluationType == "WeightedScale" && !ses.Criteria.Any())
                return $"La votación de {tipoVotante} requiere al menos un criterio porque usa Baremo Ponderado.";

            if (ses.Criteria.Any())
            {
                double sumaPesos = 0;
                foreach (var cr in ses.Criteria)
                {
                    if (string.IsNullOrWhiteSpace(cr.Name)) return $"Todos los criterios en la votación de {tipoVotante} deben tener un nombre.";
                    if (cr.Weight <= 0) return $"El peso del criterio '{cr.Name}' debe ser mayor que 0.";
                    sumaPesos += cr.Weight;
                }
                if (Math.Abs(sumaPesos - 1.0) > 0.001)
                    return $"La suma de los pesos de los criterios en la votación de {tipoVotante} debe ser exactamente 1 (actualmente suma {sumaPesos.ToString("0.##")}).";
            }

            if (!ses.AllowComments) ses.RequireComments = false;
            if (ses.EvaluationType != "WeightedScale") ses.AllowCommentsPerCriterion = false;

            if (ses.EvaluationType == "PointDistribution")
            {
                if (ses.PointsPerVoter == null || ses.PointsPerVoter <= 0) return $"La votación de {tipoVotante}: el total de puntos debe ser mayor que 0.";
                if (ses.MaxPointsPerProject == null || ses.MaxPointsPerProject <= 0) return $"La votación de {tipoVotante}: el máximo por proyecto debe ser mayor que 0.";
                if (ses.MaxPointsPerProject > ses.PointsPerVoter) return $"La votación de {tipoVotante}: el máximo por proyecto ({ses.MaxPointsPerProject}) no puede superar el total de puntos ({ses.PointsPerVoter}).";
            }
        }
        return null;
    }

    private object BuildSessionsPayload(CategoryDraft d) => d.Sessions.Select(s => new
    {
        s.VoterType,
        s.EvaluationType,
        s.CriterionType,
        s.TopN,
        s.PointsPerVoter,
        s.MaxPointsPerProject,
        s.AllowComments,
        s.RequireComments,
        s.AllowCommentsPerCriterion,
        OpenAt = s.OpenAt,
        CloseAt = s.CloseAt,
        JurorEmails = s.VoterType == "Jury" ? s.JurorEmails : new List<string>(),
        Criteria = s.Criteria.Select(c => new { c.Name, c.Weight }),
        Prizes = s.Prizes.Select(p => new { p.Position, p.Name, p.Description })
    });

    private async Task GuardarCategoria()
    {
        errorFormulario = ValidarDraft(draft);
        if (errorFormulario != null) return;

        try
        {
            guardando = true;
            var payload = new
            {
                EventId = EventId,
                draft.Name,
                draft.Description,
                draft.AllowSelfVoting,
                draft.CombineResults,
                JuryWeight = draft.CombineResults ? draft.JuryWeight : null,
                PublicWeight = draft.CombineResults ? draft.PublicWeight : null,
                VotingSessions = BuildSessionsPayload(draft)
            };

            var http = HttpClientFactory.CreateClient("API");
            var resp = await http.PostAsJsonAsync("/api/categories", payload);

            if (resp.IsSuccessStatusCode) { mostrandoFormulario = false; await CargarEvento(); }
            else errorFormulario = (await resp.Content.ReadAsStringAsync()).Trim('"');
        }
        catch (Exception ex) { errorFormulario = $"Error: {ex.Message}"; }
        finally { guardando = false; }
    }

    private RenderFragment RenderCategoryForm(CategoryDraft d) => __builder =>
