        </div>

        @foreach (var ses in d.Sessions)
        {
            <div class="session-card">
                <div class="session-card-header">
                    <h5 class="session-title">
                        Votación
                        <span class="voter-tag @(ses.VoterType == "Public" ? "public" : "")">
                            @(ses.VoterType == "Jury" ? "Jurado" : "Público")
                        </span>
                    </h5>
                    <button type="button" class="btn-remove" @onclick="() => d.Sessions.Remove(ses)">✕</button>
                </div>

                <div class="form-group">
                    <label>Modelo de votación</label>
                    <div class="model-grid">
                        @if (ses.VoterType == "Jury")
                        {
                            <div class="model-card @(ses.EvaluationType == "WeightedScale" ? "selected" : "")"
                                 @onclick='() => SelectModelOnDraft(ses, "WeightedScale")'>
                                <div class="model-radio"></div>
                                <p class="model-title">Baremo ponderado</p>
                            </div>
                        }
                        <div class="model-card @(ses.EvaluationType == "PointDistribution" ? "selected" : "")"
                             @onclick='() => SelectModelOnDraft(ses, "PointDistribution")'>
                            <div class="model-radio"></div>
                            <p class="model-title">Reparto de puntos</p>
                        </div>
                        <div class="model-card @(ses.EvaluationType == "TopN" ? "selected" : "")"
                             @onclick='() => SelectModelOnDraft(ses, "TopN")'>
                            <div class="model-radio"></div>
                            <p class="model-title">Selección Top-N</p>
                        </div>
                    </div>

                    @if (ses.EvaluationType == "TopN")
                    {
                        <div class="model-config">
                            <label class="field-label">Top N proyectos a elegir</label>
                            <input type="number" min="1" class="form-control form-control-sm" @bind="ses.TopN" style="max-width: 100px;" />
                            <small style="font-size: 0.8rem; color: #6b7280; margin-top: 0.25rem; display: block;">Número de proyectos que cada votante selecciona. Mínimo 1.</small>
                        </div>
                    }
                    else if (ses.EvaluationType == "PointDistribution")
                    {
                        <div class="model-config" style="display:flex; gap:1rem;">
                            <div>
                                <label class="field-label">Total puntos</label>
                                <input type="number" min="1" class="form-control form-control-sm" @bind="ses.PointsPerVoter" style="max-width: 100px;" />
                                <small style="font-size: 0.8rem; color: #6b7280; margin-top: 0.25rem; display: block;">Puntos totales que cada votante reparte entre los proyectos.</small>
                            </div>
                            <div>
                                <label class="field-label">Máx. por proyecto</label>
                                <input type="number" min="1" class="form-control form-control-sm" @bind="ses.MaxPointsPerProject" style="max-width: 100px;" />
                                @if (ses.MaxPointsPerProject > ses.PointsPerVoter && ses.PointsPerVoter > 0)
                                {
                                    <span style="color: #ef4444; font-size: 0.78rem; display:block; margin-top:0.2rem;">No puede superar el total (@ses.PointsPerVoter pts)</span>
                                }
                                <small style="font-size: 0.8rem; color: #6b7280; margin-top: 0.25rem; display: block;">No puede superar el total de puntos.</small>
                            </div>
                        </div>
                    }

                    @if (ses.EvaluationType == "WeightedScale")
                    {
                        <div class="model-config" style="margin-top: 0.75rem;">
                            <label class="field-label">Tipo de criterio</label>
                            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                <div class="model-card @(ses.CriterionType == "Numeric" ? "selected" : "")"
                                     style="flex: 1; min-width: 140px; min-height: auto; padding: 0.65rem 0.85rem;"
                                     @onclick='() => ses.CriterionType = "Numeric"'>
                                    <p class="model-title" style="font-size: 0.85rem; margin: 0;"># Numérico</p>
                                    <p class="model-desc" style="font-size: 0.75rem; margin: 0.15rem 0 0;">Puntuación 0–10 por criterio</p>
                                </div>
                                <div class="model-card @(ses.CriterionType == "Checklist" ? "selected" : "")"
                                     style="flex: 1; min-width: 140px; min-height: auto; padding: 0.65rem 0.85rem;"
                                     @onclick='() => ses.CriterionType = "Checklist"'>
                                    <p class="model-title" style="font-size: 0.85rem; margin: 0;">✓ Checklist</p>
                                    <p class="model-desc" style="font-size: 0.75rem; margin: 0.15rem 0 0;">Cumple / no cumple</p>
                                </div>
                                <div class="model-card @(ses.CriterionType == "Rubric" ? "selected" : "")"
                                     style="flex: 1; min-width: 140px; min-height: auto; padding: 0.65rem 0.85rem;"
                                     @onclick='() => ses.CriterionType = "Rubric"'>
                                    <p class="model-title" style="font-size: 0.85rem; margin: 0;">▤ Rúbrica</p>
                                    <p class="model-desc" style="font-size: 0.75rem; margin: 0.15rem 0 0;">Niveles D / C / B / A / S</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (ses.EvaluationType == "WeightedScale")
                {
                    <div class="form-group" style="margin-top: 1.5rem; border-top: 1px dashed #cbd5e1; padding-top: 1rem;">
                        <label>Criterios de evaluación</label>
                        <small style="font-size: 0.8rem; color: #6b7280; margin-top: 0.25rem; display: block;">Peso: decimal entre 0 y 1. La suma de todos debe ser exactamente 1.</small>
                        @foreach (var cr in ses.Criteria)
                        {
                            <div class="item-row">
                                <div class="item-row-main">
                                    <input type="text" class="form-control form-control-sm" placeholder="Nombre" @bind="cr.Name" />
                                    <input type="number" step="0.05" min="0.05" max="1" class="form-control form-control-sm" placeholder="Peso" @bind="cr.Weight" />
                                    <button type="button" class="btn-remove" @onclick="() => ses.Criteria.Remove(cr)">✕</button>
                                </div>
                            </div>
                        }
                        <button type="button" class="btn-ghost" @onclick="() => ses.Criteria.Add(new CriterionDraft())">+ Añadir criterio</button>
                    </div>
                }

                <div class="form-group" style="background-color: #f8fafc; padding: 1rem; border-radius: 0.5rem; border: 1px solid #e2e8f0;">
                    <label style="margin-bottom: 0.5rem;">Comentarios</label>
                    <label class="checkbox-row">
                        <input type="checkbox" @bind="ses.AllowComments" />
                        Permitir comentario por proyecto
                    </label>
                    @if (ses.AllowComments)
                    {
                        <label class="checkbox-row" style="margin-left: 1.5rem; margin-top: 0.4rem;">
                            <input type="checkbox" @bind="ses.RequireComments" />
                            Hacerlo obligatorio
                        </label>
                    }
                    @if (ses.EvaluationType == "WeightedScale")
                    {
                        <label class="checkbox-row" style="margin-top: 0.4rem;">
                            <input type="checkbox" @bind="ses.AllowCommentsPerCriterion" />
                            Permitir comentario por criterio
                        </label>
                    }
                </div>

                <div class="form-group" style="margin-top: 1.5rem; border-top: 1px dashed #cbd5e1; padding-top: 1rem;">
                    <label>Premios de esta votación</label>
                    @foreach (var pr in ses.Prizes)
                    {
                        <div class="item-row">
                            <div class="item-row-main prize" style="grid-template-columns: 4.5rem 2fr auto;">
                                <input type="number" min="1" class="form-control form-control-sm" placeholder="Pos." @bind="pr.Position" />
                                <input type="text" class="form-control form-control-sm" placeholder="Recompensa" @bind="pr.Name" />
                                <button type="button" class="btn-remove" @onclick="() => ses.Prizes.Remove(pr)">✕</button>
                            </div>
                            <div class="item-row-desc">
                                <input type="text" style="width: 100%; border: none; font-size: 0.8rem;" placeholder="Descripción opcional..." @bind="pr.Description" />
                            </div>
                        </div>
                    }
                    <button type="button" class="btn-ghost" @onclick="() => AddPrizeToDraft(ses)">+ Añadir premio</button>
                </div>

                @if (ses.VoterType == "Jury")
                {
                    <div class="form-group" style="margin-top: 1.5rem; border-top: 1px dashed #cbd5e1; padding-top: 1rem;">
