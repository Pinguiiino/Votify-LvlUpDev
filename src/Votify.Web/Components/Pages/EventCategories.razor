                </label>
                @if (d.CombineResults)
                {
                    <div class="combine-weights">
                        <div><label>Peso jurado</label><input type="number" step="0.05" @bind="d.JuryWeight" class="form-control" /></div>
                        <div><label>Peso público</label><input type="number" step="0.05" @bind="d.PublicWeight" class="form-control" /></div>
                    </div>
                    <small style="font-size: 0.8rem; color: #6b7280; margin-top: 0.25rem; display: block;">Decimales. Ej: 0.6 y 0.4.</small>
                }
            </div>
        }
    };

    private static string FormatEval(VotingSessionDto vs) => vs.EvaluationType switch
    {
        "WeightedScale" => "Baremo ponderado",
        "PointDistribution" => $"Reparto {vs.PointsPerVoter}pts (máx {vs.MaxPointsPerProject}/proy)",
        "TopN" => $"Top {vs.TopN}",
        _ => vs.EvaluationType
    };

    private static string GetVsStatusKey(VotingSessionDto vs)
    {
        if (vs.ManualStatus == "closed") return "closed";
        if (vs.ManualStatus == "paused") return "paused";
        if (vs.ManualStatus == "open") return "open";
        if (!vs.OpenAt.HasValue || !vs.CloseAt.HasValue) return "unconfigured";
        var now = DateTime.UtcNow;
        if (now > vs.CloseAt.Value) return "closed";
        if (now >= vs.OpenAt.Value) return "open";
        return "scheduled";
    }

    private CategoryDetailDto? categoriaAEliminar;
    private bool eliminandoCategoria;

    private void AbrirModalEliminarCategoria(CategoryDetailDto cat) { categoriaAEliminar = cat; eliminandoCategoria = false; }
    private void CerrarModalEliminarCategoria() { categoriaAEliminar = null; eliminandoCategoria = false; }

    private async Task ConfirmarEliminarCategoria()
    {
        if (categoriaAEliminar == null) return;
        eliminandoCategoria = true;

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var session = await CustomAuthProvider.GetUserSessionAsync();
            if (!string.IsNullOrEmpty(session?.Token))
                http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", session.Token);

            var response = await http.DeleteAsync($"api/categories/{categoriaAEliminar.Id}");

            if (response.IsSuccessStatusCode)
            {
                evento?.Categories.RemoveAll(c => c.Id == categoriaAEliminar!.Id);
                if (expandedCategoryId == categoriaAEliminar.Id) expandedCategoryId = null;
                categoriaAEliminar = null;
                StateHasChanged();
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                await JSRuntime.InvokeVoidAsync("alert", $"Error al eliminar: {msg}");
            }
        }
        catch { await JSRuntime.InvokeVoidAsync("alert", "Error de conexión al eliminar la categoría."); }
        finally { eliminandoCategoria = false; }
    }

