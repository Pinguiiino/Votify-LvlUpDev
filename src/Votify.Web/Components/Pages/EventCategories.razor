@page "/event/{EventId}/categories"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Categorías del Evento - Votify</PageTitle>

<div class="categories-page-container">

    @if (evento == null)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Cargando categorías...</p>
        </div>
    }
    else
    {
        <header class="page-header">
            <button class="back-btn" @onclick="Volver">← Volver</button>

            <div class="header-content">
                <div class="event-badge">@evento.Modality</div>
                <h1 class="page-title">@evento.Name</h1>
                @if (!string.IsNullOrWhiteSpace(evento.Description))
                {
                    <p class="page-subtitle">@evento.Description</p>
                }
                <div class="event-meta">
                    <span class="meta-item">@evento.StartDate.ToString("dd MMM yyyy") — @evento.EndDate.ToString("dd MMM yyyy")</span>
                    <span class="meta-item">Máx. @evento.MaxProjects proyectos</span>
                </div>
            </div>
        </header>

        <div class="section-header">
            <h2 class="section-title">
                Categorías
                @if (evento.Categories.Any())
                {
                    <span class="count-badge">@evento.Categories.Count</span>
                }
            </h2>

            <div style="display: flex; gap: 0.75rem; align-items: center;">
                @if (evento.Categories.Any())
                {
                    <a href="@($"/dashboard/{EventId}")" class="btn-secondary" style="text-decoration:none;">Ver resultados</a>
                    
                    @if (isParticipant || isPublic)
                    {
                        <a href="@($"/event/{EventId}/create-project")" class="btn-dark">+ Subir proyecto</a>
                    }
                    
                    @if (isGlobalAuditor)
                    {
                        <a href="@($"/event/{EventId}/audit")" class="btn-dark">Auditar</a>
                    }
                }

                @if (isOrganizer && !mostrandoFormulario)
                {
                    <button class="btn-dark" @onclick="MostrarFormulario">+ Crear categoría</button>
                }
            </div>
        </div>

        @if (!evento.Categories.Any() && !mostrandoFormulario)
        {
            <div class="empty-state">
                <p>Este evento todavía no tiene categorías. Crea la primera para empezar.</p>
            </div>
        }

        @if (mostrandoFormulario && isOrganizer)
        {
            <div class="create-cat-panel">
                <h3 class="panel-title">Nueva categoría</h3>
                <p class="panel-subtitle">Configura el nombre, las votaciones y los premios.</p>

                <div class="form-group">
                    <label>Nombre *</label>
                    <input type="text" class="form-control" @bind="draft.Name" placeholder="Ej: Proyectos de IA" />
                </div>

                <div class="form-group">
                    <label>Descripción</label>
                    <textarea class="form-control" rows="2" @bind="draft.Description"
                              placeholder="Descripción opcional..."></textarea>
                </div>

                <div class="form-group">
                    <label class="checkbox-row">
                        <input type="checkbox" @bind="draft.AllowSelfVoting" />
                        Permitir que los participantes voten su propio proyecto
                    </label>
                </div>

                <hr class="panel-divider" />

                <h4 class="section-label">Votaciones</h4>
                <p class="section-hint">Añade al menos una (jurado o público).</p>

                <div class="session-add-buttons">
                    <button type="button" class="btn-secondary"
                            disabled="@(draft.Sessions.Any(s => s.VoterType == "Jury"))"
                            @onclick='() => AddSession("Jury")'>
                        + Votación del jurado
                    </button>
                    <button type="button" class="btn-secondary"
                            disabled="@(draft.Sessions.Any(s => s.VoterType == "Public"))"
                            @onclick='() => AddSession("Public")'>
                        + Votación del público
                    </button>
                </div>

                @foreach (var ses in draft.Sessions)
                {
                    <div class="session-card">
                        <div class="session-card-header">
                            <h5 class="session-title">
                                Votación
                                <span class="voter-tag @(ses.VoterType == "Public" ? "public" : "")">
                                    @(ses.VoterType == "Jury" ? "Jurado" : "Público")
                                </span>
                            </h5>
                            <button type="button" class="btn-remove" @onclick="() => draft.Sessions.Remove(ses)">✕</button>
                        </div>

                        <div class="form-group">
                            <label>Modelo de votación</label>
                            <div class="model-grid">
                                @if (ses.VoterType == "Jury")
                                {
                                    <div class="model-card @(ses.EvaluationType == "WeightedScale" ? "selected" : "")"
                                         @onclick='() => SelectModel(ses, "WeightedScale", false)'>
                                        <div class="model-radio"></div>
                                        <p class="model-title">Baremo ponderado</p>
                                    </div>
                                }

                                <div class="model-card @(ses.EvaluationType == "PointDistribution" ? "selected" : "")"
                                     @onclick='() => SelectModel(ses, "PointDistribution", false)'>
                                    <div class="model-radio"></div>
                                    <p class="model-title">Reparto de puntos</p>
                                </div>

                                <div class="model-card @(ses.EvaluationType == "TopN" ? "selected" : "")"
                                     @onclick='() => SelectModel(ses, "TopN", false)'>
                                    <div class="model-radio"></div>
                                    <p class="model-title">Selección Top-N</p>
                                </div>
                            </div>

                            @if (ses.EvaluationType == "TopN")
                            {
                                <div class="model-config">
                                    <label class="field-label">Top N proyectos a elegir</label>
                                    <input type="number" min="1" class="form-control form-control-sm" @bind="ses.TopN" style="max-width: 100px;" />
                                </div>
                            }
                            else if (ses.EvaluationType == "PointDistribution")
                            {
                                <div class="model-config" style="display:flex; gap:1rem;">
                                    <div>
                                        <label class="field-label">Total puntos</label>
                                        <input type="number" min="1" class="form-control form-control-sm" @bind="ses.PointsPerVoter" style="max-width: 100px;" />
                                    </div>
                                    <div>
                                        <label class="field-label">Máx. por proyecto</label>
                                        <input type="number" min="1" class="form-control form-control-sm" @bind="ses.MaxPointsPerProject" style="max-width: 100px;" />
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- === NUEVA SECCIÓN DE JURADOS === -->
                        @if (ses.VoterType == "Jury")
                        {
                            <div class="form-group" style="background-color: #f8fafc; padding: 1rem; border-radius: 0.5rem; border: 1px solid #e2e8f0;">
                                <label style="display: flex; justify-content: space-between;">
                                    Jurados Asignados
                                    <span style="font-weight: normal; color: #64748b; font-size: 0.8rem;">(Introduce sus correos)</span>
                                </label>
                                
                                <div style="display: flex; gap: 0.5rem; margin-bottom: 0.75rem;">
                                    <input type="email" class="form-control form-control-sm" placeholder="correo@ejemplo.com" @bind="nuevoCorreoJurado" />
                                    <button type="button" class="btn-dark" style="padding: 0.35rem 1rem;" @onclick="() => AddJuror(ses)">Añadir</button>
                                </div>

                                @if (ses.JurorEmails.Any())
                                {
                                    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                                        @foreach (var email in ses.JurorEmails)
                                        {
                                            <span style="background: white; border: 1px solid #cbd5e1; padding: 0.2rem 0.6rem; border-radius: 99px; font-size: 0.8rem; display: flex; align-items: center; gap: 0.4rem;">
                                                @email
                                                <button type="button" style="background: none; border: none; color: #ef4444; cursor: pointer; font-weight: bold; padding: 0;" @onclick="() => ses.JurorEmails.Remove(email)">×</button>
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                        }

                        <!-- === SECCIÓN CRITERIOS === -->
                        <div class="form-group">
                            <label>Criterios</label>
                            @foreach (var cr in ses.Criteria)
                            {
                                <div class="item-row">
                                    <div class="item-row-main" style="grid-template-columns: 2fr 1fr auto;">
                                        <input type="text" class="form-control form-control-sm" placeholder="Nombre" @bind="cr.Name" />
                                        <input type="number" step="0.05" min="0" max="1" class="form-control form-control-sm" placeholder="Peso" @bind="cr.Weight" />
                                        <button type="button" class="btn-remove" @onclick="() => ses.Criteria.Remove(cr)">✕</button>
                                    </div>
                                </div>
                            }
                            <button type="button" class="btn-ghost" @onclick="() => ses.Criteria.Add(new CriterionDraft())">+ Añadir criterio</button>
                        </div>

                        <!-- === NUEVA SECCIÓN PREMIOS (MovidA AQUÍ) === -->
                        <div class="form-group" style="margin-top: 1.5rem; border-top: 1px dashed #cbd5e1; padding-top: 1rem;">
                            <label>Premios de esta votación</label>
                            @foreach (var pr in ses.Prizes)
                            {
                                <div class="item-row">
                                    <div class="item-row-main prize" style="grid-template-columns: 4.5rem 2fr auto;">
                                        <input type="number" min="1" class="form-control form-control-sm" placeholder="Pos." @bind="pr.Position" />
                                        <input type="text" class="form-control form-control-sm" placeholder="Nombre del premio" @bind="pr.Name" />
                                        <button type="button" class="btn-remove" @onclick="() => ses.Prizes.Remove(pr)">✕</button>
                                    </div>
                                    <div class="item-row-desc">
                                        <input type="text" style="width: 100%; border: none; font-size: 0.8rem;" placeholder="Descripción opcional..." @bind="pr.Description" />
                                    </div>
                                </div>
                            }
                            <button type="button" class="btn-ghost" @onclick="() => AddPrize(ses)">+ Añadir premio</button>
                        </div>

                    </div>
                }

                @if (draft.Sessions.Count == 2)
                {
                    <div class="combine-block">
                        <label class="checkbox-row">
                            <input type="checkbox" @bind="draft.CombineResults" />
                            Combinar resultados de jurado y público en un único ranking
                        </label>
                        @if (draft.CombineResults)
                        {
                            <div class="combine-weights">
                                <div><label>Peso jurado</label><input type="number" step="0.05" @bind="draft.JuryWeight" class="form-control" /></div>
                                <div><label>Peso público</label><input type="number" step="0.05" @bind="draft.PublicWeight" class="form-control" /></div>
                            </div>
                        }
                    </div>
                }

                @if (errorFormulario != null)
                {
                    <div class="error-banner">@errorFormulario</div>
                }

                <div class="panel-actions">
                    <button type="button" class="btn-secondary" @onclick="CancelarFormulario">Cancelar</button>
                    <button type="button" class="btn-primary" disabled="@guardando" @onclick="GuardarCategoria">
                        @(guardando ? "Guardando..." : "Guardar categoría")
                    </button>
                </div>
            </div>
        }

        @if (evento.Categories.Any())
        {
            <div class="categories-grid">
                @foreach (var cat in evento.Categories)
                {
                    <div class="category-card @(expandedCategoryId == cat.Id ? "expanded" : "")">
                        <div class="cat-card-header" @onclick="() => ToggleExpand(cat.Id)">
                            <div class="cat-title-row">
                                <div>
                                    <h3 class="cat-name">@cat.Name</h3>
                                    <p class="cat-description">@cat.Description</p>
                                </div>
                            </div>
                        </div>

                        @if (expandedCategoryId == cat.Id)
                        {
                            <div class="cat-card-body">
                                @foreach (var vs in cat.VotingSessions)
                                {
                                    <div class="detail-section">
                                        <h4 class="detail-title">
                                            @(vs.VoterType == "Jury" ? "Votación Jurado" : "Votación Público")
                                        </h4>
                                        
                                        @if (vs.VoterType == "Jury" && vs.JurorEmails.Any())
                                        {
                                            <div style="font-size: 0.8rem; margin-bottom: 0.5rem; color: #475569;">
                                                <strong>Jurados:</strong> @string.Join(", ", vs.JurorEmails)
                                            </div>
                                        }

                                        @if (vs.Prizes.Any())
                                        {
                                            <div class="prizes-list" style="margin-top: 1rem;">
                                                <h5 style="font-size: 0.8rem; color: #b45309;">Premios:</h5>
                                                @foreach (var pr in vs.Prizes.OrderBy(p => p.Position))
                                                {
                                                    <div class="prize-item" style="padding: 0.5rem;">
                                                        <strong>#@pr.Position</strong> @pr.Name
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string EventId { get; set; } = string.Empty;

    private EventDetailDto? evento;
    private string? expandedCategoryId;

    private bool mostrandoFormulario;
    private bool guardando;
    private string? errorFormulario;
    private CategoryDraft draft = new();
    
    // Variable temporal para el input del correo
    private string nuevoCorreoJurado = string.Empty;

    private string currentUserId = string.Empty;
    private bool isGlobalAuditor = false;
    private bool isOrganizer = false;
    private bool isParticipant = false;
    private bool isPublic = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        isGlobalAuditor = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Auditor";
        await CargarEvento();
    }

    private async Task CargarEvento()
    {
        var http = HttpClientFactory.CreateClient("API");
        evento = await http.GetFromJsonAsync<EventDetailDto>($"/api/events/{EventId}");

        if (evento != null && !string.IsNullOrEmpty(currentUserId))
        {
            isOrganizer = evento.Organizer == currentUserId;
            isParticipant = evento.ParticipantsIds.Contains(currentUserId);
            isPublic = evento.PublicIds.Contains(currentUserId);
        }
    }

    private void ToggleExpand(string catId) => expandedCategoryId = expandedCategoryId == catId ? null : catId;
    private void Volver() => Navigation.NavigateTo("/MainEvent");
    private void MostrarFormulario() { draft = new CategoryDraft(); errorFormulario = null; mostrandoFormulario = true; }
    private void CancelarFormulario() { mostrandoFormulario = false; errorFormulario = null; }

    private void AddSession(string voterType)
    {
        var defaultEval = voterType == "Jury" ? "WeightedScale" : "TopN";
        draft.Sessions.Add(new SessionDraft
        {
            VoterType = voterType,
            EvaluationType = defaultEval,
            TopN = defaultEval == "TopN" ? 3 : null,
        });
    }

    private void SelectModel(SessionDraft ses, string model, bool disabled) { if (!disabled) ses.EvaluationType = model; }

    private void AddPrize(SessionDraft ses)
    {
        ses.Prizes.Add(new PrizeDraft { Position = ses.Prizes.Count + 1 });
    }

    private void AddJuror(SessionDraft ses)
    {
        if (!string.IsNullOrWhiteSpace(nuevoCorreoJurado) && !ses.JurorEmails.Contains(nuevoCorreoJurado))
        {
            ses.JurorEmails.Add(nuevoCorreoJurado.Trim().ToLower());
            nuevoCorreoJurado = string.Empty; // Limpiamos el input
        }
    }

    private async Task GuardarCategoria()
    {
        errorFormulario = null;
        try
        {
            guardando = true;
            var payload = new
            {
                EventId = EventId,
                draft.Name,
                draft.Description,
                draft.AllowSelfVoting,
                draft.CombineResults,
                JuryWeight = draft.CombineResults ? draft.JuryWeight : null,
                PublicWeight = draft.CombineResults ? draft.PublicWeight : null,
                VotingSessions = draft.Sessions.Select(s => new
                {
                    s.VoterType,
                    s.EvaluationType,
                    s.TopN,
                    s.PointsPerVoter,
                    s.MaxPointsPerProject,
                    JurorEmails = s.VoterType == "Jury" ? s.JurorEmails : new List<string>(),
                    Criteria = s.Criteria.Select(c => new { c.Name, c.Weight }),
                    Prizes = s.Prizes.Select(p => new { p.Position, p.Name, p.Description })
                })
            };

            var http = HttpClientFactory.CreateClient("API");
            var resp = await http.PostAsJsonAsync("/api/categories", payload);

            if (resp.IsSuccessStatusCode)
            {
                mostrandoFormulario = false;
                await CargarEvento();
            }
            else
            {
                errorFormulario = (await resp.Content.ReadAsStringAsync()).Trim('"');
            }
        }
        catch (Exception ex) { errorFormulario = $"Error: {ex.Message}"; }
        finally { guardando = false; }
    }

    public class EventDetailDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Modality { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int MaxProjects { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public string Organizer { get; set; } = string.Empty;
        public List<string> ParticipantsIds { get; set; } = new();
        public List<string> PublicIds { get; set; } = new();
        public List<CategoryDetailDto> Categories { get; set; } = new();
    }

    public class CategoryDetailDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public List<VotingSessionDto> VotingSessions { get; set; } = new();
    }

    public class VotingSessionDto
    {
        public string Id { get; set; } = string.Empty;
        public string VoterType { get; set; } = string.Empty;
        public string EvaluationType { get; set; } = string.Empty;
        public List<string> JurorEmails { get; set; } = new();
        public List<PrizeDetailDto> Prizes { get; set; } = new();
    }

    public class PrizeDetailDto
    {
        public int Position { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }

    public class CategoryDraft
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool AllowSelfVoting { get; set; }
        public bool CombineResults { get; set; }
        public double? JuryWeight { get; set; }
        public double? PublicWeight { get; set; }
        public List<SessionDraft> Sessions { get; set; } = new();
    }

    public class SessionDraft
    {
        public string VoterType { get; set; } = "Jury";
        public string EvaluationType { get; set; } = "WeightedScale";
        public int? TopN { get; set; }
        public int? PointsPerVoter { get; set; }
        public int? MaxPointsPerProject { get; set; }
        public List<string> JurorEmails { get; set; } = new();
        public List<CriterionDraft> Criteria { get; set; } = new();
        public List<PrizeDraft> Prizes { get; set; } = new();
    }

    public class CriterionDraft { public string Name { get; set; } = string.Empty; public double Weight { get; set; } }
    public class PrizeDraft { public int Position { get; set; } = 1; public string Name { get; set; } = string.Empty; public string? Description { get; set; } }
}