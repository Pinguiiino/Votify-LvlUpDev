@page "/event/{EventId}/categories"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Categorías del Evento - Votify</PageTitle>

<div class="categories-page-container">

    @if (evento == null)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Cargando categorías...</p>
        </div>
    }
    else
    {
        <header class="page-header">
            <button class="back-btn" @onclick="Volver">← Volver</button>

            <div class="header-content">
                <div class="event-badge">@evento.Modality</div>
                <h1 class="page-title">@evento.Name</h1>
                @if (!string.IsNullOrWhiteSpace(evento.Description))
                {
                    <p class="page-subtitle">@evento.Description</p>
                }
                <div class="event-meta">
                    <span class="meta-item">@evento.StartDate.ToString("dd MMM yyyy") — @evento.EndDate.ToString("dd MMM yyyy")</span>
                    <span class="meta-item">Máx. @evento.MaxProjects proyectos</span>
                </div>
            </div>
        </header>

        <div class="section-header">
            <h2 class="section-title">
                Categorías
                @if (evento.Categories.Any())
                {
                    <span class="count-badge">@evento.Categories.Count</span>
                }
            </h2>

            <div style="display: flex; gap: 0.75rem; align-items: center;">
                @if (evento.Categories.Any())
                {
                    <a href="@($"/dashboard/{EventId}")" class="btn-secondary" style="text-decoration:none;">Ver resultados</a>
                    <a href="@($"/event/{EventId}/create-project")" class="btn-dark">+ Subir proyecto</a>
                    <a href="@($"/event/{EventId}/audit")" class="btn-dark">Auditar</a>
                }
                @if (!mostrandoFormulario)
                {
                    <button class="btn-dark" @onclick="MostrarFormulario">+ Crear categoría</button>
                }
            </div>
        </div>

        @if (!evento.Categories.Any() && !mostrandoFormulario)
        {
            <div class="empty-state">
                <p>Este evento todavía no tiene categorías. Crea la primera para empezar.</p>
            </div>
        }

        @if (mostrandoFormulario)
        {
            <div class="create-cat-panel">
                <h3 class="panel-title">Nueva categoría</h3>
                <p class="panel-subtitle">Configura el nombre, las votaciones y los premios.</p>

                <div class="form-group">
                    <label>Nombre *</label>
                    <input type="text" class="form-control" @bind="draft.Name" placeholder="Ej: Proyectos de IA" />
                </div>

                <div class="form-group">
                    <label>Descripción</label>
                    <textarea class="form-control" rows="2" @bind="draft.Description"
                              placeholder="Descripción opcional..."></textarea>
                </div>

                <div class="form-group">
                    <label class="checkbox-row">
                        <input type="checkbox" @bind="draft.AllowSelfVoting" />
                        Permitir que los participantes voten su propio proyecto
                    </label>
                </div>

                <hr class="panel-divider" />

                <h4 class="section-label">Votaciones</h4>
                <p class="section-hint">Añade al menos una (jurado o público).</p>

                <div class="session-add-buttons">
                    <button type="button" class="btn-secondary"
                            disabled="@(draft.Sessions.Any(s => s.VoterType == "Jury"))"
                            @onclick='() => AddSession("Jury")'>
                        + Votación del jurado
                    </button>
                    <button type="button" class="btn-secondary"
                            disabled="@(draft.Sessions.Any(s => s.VoterType == "Public"))"
                            @onclick='() => AddSession("Public")'>
                        + Votación del público
                    </button>
                </div>

                @foreach (var ses in draft.Sessions)
                {
                    <div class="session-card">
                        <div class="session-card-header">
                            <h5 class="session-title">
                                Votación
                                <span class="voter-tag @(ses.VoterType == "Public" ? "public" : "")">
                                    @(ses.VoterType == "Jury" ? "Jurado" : "Público")
                                </span>
                            </h5>
                            <button type="button" class="btn-remove" @onclick="() => draft.Sessions.Remove(ses)">✕</button>
                        </div>

                        <div class="form-group">
                            <label>Modelo de votación</label>
                            <p class="section-hint" style="margin-bottom:0.75rem;">Elige cómo votarán los jurados o el público</p>

                            <div class="model-grid">
                                @if (ses.VoterType == "Jury")
                                {
                                <div class="model-card @(ses.EvaluationType == "WeightedScale" ? "selected" : "")"
                                     @onclick='() => SelectModel(ses, "WeightedScale", false)'>
                                    <div class="model-radio"></div>
                                    <div class="model-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M3 7h18M6 7l-2 6a2 2 0 0 0 4 0L6 7zM18 7l-2 6a2 2 0 0 0 4 0l-2-6z" />
                                        </svg>
                                    </div>
                                    <p class="model-title">Baremo ponderado</p>
                                    <p class="model-desc">Evaluación multicriterio con pesos para diferenciar la importancia de cada criterio.</p>
                                </div>
                                }

                                <div class="model-card @(ses.EvaluationType == "PointDistribution" ? "selected" : "")"
                                     @onclick='() => SelectModel(ses, "PointDistribution", false)'>
                                    <div class="model-radio"></div>
                                    <div class="model-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v9l6.5 3.75M12 3a9 9 0 1 0 9 9h-9V3z" />
                                        </svg>
                                    </div>
                                    <p class="model-title">Reparto de puntos</p>
                                    <p class="model-desc">Cada persona distribuye Y puntos entre los proyectos de la categoría.</p>
                                </div>

                                <div class="model-card @(ses.EvaluationType == "TopN" ? "selected" : "")"
                                     @onclick='() => SelectModel(ses, "TopN", false)'>
                                    <div class="model-radio"></div>
                                    <div class="model-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 20V10M12 20V4M20 20v-7" />
                                        </svg>
                                    </div>
                                    <p class="model-title">Selección Top-N</p>
                                    <p class="model-desc">Cada persona elige X proyectos en cada categoría.</p>
                                </div>
                            </div>

                            @if (ses.EvaluationType == "TopN")
                            {
                                <div class="model-config">
                                    <label class="field-label">Top N proyectos que cada votante puede elegir</label>
                                    <div class="input-with-suffix">
                                        <input type="number" min="1" max="100" class="form-control form-control-sm" @bind="ses.TopN" />
                                        <span class="suffix">proyectos</span>
                                    </div>
                                </div>
                            }

                            @if (ses.EvaluationType == "PointDistribution")
                            {
                                <div class="model-config">
                                    <div class="two-fields">
                                        <div>
                                            <label class="field-label">Presupuesto por votante (Y)</label>
                                            <div class="input-with-suffix">
                                                <input type="number" min="1" class="form-control form-control-sm" @bind="ses.PointsPerVoter" />
                                                <span class="suffix">puntos</span>
                                            </div>
                                        </div>
                                        <div>
                                            <label class="field-label">Máximo de puntos por proyecto</label>
                                            <div class="input-with-suffix">
                                                <input type="number" min="1" class="form-control form-control-sm" @bind="ses.MaxPointsPerProject" />
                                                <span class="suffix">puntos</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="form-group">
                            <label class="checkbox-row">
                                <input type="checkbox" @bind="ses.AllowComments" />
                                Permitir comentario por proyecto
                            </label>

                            @if (ses.AllowComments)
                            {
                                <div style="margin-top: 0.5rem; margin-left: 1.5rem; display:flex; flex-direction:column; gap:0.4rem;">
                                    <label class="checkbox-row">
                                        <input type="checkbox" @bind="ses.RequireComments" />
                                        Comentario por proyecto obligatorio
                                    </label>
                                    <label class="checkbox-row">
                                        <input type="checkbox" @bind="ses.AllowCommentsPerCriterion" />
                                        Permitir comentario por criterio
                                    </label>
                                </div>
                            }
                        </div>

                        <div class="form-group">
                            <label>
                                Criterios
                                @if (ses.EvaluationType == "WeightedScale")
                                {
                                    <span style="color: #dc2626;">*</span>
                                }
                                else
                                {
                                    <span style="font-weight: normal; color: #9ca3af; margin-left: 0.35rem;">(opcionales)</span>
                                }
                            </label>

                            @if (ses.Criteria.Any())
                            {
                                <div class="form-group" style="margin-bottom: 0.85rem;">
                                    <label style="font-size: 0.82rem;">Tipo de criterio</label>
                                    <select class="form-control form-control-sm" @bind="ses.CriterionType" style="max-width: 16rem;">
                                        <option value="Numeric">Numérico</option>
                                        <option value="Checklist">Checklist</option>
                                        <option value="Rubric">Rúbrica</option>
                                    </select>
                                </div>
                            }

                            @foreach (var cr in ses.Criteria)
                            {
                                <div class="item-row">
                                    <div class="item-row-main">
                                        <input type="text" class="form-control form-control-sm" placeholder="Nombre del criterio" @bind="cr.Name" />
                                        <input type="number" step="0.05" min="0" max="1" class="form-control form-control-sm"
                                               placeholder="Peso (0-1)" @bind="cr.Weight" />
                                        <button type="button" class="btn-remove" @onclick="() => ses.Criteria.Remove(cr)">✕</button>
                                    </div>
                                    <div class="item-row-desc">
                                        <span class="desc-label">Descripción</span>
                                        <input type="text" placeholder="Opcional" @bind="cr.Description" />
                                    </div>
                                </div>
                            }

                            <button type="button" class="btn-ghost" @onclick="() => ses.Criteria.Add(new CriterionDraft())">
                                + Añadir criterio
                            </button>
                        </div>
                    </div>
                }

                @if (draft.Sessions.Count == 2)
                {
                    <div class="combine-block">
                        <label class="checkbox-row">
                            <input type="checkbox" @bind="draft.CombineResults" />
                            Combinar resultados de jurado y público en un único ranking
                        </label>

                        @if (draft.CombineResults)
                        {
                            <div class="combine-weights">
                                <div>
                                    <label class="field-label">Peso del jurado (0-1)</label>
                                    <input type="number" step="0.05" min="0" max="1" class="form-control form-control-sm"
                                           @bind="draft.JuryWeight" />
                                </div>
                                <div>
                                    <label class="field-label">Peso del público (0-1)</label>
                                    <input type="number" step="0.05" min="0" max="1" class="form-control form-control-sm"
                                           @bind="draft.PublicWeight" />
                                </div>
                            </div>
                        }
                    </div>
                }

                <hr class="panel-divider" />

                <h4 class="section-label">Premios</h4>
                <p class="section-hint">
                    @if (draft.CombineResults)
                    {
                        <span>Como los resultados se combinan, los premios son únicos para la categoría.</span>
                    }
                    else
                    {
                        <span>Al menos un premio por cada votación.</span>
                    }
                </p>

                @foreach (var pr in draft.Prizes)
                {
                    <div class="item-row">
                        <div class="item-row-main prize">
                            <input type="number" min="1" class="form-control form-control-sm" placeholder="Pos." @bind="pr.Position" />
                            <input type="text" class="form-control form-control-sm" placeholder="Nombre del premio" @bind="pr.Name" />
                            @if (!draft.CombineResults && draft.Sessions.Count > 0)
                            {
                                <select class="form-control form-control-sm" @bind="pr.TargetVoter">
                                    @foreach (var s in draft.Sessions)
                                    {
                                        <option value="@s.VoterType">@(s.VoterType == "Jury" ? "Jurado" : "Público")</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <span style="font-size: 0.8rem; color: #6b7280;">Combinado</span>
                            }
                            <button type="button" class="btn-remove" @onclick="() => draft.Prizes.Remove(pr)">✕</button>
                        </div>
                        <div class="item-row-desc">
                            <span class="desc-label">Descripción</span>
                            <input type="text" placeholder="Opcional" @bind="pr.Description" />
                        </div>
                    </div>
                }

                <button type="button" class="btn-ghost" @onclick="AddPrize">+ Añadir premio</button>

                @if (errorFormulario != null)
                {
                    <div class="error-banner">@errorFormulario</div>
                }

                <div class="panel-actions">
                    <button type="button" class="btn-secondary" @onclick="CancelarFormulario">Cancelar</button>
                    <button type="button" class="btn-primary" disabled="@guardando" @onclick="GuardarCategoria">
                        @(guardando ? "Guardando..." : "Guardar categoría")
                    </button>
                </div>
            </div>
        }

        @if (evento.Categories.Any())
        {
            <div class="categories-grid">
                @foreach (var cat in evento.Categories)
                {
                    <div class="category-card @(expandedCategoryId == cat.Id ? "expanded" : "")">
                        <div class="cat-card-header" @onclick="() => ToggleExpand(cat.Id)">
                            <div class="cat-title-row">
                                <div>
                                    <h3 class="cat-name">@cat.Name</h3>
                                    @if (!string.IsNullOrWhiteSpace(cat.Description))
                                    {
                                        <p class="cat-description">@cat.Description</p>
                                    }
                                </div>
                            </div>

                            <div class="cat-summary-row">
                                <div class="cat-pills">
                                    @foreach (var vs in cat.VotingSessions)
                                    {
                                        <span class="pill pill-blue">
                                            @(vs.VoterType == "Jury" ? "Jurado" : "Público") · @FormatEval(vs)
                                        </span>
                                    }
                                    @if (cat.CombineResults)
                                    {
                                        <span class="pill pill-amber">Combinado (@((cat.JuryWeight ?? 0) * 100)% / @((cat.PublicWeight ?? 0) * 100)%)</span>
                                    }
                                    @if (cat.Prizes.Any())
                                    {
                                        <span class="pill pill-amber">@cat.Prizes.Count premio@(cat.Prizes.Count != 1 ? "s" : "")</span>
                                    }
                                    @if (cat.AllowSelfVoting)
                                    {
                                        <span class="pill pill-green">Autovoto permitido</span>
                                    }
                                </div>
                                <a href="@($"/event/{EventId}/categories/{cat.Id}/projects")" class="btn-explore"
                                   @onclick:stopPropagation="true">
                                    Explorar proyectos
                                </a>
                            </div>
                        </div>

                        @if (expandedCategoryId == cat.Id)
                        {
                            <div class="cat-card-body">
                                @foreach (var vs in cat.VotingSessions)
                                {
                                    <div class="detail-section">
                                        <h4 class="detail-title">
                                            @(vs.VoterType == "Jury" ? "Votación del jurado" : "Votación del público") — @FormatEval(vs)
                                        </h4>

                                        @if (vs.Criteria.Any())
                                        {
                                            <div class="criteria-list">
                                                @foreach (var cr in vs.Criteria.OrderByDescending(c => c.Weight))
                                                {
                                                    <div class="criterion-item">
                                                        <div class="criterion-info">
                                                            <div class="criterion-name-row">
                                                                <span class="criterion-name">@cr.Name</span>
                                                                @if (!string.IsNullOrWhiteSpace(vs.CriterionType))
                                                                {
                                                                    <span class="criterion-type-badge">@vs.CriterionType</span>
                                                                }
                                                            </div>
                                                            @if (!string.IsNullOrWhiteSpace(cr.Description))
                                                            {
                                                                <p class="criterion-desc">@cr.Description</p>
                                                            }
                                                        </div>
                                                        <div class="weight-display">
                                                            <div class="weight-bar-container">
                                                                <div class="weight-bar" style="width: @((cr.Weight * 100).ToString("0"))%"></div>
                                                            </div>
                                                            <span class="weight-label">@((cr.Weight * 100).ToString("0"))%</span>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                @if (cat.Prizes.Any())
                                {
                                    <div class="detail-section">
                                        <h4 class="detail-title">Premios</h4>
                                        <div class="prizes-list">
                                            @foreach (var pr in cat.Prizes.OrderBy(p => p.Position))
                                            {
                                                <div class="prize-item">
                                                    <div class="prize-position">
                                                        @(pr.Position == 1 ? "🥇" : pr.Position == 2 ? "🥈" : pr.Position == 3 ? "🥉" : $"#{pr.Position}")
                                                    </div>
                                                    <div class="prize-info">
                                                        <span class="prize-name">
                                                            @pr.Name
                                                            @if (!string.IsNullOrWhiteSpace(pr.TargetVoter))
                                                            {
                                                                <span style="font-size: 0.75rem; color: #6b7280; margin-left: 0.5rem;">
                                                                    (@(pr.TargetVoter == "Jury" ? "Jurado" : "Público"))
                                                                </span>
                                                            }
                                                        </span>
                                                        @if (!string.IsNullOrWhiteSpace(pr.Description))
                                                        {
                                                            <p class="prize-desc">@pr.Description</p>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string EventId { get; set; } = string.Empty;

    private EventDetailDto? evento;
    private string? expandedCategoryId;

    private bool mostrandoFormulario;
    private bool guardando;
    private string? errorFormulario;
    private CategoryDraft draft = new();

    protected override async Task OnInitializedAsync() => await CargarEvento();

    private async Task CargarEvento()
    {
        var http = HttpClientFactory.CreateClient("API");
        evento = await http.GetFromJsonAsync<EventDetailDto>($"/api/events/{EventId}");
    }

    private void ToggleExpand(string catId)
        => expandedCategoryId = expandedCategoryId == catId ? null : catId;

    private void Volver() => Navigation.NavigateTo("/");

    private void MostrarFormulario()
    {
        draft = new CategoryDraft();
        errorFormulario = null;
        mostrandoFormulario = true;
    }

    private void CancelarFormulario()
    {
        mostrandoFormulario = false;
        errorFormulario = null;
    }

    private void AddSession(string voterType)
    {
        var defaultEval = voterType == "Jury" ? "WeightedScale" : "TopN";
        draft.Sessions.Add(new SessionDraft
        {
            VoterType = voterType,
            EvaluationType = defaultEval,
            TopN = defaultEval == "TopN" ? 3 : null,
            CriterionType = "Numeric"
        });
    }

    private void SelectModel(SessionDraft ses, string model, bool disabled)
    {
        if (disabled) return;
        ses.EvaluationType = model;
        if (model == "TopN" && !ses.TopN.HasValue) ses.TopN = 3;
        if (model == "PointDistribution")
        {
            if (!ses.PointsPerVoter.HasValue) ses.PointsPerVoter = 100;
            if (!ses.MaxPointsPerProject.HasValue) ses.MaxPointsPerProject = 40;
        }
    }

    private void AddPrize()
    {
        var pr = new PrizeDraft { Position = draft.Prizes.Count + 1 };
        if (!draft.CombineResults && draft.Sessions.Count > 0)
            pr.TargetVoter = draft.Sessions[0].VoterType;
        draft.Prizes.Add(pr);
    }

    private static string FormatEval(VotingSessionDto vs) => vs.EvaluationType switch
    {
        "WeightedScale" => "Baremo ponderado",
        "PointDistribution" => $"Reparto {vs.PointsPerVoter}pts (máx {vs.MaxPointsPerProject}/proy)",
        "TopN" => $"Top {vs.TopN}",
        _ => vs.EvaluationType
    };

    private async Task GuardarCategoria()
    {
        errorFormulario = null;

        if (string.IsNullOrWhiteSpace(draft.Name))
        {
            errorFormulario = "El nombre de la categoría es obligatorio.";
            return;
        }
        if (draft.Sessions.Count == 0)
        {
            errorFormulario = "Debe haber al menos una votación.";
            return;
        }
        if (draft.Prizes.Count == 0)
        {
            errorFormulario = "Debe haber al menos un premio.";
            return;
        }

        try
        {
            guardando = true;
            var payload = new
            {
                EventId = EventId,
                draft.Name,
                draft.Description,
                draft.AllowSelfVoting,
                draft.CombineResults,
                JuryWeight = draft.CombineResults ? draft.JuryWeight : (double?)null,
                PublicWeight = draft.CombineResults ? draft.PublicWeight : (double?)null,
                VotingSessions = draft.Sessions.Select(s => new
                {
                    s.VoterType,
                    s.EvaluationType,
                    CriterionType = s.Criteria.Any() ? s.CriterionType : null,
                    s.TopN,
                    s.PointsPerVoter,
                    s.MaxPointsPerProject,
                    s.AllowComments,
                    s.RequireComments,
                    s.AllowCommentsPerCriterion,
                    Criteria = s.Criteria.Select(c => new { c.Name, c.Description, c.Weight })
                }),
                Prizes = draft.Prizes.Select(p => new
                {
                    p.Position,
                    p.Name,
                    p.Description,
                    TargetVoter = draft.CombineResults ? null : p.TargetVoter
                })
            };

            var http = HttpClientFactory.CreateClient("API");
            var resp = await http.PostAsJsonAsync("/api/categories", payload);

            if (resp.IsSuccessStatusCode)
            {
                mostrandoFormulario = false;
                await CargarEvento();
            }
            else
            {
                var msg = await resp.Content.ReadAsStringAsync();
                errorFormulario = msg.Trim('"');
            }
        }
        catch (Exception ex)
        {
            errorFormulario = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }

    public class EventDetailDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int MaxProjects { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public string Modality { get; set; } = string.Empty;
        public List<CategoryDetailDto> Categories { get; set; } = new();
    }

    public class CategoryDetailDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool AllowSelfVoting { get; set; }
        public bool CombineResults { get; set; }
        public double? JuryWeight { get; set; }
        public double? PublicWeight { get; set; }
        public List<VotingSessionDto> VotingSessions { get; set; } = new();
        public List<PrizeDetailDto> Prizes { get; set; } = new();
    }

    public class VotingSessionDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string VoterType { get; set; } = string.Empty;
        public string EvaluationType { get; set; } = string.Empty;
        public string? CriterionType { get; set; }
        public int? TopN { get; set; }
        public int? PointsPerVoter { get; set; }
