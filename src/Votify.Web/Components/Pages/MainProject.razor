@page "/event/{EventId}/categories/{CategoryId}/projects"
@rendermode InteractiveServer
@implements IDisposable
@using Votify.Web.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage

<PageTitle>Proyectos - Votify</PageTitle>

<div class="mainproject-container" style="position: relative;">
    <header class="hero-section" style="display: flex; justify-content: space-between; align-items: flex-start; text-align: left;">
        <Breadcrumb EventId="@EventId" CategoryId="@CategoryId" CurrentPageName="Proyectos" />
        <div>
            <button class="back-btn" style="align-self: flex-start; margin-bottom: 1rem;"
                    @onclick='() => Navigation.NavigateTo($"/event/{EventId}/categories")'>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
                </svg>
                Volver
            </button>

            <h1 class="main-title" style="margin-bottom: 0.5rem;">Proyectos de @(categoriaNombre ?? "la categoría")</h1>
            <p class="subtitle" style="margin: 0;">Explora los proyectos y vótalos</p>
        </div>

        @if (puedeVotar && _sesionActivaDelUsuario != null)
        {
            @if (votacionActiva && !string.IsNullOrEmpty(_voteUrl))
            {
                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; margin-top: 2.5rem;">
                    <button class="btn-dark"
                            style="padding: 0.6rem 1.2rem; font-size: 0.95rem; border-radius: 0.5rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; border: none; cursor: pointer;"
                            @onclick="IrAVotar">
                        @if (haVotado)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.267.267 0 0 1 .02-.022z" />
                            </svg>
                            <span>Editar mi Voto</span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                                <path d="M10.97 4.97a.75.75 0 0 0-1.071-1.05l-3.992 4.99a.75.75 0 0 0-1.08.02L4.324 8.384a.75.75 0 1 0-1.06 1.06l2.094 2.093 3.473-4.425a.235.235 0 0 0 .02-.022z" />
                            </svg>
                            <span>Votar Ahora</span>
                        }
                    </button>
                    @if (_sesionActivaDelUsuario.CloseAt.HasValue)
                    {
                        <span style="font-size: 0.72rem; color: #9ca3af;">
                            Cierra el @_sesionActivaDelUsuario.CloseAt.Value.ToLocalTime().ToString("dd/MM HH:mm")
                        </span>
                    }
                </div>
            }
            else if (_sesionActivaDelUsuario.OpenAt.HasValue && _sesionActivaDelUsuario.OpenAt.Value > DateTime.UtcNow
                     && _sesionActivaDelUsuario.ManualStatus != "closed" && _sesionActivaDelUsuario.ManualStatus != "open")
            {
                @* Votación programada pero no iniciada aún *@
                <div style="margin-top: 2.5rem; background: #e0e7ff; color: #3730a3; border-radius: 0.6rem; padding: 0.65rem 1rem; font-size: 0.8rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z" />
                        <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z" />
                    </svg>
                    Votación abre el @_sesionActivaDelUsuario.OpenAt.Value.ToLocalTime().ToString("dd/MM HH:mm")
                </div>
            }
            else if (!_sesionActivaDelUsuario.OpenAt.HasValue
                && _sesionActivaDelUsuario.ManualStatus != "open"
                && _sesionActivaDelUsuario.ManualStatus != "closed")
            {
                <div style="margin-top: 2.5rem; background: #f1f5f9; color: #64748b; border-radius: 0.6rem;
                    padding: 0.65rem 1rem; font-size: 0.8rem; font-weight: 600;
                    display: flex; align-items: center; gap: 0.5rem;">
                    ○ Votación pendiente de configurar
                </div>
            }
        }

    </header>

    @if (ProyectosSubidos == null)
    {
        <p><em>Cargando proyectos...</em></p>
    }
    else if (!ProyectosSubidos.Any())
    {
        <p>No hay proyectos disponibles en este momento.</p>
    }
    else
    {
        <div class="projects-grid">
            @foreach (var proyecto in ProyectosSubidos)
            {
                <div class="project-card" @onclick="() => AbrirPopup(proyecto)">
                    @if (!string.IsNullOrWhiteSpace(proyecto.ImageUrl))
                    {
                        <img src="@(apiBaseUrl + proyecto.ImageUrl)" alt="@proyecto.Title" class="card-image" />
                    }
                    else
                    {
                        <div class="icon-container">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M.54 3.87.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.826a2 2 0 0 1-1.991-1.819l-.637-7a1.99 1.99 0 0 1 .342-1.31z" />
                            </svg>
                        </div>
                    }
                    <div class="card-info">
                        <h2 class="card-title">@proyecto.Title</h2>
                        <p class="card-description">@proyecto.Description</p>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span class="card-modality" style="font-weight: bold; color: #4b5563;">@(Translations.TipoProyecto.GetValueOrDefault(proyecto.ProjectType, proyecto.ProjectType))</span>

                            @if (comentariosPorProyecto.TryGetValue(proyecto.Id, out var count) && count > 0)
                            {
                                <span class="comment-count-badge">@count</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (proyectoSeleccionado != null)
{
    <div class="modal-overlay" @onclick="CerrarPopup" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(17, 24, 39, 0.7); display: flex; align-items: center; justify-content: center; z-index: 10000; backdrop-filter: blur(4px);">
        
        <div class="modal-content" @onclick:stopPropagation="true" style="background: white; width: 90%; max-width: 650px; border-radius: 1rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); padding: 2rem; position: relative; max-height: 85vh; overflow-y: auto;">
            
            <button class="close-btn" @onclick="CerrarPopup" style="position: absolute; top: 1.5rem; right: 1.5rem; width: 2rem; height: 2rem; border-radius: 50%; border: none; background: #f3f4f6; color: #4b5563; font-weight: bold; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s;">✕</button>

            <h2 class="modal-title" style="font-size: 1.5rem; font-weight: 800; color: #111827; margin-top: 0; margin-bottom: 1.5rem; padding-right: 2rem;">@proyectoSeleccionado.Title</h2>

            <div class="tabs" style="display: flex; gap: 1.5rem; border-bottom: 1px solid #e5e7eb; margin-bottom: 1.5rem;">
                <button class="@(tabActiva == "info" ? "active" : "")" style="background: none; border: none; padding: 0.5rem 0; font-size: 0.95rem; font-weight: 600; cursor: pointer; color: @(tabActiva == "info" ? "#111827" : "#6b7280"); border-bottom: @(tabActiva == "info" ? "2px solid #111827" : "2px solid transparent"); transition: all 0.2s;" @onclick='() => tabActiva = "info"'>Información</button>
                <button class="@(tabActiva == "comentarios" ? "active" : "")" style="background: none; border: none; padding: 0.5rem 0; font-size: 0.95rem; font-weight: 600; cursor: pointer; color: @(tabActiva == "comentarios" ? "#111827" : "#6b7280"); border-bottom: @(tabActiva == "comentarios" ? "2px solid #111827" : "2px solid transparent"); transition: all 0.2s;" @onclick='() => tabActiva = "comentarios"'>Comentarios (@comentariosProyecto.Count)</button>
            </div>

            <div class="tab-content">
                @if (tabActiva == "info")
                {
                    <p style="color: #4b5563; line-height: 1.6; margin: 0;">@proyectoSeleccionado.Description</p>
                    @if (!string.IsNullOrWhiteSpace(proyectoSeleccionado.ImageUrl))
                    {
                        <img src="@(apiBaseUrl + proyectoSeleccionado.ImageUrl)" alt="@proyectoSeleccionado.Title"
                             style="width: 100%; border-radius: 0.75rem; margin-top: 1.5rem; border: 1px solid #e5e7eb; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);" />
                    }
                }
                else if (tabActiva == "comentarios")
                {
                    @if (cargandoComentarios)
                    {
                        <div style="display: flex; justify-content: center; padding: 2rem 0; color: #6b7280;">
                            <p><em>Cargando comentarios...</em></p>
                        </div>
                    }
                    else if (!comentariosProyecto.Any())
                    {
                        <div style="text-align: center; padding: 3rem 0; color: #9ca3af; background: #f9fafb; border-radius: 0.5rem; border: 1px dashed #d1d5db;">
                            <p style="margin: 0;">No hay comentarios para este proyecto.</p>
                        </div>
                    }
                    else
                    {
                        <div class="comments-list" style="display: flex; flex-direction: column; gap: 1rem;">
                            @foreach (var c in comentariosProyecto)
                            {
                                <div class="comment-item" style="background: #f9fafb; padding: 1.25rem; border-radius: 0.75rem; border: 1px solid #e5e7eb;">
                                    <div class="comment-header" style="display: flex; align-items: center; gap: 0.85rem; margin-bottom: 0.75rem;">
                                        <div class="comment-avatar" style="width: 36px; height: 36px; background: #e0e7ff; color: #4338ca; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.1rem;">@c.VoteType[0]</div>
                                        <div class="comment-meta" style="display: flex; flex-direction: column; gap: 0.1rem;">
                                            <span class="comment-author" style="font-weight: 700; font-size: 0.95rem; color: #111827; display: flex; align-items: center; gap: 0.5rem;">
                                                Votante
                                                <span class="vote-type-pill" style="font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; background: @(c.VoteType == "Expert" ? "#fef3c7" : "#dbeafe"); color: @(c.VoteType == "Expert" ? "#b45309" : "#1e40af"); padding: 0.15rem 0.5rem; border-radius: 9999px;">@(c.VoteType == "Expert" ? "Jurado" : "Público")</span>
                                            </span>
                                            <span class="comment-position" style="font-size: 0.8rem; color: #6b7280;">
                                                @if (c.EvaluationType == "PointDistribution")
                                                {
                                                    <span>Le asignó <strong style="color: #374151;">@c.TopPosition pts</strong></span>
                                                }
                                                else if (c.TopPosition > 0)
                                                {
                                                    <span>Lo situó en el <strong style="color: #374151;">@c.TopPosition&#186; puesto</strong></span>
                                                }
                                            </span>
                                        </div>
                                    </div>
                                    <p class="comment-text" style="margin: 0; font-size: 0.95rem; color: #4b5563; line-height: 1.5;">@c.Comment</p>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string EventId { get; set; } = string.Empty;
    [Parameter] public string CategoryId { get; set; } = string.Empty;
    private string _voteUrl = "";
    private string _sesionWeightedId = "";
    private string _voterTypeForUser = string.Empty;
    private VotingSessionDto? _sesionActivaDelUsuario;

    private List<ProjectDto>? ProyectosSubidos;
    private ProjectDto? proyectoSeleccionado;
    private string categoriaNombre = "la categoría";

    private bool votacionActiva = false;
    private bool puedeVotar = false;
    private bool haVotado = false;
    private int maxVotosPermitidos = 1;
    private string _sessionUserId = string.Empty;
    private string apiBaseUrl = string.Empty;

    private string tabActiva = "info";
    private bool cargandoComentarios = false;
    private List<CommentDto> comentariosProyecto = new();
    private Dictionary<string, int> comentariosPorProyecto = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _sessionUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        var userEmail = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? string.Empty;

        var http = HttpClientFactory.CreateClient("API");
        apiBaseUrl = http.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;

        try
        {
            var cats = await http.GetFromJsonAsync<List<CategorySimpleDto>>($"api/categories/by-event/{EventId}");
            var categoriaSimple = cats?.FirstOrDefault(c => c.Id == CategoryId);
            categoriaNombre = categoriaSimple?.Name ?? "la categoría";
            maxVotosPermitidos = categoriaSimple?.TopNProjectsAllowed ?? 1;
        }
        catch { }

        var evento = await http.GetFromJsonAsync<EventDetailDto>($"api/events/{EventId}");
        var categoriaActual = evento?.Categories.FirstOrDefault(c => c.Id == CategoryId);

        bool esJuradoAsignado = categoriaActual?.VotingSessions.Any(s => s.VoterType == "Jury" && s.JurorEmails.Contains(userEmail.ToLower())) == true;
        bool estaInscritoEvento = evento?.ParticipantsIds.Contains(_sessionUserId) == true || evento?.PublicIds.Contains(_sessionUserId) == true;

        if (esJuradoAsignado)
        {
            _voterTypeForUser = "Jury";
            puedeVotar = true;
        }
        else if (estaInscritoEvento)
        {
            _voterTypeForUser = "Public";
            puedeVotar = true;
        }
        else
        {
            _voterTypeForUser = string.Empty;
            puedeVotar = false;
        }

        if (puedeVotar)
        {
            List<VotingSessionDto>? sesionesActivas = null;
            try { sesionesActivas = await http.GetFromJsonAsync<List<VotingSessionDto>>($"api/votingsessions/active/{EventId}"); }
            catch { }

            var sesionDelUsuario = sesionesActivas?.FirstOrDefault(s => s.CategoryId == CategoryId && s.VoterType == _voterTypeForUser);
            _sesionActivaDelUsuario = sesionDelUsuario;
            votacionActiva = EsVotacionActiva(sesionDelUsuario);


            if (sesionDelUsuario != null)
            {

                _voteUrl = sesionDelUsuario.EvaluationType switch
                {
                    "WeightedScale" => $"/event/{EventId}/categories/{CategoryId}/vote-weighted",
                    "PointDistribution" => $"/event/{EventId}/categories/{CategoryId}/vote-point-distribution",
                    _ => $"/event/{EventId}/categories/{CategoryId}/vote-ranking"
                };

                if (sesionDelUsuario.EvaluationType == "WeightedScale")
                {
                    _sesionWeightedId = sesionDelUsuario.Id;
                }
            }
        }

        ProyectosSubidos = await http.GetFromJsonAsync<List<ProjectDto>>($"api/projects/by-category/{CategoryId}");

        if (ProyectosSubidos != null)
        {
            foreach (var proyecto in ProyectosSubidos)
            {
                try
                {
                    var comentarios = await http.GetFromJsonAsync<List<CommentDto>>($"api/votes/comments/{proyecto.Id}");
                    comentariosPorProyecto[proyecto.Id] = comentarios?.Count ?? 0;
                }
                catch
                {
                    comentariosPorProyecto[proyecto.Id] = 0;
                }
            }
        }
        if (puedeVotar && !string.IsNullOrEmpty(_sessionUserId) && !string.IsNullOrEmpty(_voteUrl))
        {
            try
            {
                var http2 = HttpClientFactory.CreateClient("API");
                if (_voteUrl.Contains("vote-weighted") && !string.IsNullOrEmpty(_sesionWeightedId))
                {
                    var previos = await http2.GetFromJsonAsync<List<WeightedVotePrevioDto>>(
                        $"api/votes/weighted?userId={_sessionUserId}&votingSessionId={_sesionWeightedId}");
                    haVotado = previos != null && previos.Any();
                }
                else if (_sesionActivaDelUsuario != null)
                {
                    var votosPrevios = await http2.GetFromJsonAsync<List<VoteResultDto>>(
                        $"api/votes/by-user?userId={_sessionUserId}&categoryId={CategoryId}&votingSessionId={_sesionActivaDelUsuario.Id}");
                    haVotado = votosPrevios != null && votosPrevios.Any();
                }
            }
            catch { }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {    }

    private void IrAVotar() => Navigation.NavigateTo(_voteUrl);

    private System.Threading.Timer? _timer;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
    
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }

    private async Task AbrirPopup(ProjectDto proyecto)
    {
        proyectoSeleccionado = proyecto;
        tabActiva = "info";
        comentariosProyecto = new();
        cargandoComentarios = true;
        StateHasChanged();

        var http = HttpClientFactory.CreateClient("API");
        try
        {
            var resultado = await http.GetFromJsonAsync<List<CommentDto>>($"api/votes/comments/{proyecto.Id}");
            comentariosProyecto = resultado ?? new();
            comentariosPorProyecto[proyecto.Id] = comentariosProyecto.Count;
        }
        catch { comentariosProyecto = new(); }
        finally { cargandoComentarios = false; }
    }

    private void CerrarPopup()
    {
        proyectoSeleccionado = null;
        comentariosProyecto = new();
    }

    private static bool EsVotacionActiva(VotingSessionDto ses)
    {
        if (ses == null) return false;
        if (ses.ManualStatus == "closed") return false;
        if (ses.ManualStatus == "paused") return false;
        if (ses.ManualStatus == "open") return true;

        if (!ses.OpenAt.HasValue || !ses.CloseAt.HasValue) return false;
        var now = DateTime.UtcNow;
        return now >= ses.OpenAt.Value && now <= ses.CloseAt.Value;
    }

    public class ProjectDto
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string? Description { get; set; }
        public string ProjectType { get; set; } = "";
        public string? ImageUrl { get; set; }
        public List<MaterialDto> Materials { get; set; } = new();
    }
    public class MaterialDto
    {
        public string Id { get; set; } = "";
        public string Type { get; set; } = "";
        public string Url { get; set; } = "";
        public string? Description { get; set; }
    }

    public class EventDetailDto
    {
        public List<string> ParticipantsIds { get; set; } = new();
        public List<string> PublicIds { get; set; } = new();
        public List<CategoryDetailDto> Categories { get; set; } = new();
    }

    public class CategoryDetailDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public List<VotingSessionFullDto> VotingSessions { get; set; } = new();
    }

    public class CategorySimpleDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public bool AllowSelfVoting { get; set; }
        public int TopNProjectsAllowed { get; set; }
        public string? EvaluationType { get; set; }
    }

    public class VotingSessionFullDto
    {
        public string Id { get; set; } = "";
        public string VoterType { get; set; } = "";
        public string EvaluationType { get; set; } = "";
        public int? TopN { get; set; }
        public List<string> JurorEmails { get; set; } = new();
    }

    public class VotingSessionDto
    {
        public string Id { get; set; } = "";
        public string CategoryId { get; set; } = "";
        public string VoterType { get; set; } = "";
        public string EvaluationType { get; set; } = "";
        public bool IsActive { get; set; }
        public DateTime? OpenAt { get; set; }
        public DateTime? CloseAt { get; set; }
        public string? ManualStatus { get; set; }
    }

    public class VoteResultDto { public string VotedProjectId { get; set; } = ""; public int TopPosition { get; set; } }

    public class CommentDto
    {
        public string Comment { get; set; } = string.Empty;
        public int TopPosition { get; set; }
        public string VoteType { get; set; } = string.Empty;
        public string EvaluationType { get; set; } = string.Empty;
    }

    public class WeightedVotePrevioDto { public string ProjectId { get; set; } = ""; }
}