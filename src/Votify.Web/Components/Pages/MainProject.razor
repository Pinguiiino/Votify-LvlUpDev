@page "/event/{EventId}/categories/{CategoryId}/projects"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Votify.Domain.ProjectFolder
@using Votify.Domain.CategoryFolder
@using Votify.Infrastructure
@inject NavigationManager Navigation
@inject IDbContextFactory<VotifyDbContext> DbFactory

<PageTitle>Proyectos - Votify</PageTitle>

<div class="mainproject-container">
    <header class="hero-section">
        <button class="back-btn" style="align-self: flex-start;" @onclick='() => Navigation.NavigateTo($"/event/{EventId}/categories")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
            </svg>
            Volver
        </button>
        <h1 class="main-title">
            Proyectos de @(categoria?.Name ?? "la categoría")
        </h1>
        <p class="subtitle">Explora los proyectos y vota a los mejores</p>
    </header>

    @if (ProyectosSubidos == null)
    {
        <p><em>Cargando proyectos desde la base de datos...</em></p>
    }
    else if (!ProyectosSubidos.Any())
    {
        <p>No hay proyectos disponibles en este momento.</p>
    }
    else
    {
        <div class="projects-grid">
            @foreach (var proyecto in ProyectosSubidos)
            {
                <div class="project-card" @onclick="() => AbrirPopup(proyecto)">
                    <div class="icon-container">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M.54 3.87.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.826a2 2 0 0 1-1.991-1.819l-.637-7a1.99 1.99 0 0 1 .342-1.31z" />
                        </svg>
                    </div>
                    <div class="card-info">
                        <h2 class="card-title">@proyecto.Title</h2>
                        <p class="card-description">@proyecto.Description</p>
                        <span class="card-modality" style="font-weight: bold; color: #4b5563;">@proyecto.ProjectType()</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (proyectoSeleccionado != null)
{
    <div class="popup-overlay" @onclick="CerrarPopup">
        <div class="popup-box" @onclick:stopPropagation="true">
            <div class="popup-header">
                <h2>@proyectoSeleccionado.Title</h2>
                <button class="close-btn" @onclick="CerrarPopup">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                    </svg>
                </button>
            </div>
            <div class="popup-body">
                <p class="popup-type">@proyectoSeleccionado.ProjectType()</p>
                <p class="popup-description">@proyectoSeleccionado.Description</p>

                @if (proyectoSeleccionado.Materials.Any())
                {
                    <h4>Materiales</h4>
                    <ul class="popup-materials">
                        @foreach (var mat in proyectoSeleccionado.Materials)
                        {
                            <li>
                                <span class="badge">@mat.Type</span>
                                <a href="@mat.Url" target="_blank">@mat.Url</a>
                                @if (!string.IsNullOrWhiteSpace(mat.Description))
                                {
                                    <span class="mat-desc"> — @mat.Description</span>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p style="color: #9ca3af; font-size: 0.9rem;">Sin materiales adjuntos.</p>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<Project>? ProyectosSubidos;
    private Project? proyectoSeleccionado;
    private Category? categoria;

    [Parameter] public string EventId { get; set; } = string.Empty;
    [Parameter] public string CategoryId { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        categoria = await context.Categories
            .AsNoTracking()
            .FirstOrDefaultAsync(c => c.Id == CategoryId);

        ProyectosSubidos = await context.Projects
            .Include(p => p.Materials)
            .Include(p => p.ProjectCategories)
            .Where(p => p.ProjectCategories.Any(pc => pc.CategoryId == CategoryId))
            .AsNoTracking()
            .ToListAsync();
    }

    private void AbrirPopup(Project proyecto) => proyectoSeleccionado = proyecto;
    private void CerrarPopup() => proyectoSeleccionado = null;
}