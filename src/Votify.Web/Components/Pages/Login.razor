@page "/"
@page "/login"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Votify.Web.Auth
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Iniciar Sesión - Votify</PageTitle>

<div class="auth-container">
    
    <Breadcrumb CurrentPageName="Iniciar Sesión" />
    <div class="auth-card">
        <div class="avatar-container">
            <div class="avatar-circle">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z" />
                </svg>
            </div>
        </div>

        <h1 class="auth-title">Bienvenido</h1>
        <p class="auth-subtitle">Ingresa tus credenciales para acceder</p>

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="auth-field">
                <label>Correo electrónico</label>
                <div class="input-wrapper">
                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z" />
                    </svg>
                    <InputText type="email" class="auth-input" placeholder="ejemplo@correo.com" @bind-Value="loginModel.Email" />
                </div>
                <ValidationMessage For="@(() => loginModel.Email)" class="validation-msg" />
            </div>

            <div class="auth-field">
                <label>Contraseña</label>
                <div class="input-wrapper">
                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM5 8h6a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1z" />
                    </svg>
                    <InputText type="password" class="auth-input" placeholder="••••••••" @bind-Value="loginModel.Password" />
                </div>
                <ValidationMessage For="@(() => loginModel.Password)" class="validation-msg" />
            </div>

            @if (!string.IsNullOrEmpty(apiError))
            {
                <div class="api-error">@apiError</div>
            }

            <button type="submit" class="btn-submit" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border"></span>
                }
                else
                {
                    <span>Entrar</span>
                }
            </button>

            <div class="auth-footer">
                ¿Aún no tienes cuenta? <a href="/register">Crear cuenta</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private bool isSubmitting = false;
    private string? apiError = null;

    private async Task HandleLogin()
    {
        isSubmitting = true;
        apiError = null;

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var response = await http.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<LoginResponse>();
                if (data != null)
                {
                    var customAuthStateProvider = (CustomAuthStateProvider)AuthStateProvider;
                    await customAuthStateProvider.UpdateAuthenticationState(new UserSession
                    {
                        Id = data.Id,
                        Username = data.Username,
                        Email = data.Email,
                        Role = data.Role,
                        Token = data.Token
                    });
                    Navigation.NavigateTo("/MainEvent");
                }
            }
            else
            {
                apiError = await response.Content.ReadAsStringAsync();
                apiError = apiError.Trim('"');
            }
        }
        catch (Exception)
        {
            apiError = "No se pudo conectar con el servidor.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "El correo es obligatorio")]
        [EmailAddress(ErrorMessage = "Correo inválido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria")]
        public string Password { get; set; } = string.Empty;
    }

    private class LoginResponse
    {
        public string Id { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public string Token { get; set; } = string.Empty;
    }
}
