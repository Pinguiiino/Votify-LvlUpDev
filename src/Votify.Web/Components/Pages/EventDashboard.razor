@page "/dashboard/{EventoId}"
@rendermode InteractiveServer
@using Votify.Domain.EventFolder
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Dashboard del Evento</PageTitle>

<div class="container-fluid p-4">
    <button class="back-btn"
            style="margin-bottom: 1.5rem; background: none; border: none; font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;"
            @onclick="Volver">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd"
                  d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
        </svg>
        Volver a Categorías
    </button>

    <h2 class="mb-4">Resultados de la Votación</h2>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger"
             style="background-color: #fee2e2; color: #991b1b; padding: 1rem; border-radius: 0.5rem;">
            @errorMessage
        </div>
    }
    else if (stats == null)
    {
        <div class="text-center" style="margin-top: 3rem;">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
            <p style="margin-top: 1rem; color: #6b7280;">Calculando resultados reales de la base de datos...</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card shadow-sm h-100"
                     style="border: none; border-radius: 0.75rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                    <div class="card-body" style="padding: 2rem;">
                        <h5 class="card-title mb-4" style="font-weight: bold; font-size: 1.25rem;">Top Proyectos por
                            Categoría (Ponderado)</h5>
                        
                            @if (!stats.Ranking.Any())
                            {
                                <div style="text-align: center; padding: 3rem 0; color: #9ca3af;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                                         viewBox="0 0 16 16" style="margin-bottom: 1rem;">
                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                                        <path d="M4 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 4 8z" />
                                    </svg>
                                    <p>Aún no hay votos registrados para este evento.</p>
                                </div>
                            }
                            else
                            {
                                @foreach (var grupoCategoria in stats.Ranking.GroupBy(p => p.Categoria))
                                {
                                    <div class="mb-5">
                                        <h6 class="text-primary border-bottom pb-2 mb-3"
                                            style="font-size: 1.2rem; font-weight: 600; color: #2563eb !important; border-bottom: 2px solid #e5e7eb !important;">
                                            @grupoCategoria.Key
                                        </h6>
                                    
                                        <div class="table-responsive">
                                            <table class="table table-hover mb-0" style="width: 100%;">
                                                <thead class="table-light" style="background-color: #f9fafb;">
                                                    <tr>
                                                        <th style="width: 15%; padding: 1rem;">Posición</th>
                                                        <th style="width: 65%; padding: 1rem;">Proyecto</th>
                                                        <th class="text-end" style="width: 20%; padding: 1rem; text-align: right;">
                                                            Puntos</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @{
                                                            int posicion = 1;
                                                            foreach (var proyecto in grupoCategoria.OrderByDescending(p => p.Puntos))
                                                            {
                                                                <tr style="border-bottom: 1px solid #f3f4f6;">
                                                                    <td style="padding: 1rem;">
                                                                        <strong
                                                                            style="font-size: 1.1rem; color: @(posicion == 1 ? "#d4af37" : posicion == 2 ? "#9ca3af" : posicion == 3 ? "#cd7f32" : "inherit");">
                                                                            @(posicion == 1 ? "🥇" : posicion == 2 ? "🥈" : posicion == 3 ? "🥉" :
                                                        "") #@posicion
                                                                        </strong>
                                                                    </td>
                                                                    <td class="fw-bold text-dark" style="padding: 1rem; font-weight: 600;">
                                                                        @proyecto.Nombre</td>
                                                                        <td class="text-end fw-bold"
                                                                            style="padding: 1rem; text-align: right; color: #2563eb; font-weight: bold;">
                                                                            @proyecto.Puntos pts</td>
                                                                        </tr>
                                                                        posicion++;
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

@code {
    [Parameter] public string EventoId { get; set; } = string.Empty;
    
    private EventDashboardDto? stats;
    private string? errorMessage = null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("API");
            stats = await http.GetFromJsonAsync<EventDashboardDto>($"api/dashboard/stats/{EventoId}");
        }
        catch (Exception ex)
        {
            errorMessage = "No se pudieron cargar los datos reales: " + ex.Message;
        }
    }

    private void Volver()
    {
        Navigation.NavigateTo($"/event/{EventoId}/categories");
    }
}
