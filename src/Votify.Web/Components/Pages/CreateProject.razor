@page "/event/{EventId}/create-project"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Votify.Web.Helpers
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<PageTitle>Crear Proyecto - Votify</PageTitle>

<div class="create-project-container">
    <EditForm Model="projectModel" OnValidSubmit="ManejarSubmitValido">
        <DataAnnotationsValidator />

        <header class="modal-header">
            <div class="header-title">
                <h1>Nuevo Proyecto</h1>
            </div>
            <button type="button" class="close-btn" @onclick="Cancelar">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path
                    d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
        </header>

        <div class="modal-body">

            <div class="form-group">
                <label>Tipo de Proyecto *</label>
                <select class="form-control" @bind="projectModel.ProjectType">
                    @foreach (var tipo in tiposProyecto)
                    {
                        <option value="@tipo">@(Translations.TipoProyecto.GetValueOrDefault(tipo, tipo))</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Título del Proyecto *</label>
                <InputText class="form-control" placeholder="Ej: Votify App" @bind-Value="projectModel.Title" />
                <ValidationMessage For="@(() => projectModel.Title)" />
            </div>

            <div class="form-group">
                <label>Descripción</label>
                <InputTextArea class="form-control" rows="3" placeholder="¿De qué trata este proyecto?"
                               @bind-Value="projectModel.Description" />
            </div>

            <div class="form-group">
                <label>Categorías *</label>
                @if (cargandoCategorias)
                {
                    <p style="font-size: 0.85rem; color: #6b7280;">Cargando categorías...</p>
                }
                else if (!categoriasDisponibles.Any())
                {
                    <p style="font-size: 0.85rem; color: #9ca3af; font-style: italic;">No hay categorías disponibles.</p>
                }
                else
                {
                    <div class="cp-checklist">
                        @foreach (var cat in categoriasDisponibles)
                        {
                            var isSelected = categoriasSeleccionadas.Contains(cat.Id);
                            <div class="cp-check-item @(isSelected ? "selected" : "")" @onclick="() => ToggleCategoria(cat.Id)">
                                <div class="cp-check-box">
                                    @if (isSelected)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                             viewBox="0 0 16 16">
                                            <path
                                            d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z" />
                                        </svg>
                                    }
                                </div>
                                <div class="cp-check-info">
                                    <span class="cp-check-name">@cat.Name</span>
                                    @if (!string.IsNullOrWhiteSpace(cat.Description))
                                    {
                                        <span class="cp-check-desc">@cat.Description</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                @if (errorCategorias)
                {
                    <div class="validation-error">Debes seleccionar al menos una categoría.</div>
                }
            </div>

            <hr style="margin: 1.5rem 0; border-top: 1px solid #e5e7eb;" />

            <div class="form-group">
                <label>Materiales</label>
                <div class="materials-list">
                    @foreach (var mat in projectModel.Materials)
                    {
                        @if (materialEditando == mat)
                        {
                            <div class="add-category-box">
                                <div class="form-group">
                                    <label>Tipo de archivo</label>
                                    <select class="form-control form-control-sm" @bind="mat.Type">
                                        @foreach (var tipo in tiposMaterial)
                                        {
                                            <option value="@tipo">@(Translations.TipoMaterial.GetValueOrDefault(tipo, tipo))</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Enlace</label>
                                    <input type="text" class="form-control form-control-sm @(errorUrlEdicion ? "is-invalid" : "")"
                                           placeholder="https://..." @bind="mat.Url" />
                                    @if (errorUrlEdicion)
                                    {
                                        <div class="validation-error">
                                            Introduce una URL válida (debe empezar por http:// o https://)
                                        </div>
                                    }
                                </div>
                                <div class="form-group">
                                    <label>Descripción del material</label>
                                    <input type="text" class="form-control form-control-sm" placeholder="Opcional"
                                           @bind="mat.Description" />
                                </div>
                                <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                                    <button type="button" class="btn-primary" style="flex: 1;"
                                            @onclick="() => ConfirmarEdicionMaterial(mat)">
                                        Guardar
                                    </button>
                                    <button type="button" class="btn-secondary" style="flex: 1;"
                                            @onclick="CancelarEdicionMaterial">
                                        Cancelar
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="category-item">
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <span class="badge">@(Translations.TipoMaterial.GetValueOrDefault(mat.Type, mat.Type))</span>
                                    <div style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 250px;">
                                        <strong>@mat.Url</strong>
                                        @if (!string.IsNullOrWhiteSpace(mat.Description))
                                        {
                                            <span style="display: block; font-size: 0.78rem; color: #6b7280;">@mat.Description</span>
                                        }
                                    </div>
                                </div>
                                <div style="display: flex; gap: 0.25rem;">
                                    <button type="button" class="btn-edit" @onclick="() => IniciarEdicionMaterial(mat)">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
                                        </svg>
                                    </button>
                                    <button type="button" class="btn-delete"
                                            @onclick="() => projectModel.Materials.Remove(mat)">
                                        ✕
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>

                @if (!mostrandoFormMaterial)
                {
                    <button type="button" class="btn-secondary mt-2" style="border: 2px dashed #d1d5db;"
                            @onclick="MostrarFormMaterial">
                        + Agregar Foto, Video o Documento
                    </button>
                }
                else
                {
                    <div class="add-category-box">
                        <div class="form-group">
                            <label>Tipo de archivo</label>
                            <select class="form-control form-control-sm" @bind="nuevoMaterial.Type">
                                @foreach (var tipo in tiposMaterial)
                                {
                                    <option value="@tipo">@(Translations.TipoMaterial.GetValueOrDefault(tipo, tipo))</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Enlace</label>
                            <input type="text" class="form-control form-control-sm @(errorUrl ? "is-invalid" : "")"
                                   placeholder="https://..." @bind="nuevoMaterial.Url" />
                            @if (errorUrl)
                            {
                                <div class="validation-error">
                                    Introduce una URL válida (debe empezar por http:// o https://)
                                </div>
                            }
                        </div>
                        <div class="form-group">
                            <label>Descripción del material</label>
                            <input type="text" class="form-control form-control-sm" placeholder="Opcional"
                                   @bind="nuevoMaterial.Description" />
                        </div>

                        <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                            <button type="button" class="btn-primary" style="flex: 1;"
                                    @onclick="ConfirmarMaterial">Añadir</button>
                            <button type="button" class="btn-secondary" style="flex: 1;"
                                    @onclick="OcultarFormMaterial">Cancelar</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <footer class="modal-footer">
            <button type="submit" class="btn-primary" style="width: 100%; padding: 1rem;">
                Crear Proyecto
            </button>
        </footer>
    </EditForm>
</div>

@code {
    private CreateProjectModel projectModel = new();
    private MaterialDraft nuevoMaterial = new();
    private bool mostrandoFormMaterial = false;
    private MaterialDraft? materialEditando = null;
    private bool errorUrlEdicion = false;
    private bool errorUrl = false;
    private bool errorCategorias = false;
    private bool cargandoCategorias = false;
    private List<CategorySimpleDto> categoriasDisponibles = new();
    private HashSet<string> categoriasSeleccionadas = new();
    [Parameter] public string EventId { get; set; } = string.Empty;
    private List<string> tiposMaterial = new();
    private List<string> tiposProyecto = new();

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(EventId)) return;

        projectModel.EventId = EventId;
        cargandoCategorias = true;

        try
        {
            var http = HttpClientFactory.CreateClient("API");

            tiposMaterial = await http.GetFromJsonAsync<List<string>>("/api/projects/material-types") ?? new();
            tiposProyecto = await http.GetFromJsonAsync<List<string>>("/api/projects/project-types") ?? new();

            var resultado = await http.GetFromJsonAsync<List<CategorySimpleDto>>(
                $"/api/categories/by-event/{EventId}");
            categoriasDisponibles = resultado ?? new();
        }
        catch
        {
            categoriasDisponibles = new();
        }
        finally
        {
            cargandoCategorias = false;
        }
    }

    private void ToggleCategoria(string catId)
    {
        if (!categoriasSeleccionadas.Remove(catId))
            categoriasSeleccionadas.Add(catId);

        if (categoriasSeleccionadas.Any())
            errorCategorias = false;
    }

    private void MostrarFormMaterial()
    {
        nuevoMaterial = new();
        errorUrl = false;
        mostrandoFormMaterial = true;
    }

    private void OcultarFormMaterial() => mostrandoFormMaterial = false;

    private void ConfirmarMaterial()
    {
        if (string.IsNullOrWhiteSpace(nuevoMaterial.Url)) { errorUrl = true; return; }
        if (!Uri.TryCreate(nuevoMaterial.Url, UriKind.Absolute, out var uri)
            || (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps))
        { errorUrl = true; return; }
        errorUrl = false;
        projectModel.Materials.Add(nuevoMaterial);
        mostrandoFormMaterial = false;
    }

    private void IniciarEdicionMaterial(MaterialDraft mat)
    {
        materialEditando = mat;
        errorUrlEdicion = false;
        mostrandoFormMaterial = false;
    }

    private void ConfirmarEdicionMaterial(MaterialDraft mat)
    {
        if (string.IsNullOrWhiteSpace(mat.Url)) { errorUrlEdicion = true; return; }
        if (!Uri.TryCreate(mat.Url, UriKind.Absolute, out var uri)
            || (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps))
        { errorUrlEdicion = true; return; }

        errorUrlEdicion = false;
        materialEditando = null;
    }

    private void CancelarEdicionMaterial() => materialEditando = null;

    private async Task ManejarSubmitValido()
    {
        if (!categoriasSeleccionadas.Any())
        {
            errorCategorias = true;
            return;
        }
        errorCategorias = false;
        try
        {
            var payload = new
            {
                projectModel.Title,
                projectModel.EventId,
                projectModel.Description,
                projectModel.ProjectType,
                CategoryIds = categoriasSeleccionadas.ToList(),
                Materials = projectModel.Materials.Select(m => new
                {
                    Type = m.Type.ToString(),
                    m.Url,
                    m.Description
                })
            };
            var http = HttpClientFactory.CreateClient("API");
            var response = await http.PostAsJsonAsync("/api/projects", payload);

            if (response.IsSuccessStatusCode)
                Navigation.NavigateTo($"/event/{EventId}/categories");
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Error: {error}");
            }
        }
        catch (Exception)
        {
            await JS.InvokeVoidAsync("alert", "No se pudo conectar con la API.");
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo($"/event/{projectModel.EventId}/categories");
    }

    public class CreateProjectModel
    {
        [Required(ErrorMessage = "El título es obligatorio")]
        public string Title { get; set; } = string.Empty;

        [Required(ErrorMessage = "Debes asignar el proyecto a un evento")]
        public string EventId { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;
        public string ProjectType { get; set; } = "AI";
        public List<MaterialDraft> Materials { get; set; } = new();
    }

    public class MaterialDraft
    {
        public string Type { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
        public string? Description { get; set; }
    }

    public class CategorySimpleDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }
}