@page "/profile"
@using Microsoft.AspNetCore.Components.Authorization
@using Votify.Web.Auth
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Perfil de Usuario - Votify</PageTitle>

<div class="auth-container">

    <Breadcrumb CurrentPageName="Perfil" />
    <div class="profile-wrapper">
        <button class="btn-volver" @onclick="GoBack">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
            </svg>
            Volver
        </button>
        <div class="auth-card">

        <div class="avatar-container">
            <div class="avatar-circle">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z" />
                </svg>
            </div>
        </div>

        <h1 class="auth-title">Perfil de Usuario</h1>
        <p class="auth-subtitle">Información de tu cuenta</p>

        <div class="profile-info-box">
            <div class="info-row">
                <div class="info-icon bg-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z" /></svg>
                </div>
                <div class="info-text">
                    <label>Nombre de usuario</label>
                    <span>@userName</span>
                </div>
            </div>
            
            <hr class="info-divider" />
            
            <div class="info-row">
                <div class="info-icon bg-purple">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z" /></svg>
                </div>
                <div class="info-text">
                    <label>Correo electrónico</label>
                    <span>@userEmail</span>
                </div>
            </div>
        </div>

        <button class="btn-outline" @onclick="GoToChangePassword">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM5 8h6a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1z" /></svg>
            Cambiar Contraseña
        </button>

        <button class="btn-danger" @onclick="Logout">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z" /><path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z" /></svg>
            Cerrar Sesión
        </button>
        </div>
    </div>
</div>

@code {
    private string userName = "Cargando...";
    private string userEmail = "Cargando...";

    // CAMBIADO: Usamos OnAfterRenderAsync para evitar el fallo del servidor
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            // 1. Si el usuario intenta usar la flecha de atrás tras cerrar sesión, lo expulsamos
            if (!user.Identity?.IsAuthenticated ?? true)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            // 2. Si todo está bien, cargamos sus datos
            userName = user.Identity.Name ?? "Usuario";
            userEmail = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "Sin correo";
            
            StateHasChanged(); // Avisamos a Blazor de que repinte la pantalla
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/MainEvent");
    }

    private void GoToChangePassword()
    {
        Navigation.NavigateTo("/change-password");
    }

    private async Task Logout()
    {
        var customAuthStateProvider = (CustomAuthStateProvider)AuthStateProvider;
        await customAuthStateProvider.UpdateAuthenticationState(null);
        
        // Destruimos la caché de la página forzando una recarga nativa
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}