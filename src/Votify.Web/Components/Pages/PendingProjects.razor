@page "/event/{EventId}/pending-projects"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Votify.Web.Auth
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Proyectos pendientes - Votify</PageTitle>

<div class="pending-container">
    <button class="back-btn" @onclick="Volver">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd"
                  d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
        </svg>
        Volver
    </button>

    <header class="page-header">
        <h1 class="page-title">Proyectos pendientes</h1>
        @if (!string.IsNullOrWhiteSpace(nombreEvento))
        {
            <p class="page-subtitle">Evento: @nombreEvento</p>
        }
    </header>

    @if (cargando)
    {
        <div class="loading-state">
            <p><em>Cargando proyectos pendientes...</em></p>
        </div>
    }
    else if (!autorizado)
    {
        <div class="empty-state">
            <p>No tienes permisos para validar proyectos en este evento.</p>
        </div>
    }
    else if (proyectos == null || !proyectos.Any())
    {
        <div class="empty-state">
            <p>No hay proyectos pendientes de validación en este evento.</p>
        </div>
    }
    else
    {
        <div class="pending-table">
            <div class="table-head">
                <div class="col-project">PROYECTO</div>
                <div class="col-categories">CATEGORÍAS</div>
                <div class="col-actions">ACCIONES</div>
            </div>

            @foreach (var p in proyectos)
            {
                <div class="table-row">
                    <div class="col-project">
                        <div class="project-title">@p.Title</div>
                        <span class="project-type-pill">@TraducirTipo(p.ProjectType)</span>
                    </div>

                    <div class="col-categories">
                        @foreach (var cat in p.Categories)
                        {
                            <span class="category-pill">@cat.Name</span>
                        }
                    </div>

                    <div class="col-actions">
                        <button class="btn-accept" @onclick="() => Aprobar(p)" disabled="@procesando">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.267.267 0 0 1 .02-.022z" />
                            </svg>
                            Aceptar
                        </button>
                        <button class="btn-reject" @onclick="() => AbrirModalRechazo(p)" disabled="@procesando">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                            </svg>
                            Rechazar
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (proyectoRechazando != null)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                    </svg>
                </div>
                <div>
                    <h3 class="modal-title">Rechazar proyecto</h3>
                    <p class="modal-subtitle">@proyectoRechazando.Title</p>
                </div>
            </div>

            <textarea class="reject-textarea"
                      placeholder="Motivo del rechazo (opcional)..."
                      @bind="motivoRechazo"
                      rows="5"></textarea>

            @if (errorRechazo != null)
            {
                <div class="error-msg">@errorRechazo</div>
            }

            <div class="modal-actions">
                <button class="btn-cancel" @onclick="CerrarModal" disabled="@procesando">Cancelar</button>
                <button class="btn-confirm-reject" @onclick="ConfirmarRechazo" disabled="@procesando">
                    @(procesando ? "Procesando..." : "Confirmar rechazo")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string EventId { get; set; } = string.Empty;

    private List<PendingProjectDto>? proyectos;
    private string nombreEvento = string.Empty;
    private bool cargando = true;
    private bool autorizado = true;
    private bool procesando = false;
    private string currentUserId = string.Empty;

    private PendingProjectDto? proyectoRechazando;
    private string motivoRechazo = string.Empty;
    private string? errorRechazo;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;

        if (string.IsNullOrEmpty(currentUserId))
        {
            autorizado = false;
            cargando = false;
            return;
        }

        var http = HttpClientFactory.CreateClient("API");

        try
        {
            var evento = await http.GetFromJsonAsync<EventInfoDto>($"api/events/{EventId}");
            if (evento != null)
            {
                nombreEvento = evento.Name;
                if (!string.Equals(evento.Organizer, currentUserId, StringComparison.Ordinal))
                {
                    autorizado = false;
                    cargando = false;
                    return;
                }
            }
        }
        catch
        {
            autorizado = false;
            cargando = false;
            return;
        }

        await CargarProyectos();
    }

    private async Task CargarProyectos()
    {
        cargando = true;
        var http = HttpClientFactory.CreateClient("API");
        try
        {
            proyectos = await http.GetFromJsonAsync<List<PendingProjectDto>>(
                $"api/projects/pending/by-event/{EventId}");
        }
        catch
        {
            proyectos = new();
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task Aprobar(PendingProjectDto p)
    {
        if (procesando) return;
        procesando = true;
        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var resp = await http.PostAsJsonAsync(
                $"api/projects/{p.Id}/approve",
                new { RequesterId = currentUserId });

            if (resp.IsSuccessStatusCode)
            {
                proyectos?.RemoveAll(x => x.Id == p.Id);
            }
            else
            {
                var msg = (await resp.Content.ReadAsStringAsync()).Trim('"');
                await JS.InvokeVoidAsync("alert", $"Error al aprobar: {msg}");
            }
        }
        catch
        {
            await JS.InvokeVoidAsync("alert", "Error de conexión.");
        }
        finally
        {
            procesando = false;
        }
    }

    private void AbrirModalRechazo(PendingProjectDto p)
    {
        proyectoRechazando = p;
        motivoRechazo = string.Empty;
        errorRechazo = null;
    }

    private void CerrarModal()
    {
        if (procesando) return;
        proyectoRechazando = null;
        motivoRechazo = string.Empty;
        errorRechazo = null;
    }

    private async Task ConfirmarRechazo()
    {
        if (proyectoRechazando == null || procesando) return;

        procesando = true;
        errorRechazo = null;

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var resp = await http.PostAsJsonAsync(
                $"api/projects/{proyectoRechazando.Id}/reject",
                new { RequesterId = currentUserId, Reason = motivoRechazo });

            if (resp.IsSuccessStatusCode)
            {
                var id = proyectoRechazando.Id;
                proyectos?.RemoveAll(x => x.Id == id);
                proyectoRechazando = null;
                motivoRechazo = string.Empty;
            }
            else
            {
                errorRechazo = (await resp.Content.ReadAsStringAsync()).Trim('"');
            }
        }
        catch
        {
            errorRechazo = "Error de conexión.";
        }
        finally
        {
            procesando = false;
        }
    }

    private void Volver() => Navigation.NavigateTo($"/event/{EventId}/categories");

    private static string TraducirTipo(string tipo) => tipo switch
    {
        "AI" => "IA",
        "Sustainability" => "Sostenibilidad",
        "General" => "General",
        _ => tipo
    };

    public class PendingProjectDto
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string EventId { get; set; } = string.Empty;
        public string ProjectType { get; set; } = string.Empty;
        public List<CategoryRef> Categories { get; set; } = new();
    }

    public class CategoryRef
    {
        public string CategoryId { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }

    public class EventInfoDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Organizer { get; set; } = string.Empty;
    }
}
