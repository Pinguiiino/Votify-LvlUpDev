@page "/my-projects"
@rendermode InteractiveServer
@using Votify.Web.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@inject HttpClient Http
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Tus proyectos - Votify</PageTitle>

<div class="myprojects-container">
    <header class="hero-section">
        <button class="back-btn" style="align-self: flex-start;" @onclick='() => Navigation.NavigateTo($"/MainEvent")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                      d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
            </svg>
            Volver
        </button>
        <h1 class="main-title">Mis Proyectos</h1>
        <p class="subtitle">Visualiza tus proyectos y sus comentarios</p>
    </header>

    @if (ProyectosSubidos == null)
    {
        <p><em>Cargando proyectos desde la base de datos...</em></p>
    }
    else if (!ProyectosSubidos.Any())
    {
        <p>Aún no has subido ningún proyecto.</p>
    }
    else
    {
        @foreach (var grupo in proyectosAgrupados)
        {
            var evento = ListaEventos.FirstOrDefault(e => e.Id == grupo.Key);
            var nombreEvento = evento?.Name ?? "Evento Desconocido";
            var estadoEvento = GetEventStatus(evento);

            <div class="event-section" style="margin-bottom: 3rem;">
                <h2
                    style="font-size: 1.4rem; color: #111827; margin-bottom: 1.25rem; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" style="color: #2563eb;"
                         viewBox="0 0 16 16">
                        <path
                        d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z" />
                    </svg>
                    @nombreEvento
                    <span class="@StatusCssClass(estadoEvento)">@StatusLabel(estadoEvento)</span>
                </h2>

                <div class="projects-grid">
                    @foreach (var proyecto in grupo.Value)
                    {
                        <div class="project-card" @onclick="() => AbrirPopup(proyecto)">
                            @if (!string.IsNullOrWhiteSpace(proyecto.ImageUrl))
                            {
                                <img src="@(apiBaseUrl + proyecto.ImageUrl)" alt="@proyecto.Title" class="card-image" />
                            }
                            else
                            {
                                <div class="icon-container">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                         viewBox="0 0 16 16">
                                        <path d="M.54 3.87.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.826a2 2 0 0 1-1.991-1.819l-.637-7a1.99 1.99 0 0 1 .342-1.31z" />
                                    </svg>
                                </div>
                            }
                            <div class="card-info">
                                <h2 class="card-title">@proyecto.Title</h2>
                                <p class="card-description">@proyecto.Description</p>
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span class="card-modality" style="font-weight: bold; color: #4b5563;">@(Translations.TipoProyecto.GetValueOrDefault(proyecto.ProjectType, proyecto.ProjectType))</span>

                                    @if (comentariosPorProyecto.TryGetValue(proyecto.Id, out var count) && count > 0)
                                    {
                                        <span class="comment-count-badge">@count</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }

    @if (proyectoSeleccionado != null)
    {
        <div class="modal-overlay" @onclick="CerrarPopup">
            <div class="modal-content" @onclick:stopPropagation="true">
                <button class="close-btn" @onclick="CerrarPopup">✕</button>
                <h2 class="modal-title">@proyectoSeleccionado.Title</h2>

                <div class="tabs">
                    <button class="@(tabActiva == "info" ? "active" : "")" @onclick='() => tabActiva = "info"'>Información</button>
                    <button class="@(tabActiva == "comentarios" ? "active" : "")" @onclick='() => tabActiva = "comentarios"'>Comentarios (@comentariosProyecto.Count)</button>
                </div>

                <div class="tab-content" style="margin-top: 1rem;">
                    @if (tabActiva == "info")
                    {
                        <p>@proyectoSeleccionado.Description</p>
                        @if (!string.IsNullOrWhiteSpace(proyectoSeleccionado.ImageUrl))
                        {
                            <img src="@(apiBaseUrl + proyectoSeleccionado.ImageUrl)" alt="@proyectoSeleccionado.Title"
                                 style="max-width: 100%; border-radius: 0.5rem; margin-top: 1rem;" />
                        }

                        @if (!proyectosAuditados.Contains(proyectoSeleccionado.Id))
                        {
                            <button class="btn-outline" style="margin-top: 1rem;"
                                    @onclick="() => PedirAuditoria(proyectoSeleccionado)">
                                Solicitar auditoría
                            </button>
                        }
                        else
                        {
                            <p style="margin-top: 1rem; color: #16a34a; font-weight: 600;">✓ Auditoría solicitada</p>
                        }
                    }
                    else if (tabActiva == "comentarios")
                    {
                        @if (cargandoComentarios)
                        {
                            <p><em>Cargando comentarios...</em></p>
                        }
                        else if (!comentariosProyecto.Any())
                        {
                            <p>No hay comentarios para este proyecto.</p>
                        }
                        else
                        {
                            <div class="comments-list" style="display: flex; flex-direction: column; gap: 0.75rem;">
                                @foreach (var c in comentariosProyecto)
                                {
                                    <div class="comment-item" style="background: #f9fafb; padding: 1rem; border-radius: 0.5rem; border: 1px solid #e5e7eb;">
                                        <div class="comment-header"
                                             style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                                            <div class="comment-avatar"
                                                 style="width: 30px; height: 30px; background: #e5e7eb; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: #4b5563;">
                                                @c.VoteType[0]</div>
                                            <div class="comment-meta" style="display: flex; flex-direction: column;">
                                                <span class="comment-author" style="font-weight: 600; font-size: 0.9rem;">Votante <span
                                                    class="vote-type-pill"
                                                    style="font-weight: normal; font-size: 0.75rem; background: #dbeafe; color: #1e40af; padding: 0.1rem 0.4rem; border-radius: 1rem;">@c.VoteType</span></span>
                                                <span class="comment-position" style="font-size: 0.75rem; color: #6b7280;">Lo situó en el
                                                    @c.TopPosition&#186; puesto</span>
                                            </div>
                                        </div>
                                        <p class="comment-text" style="margin: 0; font-size: 0.9rem; color: #374151;">@c.Comment</p>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<string> proyectosAuditados = new();
    private string apiBaseUrl = string.Empty;
    private string currentUserId = string.Empty;

    public List<ProjectDto>? ProyectosSubidos;
    private List<EventDto> ListaEventos = new();
    private Dictionary<string, List<ProjectDto>> proyectosAgrupados = new();

    private ProjectDto? proyectoSeleccionado;
    private string tabActiva = "info";
    private bool cargandoComentarios = false;
    private List<CommentDto> comentariosProyecto = new();
    private Dictionary<string, int> comentariosPorProyecto = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;

        if (string.IsNullOrEmpty(currentUserId))
        {
            ProyectosSubidos = new();
            return;
        }

        var http = HttpClientFactory.CreateClient("API");
        apiBaseUrl = http.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;

        try
        {
            var eventos = await http.GetFromJsonAsync<List<EventDto>>("api/events");
            if (eventos != null) ListaEventos = eventos;
        }
        catch { }

        try
        {
            ProyectosSubidos = await http.GetFromJsonAsync<List<ProjectDto>>(
                $"api/projects/by-owner/{currentUserId}");
        }
        catch
        {
            ProyectosSubidos = new();
        }

        try
        {
            var auditados = await http.GetFromJsonAsync<List<string>>("api/audit/requested");
            if (auditados != null) proyectosAuditados = auditados;
        }
        catch { }

        if (ProyectosSubidos != null)
        {
            proyectosAgrupados = ProyectosSubidos
                .GroupBy(p => p.EventId)
                .OrderBy(g => StatusOrder(GetEventStatus(ListaEventos.FirstOrDefault(e => e.Id == g.Key))))
                .ThenBy(g => ListaEventos.FirstOrDefault(e => e.Id == g.Key)?.Name ?? "")
                .ToDictionary(g => g.Key, g => g.ToList());

            foreach (var proyecto in ProyectosSubidos)
            {
                try
                {
                    var comentarios = await http.GetFromJsonAsync<List<CommentDto>>($"api/votes/comments/{proyecto.Id}");
                    comentariosPorProyecto[proyecto.Id] = comentarios?.Count ?? 0;
                }
                catch
                {
                    comentariosPorProyecto[proyecto.Id] = 0;
                }
            }
        }
    }

    private async Task AbrirPopup(ProjectDto proyecto)
    {
        proyectoSeleccionado = proyecto;
        tabActiva = "info";
        comentariosProyecto = new();
        cargandoComentarios = true;
        StateHasChanged();

        var http = HttpClientFactory.CreateClient("API");
        try
        {
            var resultado = await http.GetFromJsonAsync<List<CommentDto>>($"api/votes/comments/{proyecto.Id}");
            comentariosProyecto = resultado ?? new();
        }
        catch
        {
            comentariosProyecto = new();
        }
        finally
        {
            cargandoComentarios = false;
        }
    }

    private void CerrarPopup()
    {
        proyectoSeleccionado = null;
        comentariosProyecto = new();
    }

    private async Task PedirAuditoria(ProjectDto proyecto)
    {
        bool confirmar = await JS.InvokeAsync<bool>("confirm",
            $"¿Enviar reclamación de '{proyecto.Title}' al Auditor?");

        if (!confirmar) return;

        try
        {
            var http = HttpClientFactory.CreateClient("API");

            var response = await http.PostAsync($"api/audit/request/{proyecto.Id}", null);
            response.EnsureSuccessStatusCode();

            proyectosAuditados.Add(proyecto.Id);
            await JS.InvokeVoidAsync("alert", "Enviado al Auditor.");
        }
        catch
        {
            await JS.InvokeVoidAsync("alert", "Error en el envío.");
        }
    }

    private enum EventStatus { Activo, Proximo, Finalizado, Desconocido }

    private EventStatus GetEventStatus(EventDto? evento)
    {
        if (evento == null) return EventStatus.Desconocido;
        var ahora = DateTime.UtcNow;
        if (ahora < evento.StartDate) return EventStatus.Proximo;
        if (ahora > evento.EndDate) return EventStatus.Finalizado;
        return EventStatus.Activo;
    }

    private int StatusOrder(EventStatus status) => status switch
    {
        EventStatus.Activo => 0,
        EventStatus.Proximo => 1,
        EventStatus.Finalizado => 2,
        _ => 3
    };

    private string StatusLabel(EventStatus status) => status switch
    {
        EventStatus.Activo => "En curso",
        EventStatus.Proximo => "Próximo",
        EventStatus.Finalizado => "Finalizado",
        _ => "—"
    };

    private string StatusCssClass(EventStatus status) => status switch
    {
        EventStatus.Activo => "status-pill status-active",
        EventStatus.Proximo => "status-pill status-upcoming",
        EventStatus.Finalizado => "status-pill status-finished",
        _ => "status-pill"
    };

    public class ProjectDto
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string? Description { get; set; }
        public string EventId { get; set; } = "";
        public string? OwnerId { get; set; }
        public string ProjectType { get; set; } = "";
        public string? ImageUrl { get; set; }
    }

    public class EventDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
    }

    public class CommentDto
    {
        public string Comment { get; set; } = string.Empty;
        public int TopPosition { get; set; }
        public string VoteType { get; set; } = string.Empty;
    }
}
