@page "/my-projects"
@rendermode InteractiveServer
@using Votify.Web.Helpers
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Tus proyectos - Votify</PageTitle>

<div class="myprojects-container">
    <header class="hero-section">
        <button class="back-btn" style="align-self: flex-start;" @onclick='() => Navigation.NavigateTo($"/")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                      d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
            </svg>
            Volver
        </button>
        <h1 class="main-title">Proyectos</h1>
        <p class="subtitle">Visualiza tus proyectos y sus comentarios</p>
    </header>

    @if (ProyectosSubidos == null)
    {
        <p><em>Cargando proyectos desde la base de datos...</em></p>
    }
    else if (!ProyectosSubidos.Any())
    {
        <p>No hay proyectos disponibles en este momento.</p>
    }
    else
    {
        <div class="projects-grid">
            @foreach (var proyecto in ProyectosSubidos)
            {
                <div class="project-card" @onclick="() => AbrirPopup(proyecto)">
                    <div class="icon-container">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M.54 3.87.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.826a2 2 0 0 1-1.991-1.819l-.637-7a1.99 1.99 0 0 1 .342-1.31z" />
                        </svg>
                    </div>
                    <div class="card-info">
                        <h2 class="card-title">@proyecto.Title</h2>
                        <p class="card-description">@proyecto.Description</p>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span class="card-modality" style="font-weight: bold; color: #4b5563;">@(Translations.TipoProyecto.GetValueOrDefault(proyecto.ProjectType, proyecto.ProjectType))</span>
                            @if (comentariosPorProyecto.TryGetValue(proyecto.Id, out var count) && count > 0)
                            {
                                <span class="comment-count-badge">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M2.678 11.894a1 1 0 0 1 .287.801 10.97 10.97 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8.06 8.06 0 0 0 8 14c3.996 0 7-2.807 7-6 0-3.192-3.004-6-7-6S1 4.808 1 8c0 1.468.617 2.83 1.678 3.894zm-.493 3.905a21.682 21.682 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a9.68 9.68 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9.06 9.06 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105z"/>
                                    </svg>
                                    @count
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (proyectoSeleccionado != null)
{
    <div class="popup-overlay" @onclick="CerrarPopup">
        <div class="popup-box" @onclick:stopPropagation="true">
            <div class="popup-header">
                <h2>@proyectoSeleccionado.Title</h2>
                <button class="close-btn" @onclick="CerrarPopup">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                    </svg>
                </button>
            </div>

            <div class="popup-tabs">
                <button class="tab-btn @(tabActiva == "info" ? "active" : "")" @onclick='() => tabActiva = "info"'>
                    Información
                </button>
                <button class="tab-btn @(tabActiva == "comentarios" ? "active" : "")" @onclick='() => tabActiva = "comentarios"'>
                    Comentarios
                    @if (comentariosProyecto.Any())
                    {
                        <span class="tab-count">@comentariosProyecto.Count</span>
                    }
                </button>
            </div>

            <div class="popup-body">
                @if (tabActiva == "info")
                {
                    <p class="popup-type">@(Translations.TipoProyecto.GetValueOrDefault(proyectoSeleccionado.ProjectType, proyectoSeleccionado.ProjectType))</p>
                    <p class="popup-description">@proyectoSeleccionado.Description</p>

                    @if (proyectoSeleccionado.Materials.Any())
                    {
                        <h4>Materiales</h4>
                        <ul class="popup-materials">
                            @foreach (var mat in proyectoSeleccionado.Materials)
                            {
                                <li>
                                    <span class="badge">@(Translations.TipoMaterial.GetValueOrDefault(mat.Type, mat.Type))</span>
                                    <a href="@mat.Url" target="_blank">@mat.Url</a>
                                    @if (!string.IsNullOrWhiteSpace(mat.Description))
                                    {
                                        <span class="mat-desc"> — @mat.Description</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p style="color: #9ca3af; font-size: 0.9rem;">Sin materiales adjuntos.</p>
                    }
                }
                else
                {
                    @if (cargandoComentarios)
                    {
                        <div class="comments-loading">
                            <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="animation: spin 1s linear infinite;">
                                <path d="M12,1A11,11,0,1,0,23,12,11,11,0,0,0,12,1Zm0,19a8,8,0,1,1,8-8A8,8,0,0,1,12,20Z" opacity=".25" fill="currentColor"/>
                                <path d="M10.14,1.16a11,11,0,0,0-9,8.92A1.59,1.59,0,0,0,2.46,12,1.52,1.52,0,0,0,4.11,10.7a8,8,0,0,1,6.66-6.61A1.42,1.42,0,0,0,12,2.69h0A1.57,1.57,0,0,0,10.14,1.16Z" fill="currentColor"/>
                            </svg>
                            <span>Cargando comentarios...</span>
                            <style>@@keyframes spin { 100% { transform: rotate(360deg); } }</style>
                        </div>
                    }
                    else if (!comentariosProyecto.Any())
                    {
                        <div class="empty-comments">
                            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.678 11.894a1 1 0 0 1 .287.801 10.97 10.97 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8.06 8.06 0 0 0 8 14c3.996 0 7-2.807 7-6 0-3.192-3.004-6-7-6S1 4.808 1 8c0 1.468.617 2.83 1.678 3.894zm-.493 3.905a21.682 21.682 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a9.68 9.68 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9.06 9.06 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105z"/>
                            </svg>
                            <p>Este proyecto aún no tiene comentarios.</p>
                        </div>
                    }
                    else
                    {
                        <div class="comments-list">
                            @foreach (var c in comentariosProyecto)
                            {
                                <div class="comment-item">
                                    <div class="comment-header">
                                        <div class="comment-avatar">@c.VoteType[0]</div>
                                        <div class="comment-meta">
                                            <span class="comment-author">Votante <span class="vote-type-pill">@c.VoteType</span></span>
                                            <span class="comment-position">Lo situó en el @c.TopPosition&#186; puesto</span>
                                        </div>
                                    </div>
                                    <p class="comment-text">@c.Comment</p>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private List<ProjectDto>? ProyectosSubidos;
    private ProjectDto? proyectoSeleccionado;
    private string tabActiva = "info";
    private bool cargandoComentarios = false;
    private List<CommentDto> comentariosProyecto = new();
    private Dictionary<string, int> comentariosPorProyecto = new();

    protected override async Task OnInitializedAsync()
    {
        var http = HttpClientFactory.CreateClient("API");
        ProyectosSubidos = await http.GetFromJsonAsync<List<ProjectDto>>("api/projects");

        if (ProyectosSubidos != null)
        {
            foreach (var proyecto in ProyectosSubidos)
            {
                try
                {
                    var comentarios = await http.GetFromJsonAsync<List<CommentDto>>($"api/votes/comments/{proyecto.Id}");
                    comentariosPorProyecto[proyecto.Id] = comentarios?.Count ?? 0;
                }
                catch
                {
                    comentariosPorProyecto[proyecto.Id] = 0;
                }
            }
        }
    }

    private async Task AbrirPopup(ProjectDto proyecto)
    {
        proyectoSeleccionado = proyecto;
        tabActiva = "info";
        comentariosProyecto = new();
        cargandoComentarios = true;

        var http = HttpClientFactory.CreateClient("API");
        try
        {
            var resultado = await http.GetFromJsonAsync<List<CommentDto>>($"api/votes/comments/{proyecto.Id}");
            comentariosProyecto = resultado ?? new();
        }
        catch
        {
            comentariosProyecto = new();
        }
        finally
        {
            cargandoComentarios = false;
        }

        StateHasChanged();
    }

    private void CerrarPopup()
    {
        proyectoSeleccionado = null;
        comentariosProyecto = new();
    }

    public class ProjectDto
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string ProjectType { get; set; } = string.Empty;
        public List<MaterialDto> Materials { get; set; } = new();
    }

    public class MaterialDto
    {
        public string Id { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
        public string? Description { get; set; }
    }

    public class CommentDto
    {
        public string Comment { get; set; } = string.Empty;
        public int TopPosition { get; set; }
        public string VoteType { get; set; } = string.Empty;
    }
}
