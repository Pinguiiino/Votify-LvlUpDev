@page "/event/{EventId}/categories/{CategoryId}/vote-weighted"
@using System.Globalization
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Evaluación por Baremo - Votify</PageTitle>

<div class="weighted-container">
    <header class="weighted-header">
        <button class="back-btn" @onclick='() => Navigation.NavigateTo($"/event/{EventId}/categories/{CategoryId}/projects")'>
            ← Volver a proyectos
        </button>
        <h1 class="weighted-title">Evaluación por Baremo</h1>
        <p class="weighted-subtitle">
            @GetSubtitleForType()
        </p>
    </header>

    @if (proyectos == null)
    {
        <div class="weighted-loading">
            <div class="weighted-spinner"></div>
            <p>Cargando proyectos...</p>
        </div>
    }
    else if (!proyectos.Any())
    {
        <div class="weighted-empty">
            <p>No hay proyectos en esta categoría.</p>
        </div>
    }
    else
    {
        @if (criterios.Any())
        {
            <div class="criteria-legend">
                <span class="criteria-legend-label">Criterios de evaluación:</span>
                @foreach (var c in criterios)
                {
                    <span class="criteria-legend-pill">
                        @c.Name <span class="criteria-legend-weight">@((c.Weight * 100).ToString("0"))%</span>
                    </span>
                }
                @if (criterionType != null)
                {
                    <span class="criteria-type-badge criteria-type-@criterionType.ToLower()">
                        @GetTypeLabel()
                    </span>
                }
            </div>
        }

        @foreach (var proyecto in proyectos)
        {
            <div class="weighted-project-card">
                <div class="weighted-project-header">
                    <div>
                        <h3 class="weighted-project-title">@proyecto.Title</h3>
                        @if (!string.IsNullOrWhiteSpace(proyecto.Description))
                        {
                            <p class="weighted-project-desc">@proyecto.Description</p>
                        }
                    </div>
                    <div class="weighted-score-badge">
                        <span class="weighted-score-value">@CalcularScore(proyecto.Id).ToString("0.00")</span>
                        <span class="weighted-score-max">/ 10</span>
                    </div>
                </div>

                <div class="criteria-rows">
                    @foreach (var criterio in criterios)
                    {
                        <div class="criterion-row" style="@(sesion?.AllowCommentsPerCriterion == true ? "flex-wrap: wrap; align-items: flex-start;" : "")">
                            <div class="criterion-info">
                                <span class="criterion-label">@criterio.Name</span>
                                <span class="criterion-weight-badge">@((criterio.Weight * 100).ToString("0"))%</span>
                                @if (!string.IsNullOrWhiteSpace(criterio.Description))
                                {
                                    <p class="criterion-desc">@criterio.Description</p>
                                }
                            </div>

                            @if (criterionType == "Checklist")
                            {
                                <div class="checklist-input-group">
                                    <label class="checklist-toggle @(GetScore(proyecto.Id, criterio.Id) == 10 ? "checked" : "")">
                                        <input type="checkbox"
                                               checked="@(GetScore(proyecto.Id, criterio.Id) == 10)"
                                               @onchange="e => SetCheckbox(proyecto.Id, criterio.Id, e.Value)" />
                                        <span class="checklist-toggle-track">
                                            <span class="checklist-toggle-thumb"></span>
                                        </span>
                                        <span class="checklist-toggle-label">
                                            @(GetScore(proyecto.Id, criterio.Id) == 10 ? "Cumple" : "No cumple")
                                        </span>
                                    </label>
                                    <span class="checklist-score-preview">
                                        +@((GetScore(proyecto.Id, criterio.Id) * criterio.Weight).ToString("0.00"))
                                    </span>
                                </div>
                            }
                            else if (criterionType == "Rubric")
                            {
                                <div class="rubric-input-group">
                                    @foreach (var level in RubricLevels)
                                    {
                                        var isSelected = GetScore(proyecto.Id, criterio.Id) == level.Score;
                                        <button type="button"
                                                class="rubric-level-btn @(isSelected ? "selected" : "") rubric-level-@level.Key"
                                                title="@level.Label (@level.Score)"
                                                @onclick="() => SetScore(proyecto.Id, criterio.Id, level.Score.ToString(CultureInfo.InvariantCulture))">
                                            <span class="rubric-level-key">@level.Key</span>
                                            <span class="rubric-level-label">@level.Label</span>
                                        </button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="score-input-group">
                                    <input type="text"
                                           class="score-input"
                                           inputmode="decimal"
                                           value="@scoresText[proyecto.Id][criterio.Id]"
                                           @oninput="e => OnInputChanged(proyecto.Id, criterio.Id, e.Value?.ToString())" />
                                    <span class="score-max">/ 10</span>
                                </div>
                            }

                            @if (sesion?.AllowCommentsPerCriterion == true)
                            {
                                <div class="criterion-comment-row" style="flex-basis: 100%; margin-top: 0.5rem;">
                                    <textarea rows="1"
                                              maxlength="300"
                                              style="width: 100%; padding: 0.4rem 0.6rem; border: 1px solid #e5e7eb; border-radius: 0.4rem; font-size: 0.85rem; resize: vertical; font-family: inherit; box-sizing: border-box;"
                                              placeholder="Comentario sobre este criterio (opcional)..."
                                              value="@GetCriterionComment(proyecto.Id, criterio.Id)"
                                              @oninput="e => SetCriterionComment(proyecto.Id, criterio.Id, e.Value?.ToString())" />
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (sesion?.AllowComments == true)
                {
                    <div class="weighted-comment-section">
                        <label class="weighted-comment-label">
                            Comentario
                            @if (sesion.RequireComments)
                            {
                                <span class="required-star">*</span>
                            }
                            else
                            {
                                <span class="optional-tag">(opcional)</span>
                            }
                        </label>
                        <textarea class="weighted-comment-textarea"
                                  rows="2"
                                  maxlength="500"
                                  @bind="comentarios[proyecto.Id]"
                                  placeholder="@(sesion.RequireComments ? "Obligatorio..." : "Añade un comentario sobre este proyecto...")" />
                        <div class="weighted-char-count">
                            @((comentarios.TryGetValue(proyecto.Id, out var txt) ? txt?.Length : 0) ?? 0)/500
                        </div>
                    </div>
                }
            </div>
        }

        @if (error != null)
        {
            <div class="weighted-error-banner">@error</div>
        }

        <button class="weighted-submit-btn" @onclick="EnviarVotos" disabled="@enviando">
            @if (enviando)
            {
                <span>Guardando...</span>
            }
            else
            {
                <span>
                    ✓ @(sesion?.VoterType == "Jury"
                        ? (haVotado ? "Modificar Veredicto" : "Emitir Veredicto")
                        : (haVotado ? "Modificar Evaluación" : "Confirmar Evaluación"))
                </span>
            }
        </button>
    }
</div>

@code {
    [Parameter] public string EventId { get; set; } = "";
    [Parameter] public string CategoryId { get; set; } = "";

    private List<ProjectDto>? proyectos;
    private List<CriterionDto> criterios = new();
    private VotingSessionSimpleDto? sesion;
    private string? criterionType;
    private string userId = "";
    private string? error;
    private bool enviando = false;
    private bool haVotado = false;

    private Dictionary<string, Dictionary<string, double>> scores = new();
    private Dictionary<string, string> comentarios = new();
    private Dictionary<string, Dictionary<string, string>> scoresText = new();
    private Dictionary<string, Dictionary<string, string>> comentariosCriterio = new();

    private static readonly List<RubricLevel> RubricLevels = new()
    {
        new("D", "Insuficiente", 0),
        new("C", "Regular",      2.5),
        new("B", "Bueno",        5),
        new("A", "Notable",      7.5),
        new("S", "Excelente",    10),
    };

    private record RubricLevel(string Key, string Label, double Score);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;

        var http = HttpClientFactory.CreateClient("API");

        try
        {
            var sesiones = await http.GetFromJsonAsync<List<VotingSessionSimpleDto>>(
                $"api/votingsessions/by-category/{CategoryId}");
            sesion = sesiones?.FirstOrDefault(s =>
                s.EvaluationType == "0" || s.EvaluationType == "WeightedScale");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }

        if (sesion != null)
        {
            criterios = sesion.Criteria;
            criterionType = sesion.CriterionType;
        }

        proyectos = await http.GetFromJsonAsync<List<ProjectDto>>(
            $"api/projects/by-category/{CategoryId}");

        if (proyectos != null)
        {
            foreach (var p in proyectos)
            {
                scores[p.Id] = criterios.ToDictionary(c => c.Id, _ => 0.0);
                scoresText[p.Id] = criterios.ToDictionary(c => c.Id, _ => "0");
                comentarios[p.Id] = "";
                comentariosCriterio[p.Id] = criterios.ToDictionary(c => c.Id, _ => "");
            }
        }

        if (!string.IsNullOrEmpty(userId) && sesion != null)
        {
            try
            {
                var previos = await http.GetFromJsonAsync<List<WeightedVoteDto>>(
                    $"api/votes/weighted?userId={userId}&votingSessionId={sesion.Id}");

                if (previos != null && previos.Any())
                {
                    foreach (var v in previos)
                    {
                        if (scores.ContainsKey(v.ProjectId))
                            scores[v.ProjectId][v.CriterionId] = v.Score;
                        if (scoresText.ContainsKey(v.ProjectId))
                            scoresText[v.ProjectId][v.CriterionId] = v.Score.ToString(CultureInfo.InvariantCulture);
                        if (!string.IsNullOrEmpty(v.Comment))
                            comentarios[v.ProjectId] = v.Comment;
                        if (!string.IsNullOrEmpty(v.CriterionComment))
                        {
                            if (!comentariosCriterio.ContainsKey(v.ProjectId))
                                comentariosCriterio[v.ProjectId] = new();
                            comentariosCriterio[v.ProjectId][v.CriterionId] = v.CriterionComment;
                        }
                    }
                    haVotado = true;
                }
            }
            catch { }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) { }

    private double GetScore(string projectId, string criterionId)
        => scores.TryGetValue(projectId, out var d) && d.TryGetValue(criterionId, out var v) ? v : 0;

    private void SetScore(string projectId, string criterionId, string? raw)
    {
        if (double.TryParse(raw, NumberStyles.Any, CultureInfo.InvariantCulture, out var val))
        {
            val = Math.Clamp(val, 0, 10);
            if (!scores.ContainsKey(projectId)) scores[projectId] = new();
            scores[projectId][criterionId] = val;

            if (!scoresText.ContainsKey(projectId)) scoresText[projectId] = new();
            scoresText[projectId][criterionId] = val == Math.Floor(val)
                ? val.ToString("0", CultureInfo.InvariantCulture)
                : val.ToString("0.#", CultureInfo.InvariantCulture);
        }
    }

    private string GetScoreString(string projectId, string criterionId)
    {
        var val = GetScore(projectId, criterionId);
        return val == Math.Floor(val)
            ? val.ToString("0", CultureInfo.InvariantCulture)
            : val.ToString("0.#", CultureInfo.InvariantCulture);
    }

    private void SetCheckbox(string projectId, string criterionId, object? value)
        => SetScore(projectId, criterionId, (value is bool b && b) ? "10" : "0");

    private string GetCriterionComment(string projectId, string criterionId)
        => comentariosCriterio.TryGetValue(projectId, out var d) && d.TryGetValue(criterionId, out var v)
            ? v
            : string.Empty;

    private void SetCriterionComment(string projectId, string criterionId, string? text)
    {
        if (!comentariosCriterio.ContainsKey(projectId))
            comentariosCriterio[projectId] = new();
        comentariosCriterio[projectId][criterionId] = text ?? string.Empty;
    }

    private double CalcularScore(string projectId)
    {
        if (!scores.TryGetValue(projectId, out var d)) return 0;
        return criterios.Sum(c => d.TryGetValue(c.Id, out var s) ? s * c.Weight : 0);
    }

    private string GetSubtitleForType() => criterionType switch
    {
        "Checklist" => "Marca cada criterio que el proyecto cumpla. La puntuación final es la suma ponderada de los criterios cumplidos.",
        "Rubric" => "Selecciona el nivel alcanzado en cada criterio. La puntuación final es la suma ponderada de los niveles elegidos.",
        _ => "Puntúa cada criterio de 0 a 10 para cada proyecto. La puntuación final es la suma ponderada de los criterios."
    };

    private string GetTypeLabel() => criterionType switch
    {
        "Checklist" => "✓ Checklist",
        "Rubric" => "▤ Rúbrica",
        _ => "# Numérico"
    };

    private void OnInputChanged(string pId, string cId, string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            scoresText[pId][cId] = raw ?? "";
            scores[pId][cId] = 0;
            return;
        }

        var normalized = raw.Replace(',', '.');

        if (double.TryParse(normalized, NumberStyles.Any, CultureInfo.InvariantCulture, out var val))
        {
            var clamped = Math.Clamp(val, 0, 10);
            scores[pId][cId] = clamped;

            if (val != clamped)
            {
                scoresText[pId][cId] = clamped == Math.Floor(clamped)
                    ? clamped.ToString("0", CultureInfo.InvariantCulture)
                    : clamped.ToString("0.#", CultureInfo.InvariantCulture);
            }
            else
            {
                scoresText[pId][cId] = raw;
            }
        }
        else
        {
            scoresText[pId][cId] = raw;
        }
    }

    private async Task EnviarVotos()
    {
        error = null;

        if (sesion == null) { error = "No hay sesión activa."; return; }

        if (sesion.RequireComments && proyectos!.Any(p => string.IsNullOrWhiteSpace(comentarios[p.Id])))
        {
            error = "El comentario es obligatorio en cada proyecto.";
            return;
        }

        enviando = true;
        try
        {
            var payload = new
            {
                EventId,
                UserId = userId,
                CategoryId,
                VotingSessionId = sesion.Id,
                Scores = proyectos!.Select(p => new
                {
                    ProjectId = p.Id,
                    Comment = string.IsNullOrWhiteSpace(comentarios[p.Id])
                        ? null : comentarios[p.Id].Trim(),
                    CriterionScores = criterios.Select(c => new
                    {
                        CriterionId = c.Id,
                        Score = GetScore(p.Id, c.Id),
                        Comment = sesion.AllowCommentsPerCriterion
                            ? (string.IsNullOrWhiteSpace(GetCriterionComment(p.Id, c.Id))
                                ? null
                                : GetCriterionComment(p.Id, c.Id).Trim())
                            : null
                    }).ToList()
                }).ToList()
            };

            var http = HttpClientFactory.CreateClient("API");
            var resp = await http.PostAsJsonAsync("api/votes/weighted-batch", payload);

            if (resp.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "¡Evaluación registrada!");
                Navigation.NavigateTo($"/event/{EventId}/categories/{CategoryId}/projects");
            }
            else
            {
                error = await resp.Content.ReadAsStringAsync();
                error = error?.Trim('"');
            }
        }
        finally
        {
            enviando = false;
        }
    }

    public class ProjectDto
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string? Description { get; set; }
    }

    public class CriterionDto
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public double Weight { get; set; }
    }

    public class VotingSessionSimpleDto
    {
        public string Id { get; set; } = "";
        public string EvaluationType { get; set; } = "";
        public string? CriterionType { get; set; }
        public bool AllowComments { get; set; }
        public bool RequireComments { get; set; }
        public bool AllowCommentsPerCriterion { get; set; }
        public string VoterType { get; set; } = string.Empty;
        public List<CriterionDto> Criteria { get; set; } = new();
    }

    public class WeightedVoteDto
    {
        public string ProjectId { get; set; } = "";
        public string CriterionId { get; set; } = "";
        public double Score { get; set; }
        public string? Comment { get; set; }
        public string? CriterionComment { get; set; }
    }
}