@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject BreadcrumbStateService BreadcrumbState
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (BreadcrumbState.Items.Count > 0)
            {
                <nav class="top-breadcrumb" aria-label="breadcrumb">
                    <ol>
                        @for (int i = 0; i < BreadcrumbState.Items.Count; i++)
                        {
                            var item = BreadcrumbState.Items[i];
                            bool isLast = i == BreadcrumbState.Items.Count - 1;
                            <li>
                                @if (item.Href != null && !isLast)
                                {
                                    <a href="@item.Href">@item.Label</a>
                                }
                                else
                                {
                                    <span class="@(isLast ? "bc-active" : "")">@item.Label</span>
                                }
                                @if (!isLast)
                                {
                                    <span class="bc-sep">›</span>
                                }
                            </li>
                        }
                    </ol>
                </nav>
            }

            <AuthorizeView>
                <Authorized>
                    <a href="/profile" class="avatar-nav-link" title="Ver perfil">
                        <div class="nav-avatar">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
                                <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z" />
                            </svg>
                        </div>
                    </a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn-login-top">Iniciar Sesión</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override void OnInitialized()
    {
        BreadcrumbState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        BreadcrumbState.OnChange -= StateHasChanged;
    }
}
