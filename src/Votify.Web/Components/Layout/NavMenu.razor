@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Votify</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="profile">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> Perfil
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="MainEvent">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Eventos
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="my-projects">
                            <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Mis Proyectos
                        </NavLink>
                    </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>
