@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory

<nav aria-label="breadcrumb" class="votify-breadcrumb">
    <ol>
        <li><a href="/MainEvent">Inicio</a></li>
        
        @if (isLoading)
        {
            <li class="active">Cargando ruta...</li>
        }
        else
        {
            @if (!string.IsNullOrEmpty(EventId))
            {
                <li><a href="/event/@EventId/categories">@(eventName ?? "Evento")</a></li>
            }
            
            @if (!string.IsNullOrEmpty(CategoryId))
            {
                <li><a href="/event/@EventId/categories/@CategoryId/projects">@(categoryName ?? "Categoría")</a></li>
            }

            @if (!string.IsNullOrEmpty(CurrentPageName))
            {
                <li class="active" aria-current="page">@CurrentPageName</li>
            }
        }
    </ol>
</nav>

<style>
    .votify-breadcrumb {
        background-color: #f8fafc;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
        border: 1px solid #e2e8f0;
    }
    .votify-breadcrumb ol {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        padding: 0;
        margin: 0;
        font-size: 0.875rem;
        font-weight: 500;
    }
    .votify-breadcrumb li {
        display: flex;
        align-items: center;
    }
    .votify-breadcrumb li:not(:last-child)::after {
        content: "›";
        margin: 0 0.5rem;
        color: #94a3b8;
        font-size: 1.2rem;
        line-height: 1;
    }
    .votify-breadcrumb a {
        color: #0284c7;
        text-decoration: none;
        transition: color 0.2s;
    }
    .votify-breadcrumb a:hover {
        color: #0369a1;
        text-decoration: underline;
    }
    .votify-breadcrumb li.active {
        color: #475569;
    }
</style>

@code {
    [Parameter] public string? EventId { get; set; }
    [Parameter] public string? CategoryId { get; set; }
    [Parameter] public string? CurrentPageName { get; set; }

    private string? eventName;
    private string? categoryName;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(EventId))
        {
            try
            {
                var http = HttpClientFactory.CreateClient("API");
                var evt = await http.GetFromJsonAsync<EventDto>($"api/events/{EventId}");
                
                if (evt != null)
                {
                    eventName = evt.Name;
                    
                    if (!string.IsNullOrEmpty(CategoryId))
                    {
                        var cat = evt.Categories?.FirstOrDefault(c => c.Id == CategoryId);
                        if (cat != null)
                        {
                            categoryName = cat.Name;
                        }
                    }
                }
            }
            catch
            {
                
            }
        }
        isLoading = false;
    }

    private class EventDto
    {
        public string Name { get; set; } = string.Empty;
        public List<CategoryDto> Categories { get; set; } = new();
    }

    private class CategoryDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }
}