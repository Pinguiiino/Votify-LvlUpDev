@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject BreadcrumbStateService BreadcrumbState
@implements IDisposable

@* Headless: sets breadcrumb state in the top-bar, renders nothing here *@

@code {
    [Parameter] public string? EventId { get; set; }
    [Parameter] public string? CategoryId { get; set; }
    [Parameter] public string? CurrentPageName { get; set; }

    private string? _eventName;
    private string? _categoryName;

    protected override async Task OnParametersSetAsync()
    {
        _eventName = null;
        _categoryName = null;

        if (!string.IsNullOrEmpty(EventId))
        {
            try
            {
                var http = HttpClientFactory.CreateClient("API");
                var evt = await http.GetFromJsonAsync<EventDto>($"api/events/{EventId}");
                if (evt != null)
                {
                    _eventName = evt.Name;
                    if (!string.IsNullOrEmpty(CategoryId))
                    {
                        var cat = evt.Categories?.FirstOrDefault(c => c.Id == CategoryId);
                        if (cat != null)
                            _categoryName = cat.Name;
                    }
                }
            }
            catch { }
        }

        PushState();
    }

    private void PushState()
    {
        var items = new List<BreadcrumbStateService.BreadcrumbItem>
        {
            new("Inicio", "/MainEvent")
        };

        if (!string.IsNullOrEmpty(EventId))
            items.Add(new(_eventName ?? "Evento", $"/event/{EventId}/categories"));

        if (!string.IsNullOrEmpty(CategoryId))
            items.Add(new(_categoryName ?? "Categoría", $"/event/{EventId}/categories/{CategoryId}/projects"));

        if (!string.IsNullOrEmpty(CurrentPageName))
            items.Add(new(CurrentPageName, null));

        BreadcrumbState.SetItems(items);
    }

    public void Dispose() => BreadcrumbState.Clear();

    private class EventDto
    {
        public string Name { get; set; } = string.Empty;
        public List<CategoryDto> Categories { get; set; } = new();
    }

    private class CategoryDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }
}
